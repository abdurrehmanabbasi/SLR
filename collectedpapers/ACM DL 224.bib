@inproceedings{10.1145/3788731.3788734,
author = {Liu, Zhuwei and Wang, Keming},
title = {A Logic-Driven Workflow Based on LLM Agents for High-Fidelity SMT Code Generation},
year = {2026},
isbn = {9798400722301},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3788731.3788734},
doi = {10.1145/3788731.3788734},
abstract = {Symbolic Model Checking (SMT) solvers are critical for ensuring system reliability, wherein high-quality SMT code constitutes the fundamental prerequisite for efficient execution. Nevertheless, Large Language Models (LLMs) struggle to generate syntactically and logically valid code for DSLs like SMT-LIB, particularly in resource-constrained settings. To address this, this study proposes LDSW(Logic-Driven SMT Code Generation Workflow), a novel framework that integrates an LLM agent workflow with Monte Carlo Tree Search (MCTS) to emulate an expert's iterative ‘generate-verify-rectify’ process. Guided by a hybrid fitness function incorporating real-time solver feedback across syntactic, semantic, and structural dimensions, LDSW conducts a principled exploration of the vast code space. In experiments on legal judgment reasoning, LDSW achieved a 90.5% Pass@3 success rate, significantly outperforming both the large model GPT-4 (71.3%) and fine-tuned small LLMs (75.1%).},
booktitle = {Proceedings of the 2025 International Conference on Embodied Intelligence and Large Models},
pages = {15–21},
numpages = {7},
keywords = {Monte Carlo tree search, SMT code generation, agent workflow, large language model},
location = {
},
series = {EILM '25}
}

@article{10.1016/j.procs.2024.06.041,
author = {Curasma, Herminio Paucar and Pan, Che Fan and Estrella, Julio Cezar},
title = {Agents for automatic control of sensors using Multi-Agent Systems and Ontologies: A scalable IoT architecture},
year = {2024},
issue_date = {2024},
publisher = {Elsevier Science Publishers B. V.},
address = {NLD},
volume = {238},
