  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10899238},
  abstract = {The soaring number of mobile devices has led the innovation of the edge caching in edge computing, which relieves the heavy pressure of cloud computing. However, with the escalating popularity of short video services, the prevalence of video content in edge server caches has seen a marked increase. Previous work ignored the impact of edge server performance on video caching and failed to automatically adjust the optimal video bit rate in response to users' demand. To improve users' evaluation for watching videos on devices with different display sizes, we propose a novel edge caching strategy called Gate Self-attention Recurrent Network-Multi Agent Reinforcement Learning(GSRN-MARL). GSRN-MARL utilizes leverages Gate Recurrent Unit(GRU) and attention mechanisms to predict cache content based on user historical request information and device details, consequently improving edge server caching performance and users' evaluation of video. Experiment demonstrates that GSRN-MARL surpasses LRU, DRL, and MAAC across two critical metrics: video cache hit rate and users' QoE (Quality of Experience).},
  publisher = {IEEE},
  isbn = {979-8-3315-0953-8},
  issn = {2767-2174},
  keywords = {video edge caching;multi-agents reinforcement learning;cooperative caching},
}

@article{automatedplanningforadaptivecy2024,
