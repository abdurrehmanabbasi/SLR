  abstract = {Developing efficient collaborative strategies for unmanned aerial vehicle (UAV) swarms is crucial for achieving accurate and rapid execution of the multitarget detecting (MTD) tasks which involve two primary stages in practical scenarios: 1) dispersed search by multi-UAVs in unknown dynamic environments to locate targets and 2) subsequent aggregation to gather all targets information within the scene, which called detecting and aggregation processes. In recent years, several collaborative strategy methods have been developed for application in UAV swarm mission scenarios. These methods are typically designed for single-stage tasks, and therefore their performance is likely to be suboptimal when applied to multistage tasks like the MTD tasks, which have distinctly different characteristics and objectives across stages. In this article, we propose a novel integrated deep reinforcement learning decision framework that can offer effective collaborative strategies for tasks characterized by distinct stages, denoted as the STDGNet. The STDGNet comprises a transformer-based deep graph network (TDGN) module alongside two specialized optimization strategies: 1) the location-dispersion strategy (LDS) and 2) the cluster-action-consistency strategy (CACS). The TDGN module is designed to extract features from observations and interaction dynamics among UAVs, aimed at generating collaborative strategies. The integration of two specialized strategies enables the STDGNet framework to adapt well to multistage tasks: during the detection stage, the LDS maintains UAV dispersal to expedite the discovery of more targets; during the aggregation stage, the CACS ensures that UAVs within the same cluster move in the same direction, facilitating the formation of interconnected communication networks. To assess the efficiency and resilience of the proposed framework, we construct an MTD environment where extensive experimentation shows that the STDGNet framework surpasses baseline methodologies.},
  publisher = {IEEE},
  issn = {2327-4662},
  keywords = {Graph attention mechanism;multiagent deep reinforcement learning (MADRL);multitarget detection (MTD) task;unmanned aerial vehicle (UAV) swarm planning},
}

