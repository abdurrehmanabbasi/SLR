@article{coramarlcostandresourceawaremu2025,
  author = {R. K. Para},
  title = {{CORA-MARL:} {Cost-and} {Resource-Aware} {MultiAgent} {Reinforcement} {Learning} {Framework}},
  journal = {2025 International Conference on Applied Artificial Intelligence, Data Engineering and Sciences (ICAIDES)},
  year = {2025},
  pages = {1--6},
  doi = {10.1109/ICAIDES67265.2025.11404025},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11404025},
  abstract = {Multi-agent reinforcement learning (MARL) has shown promise in complex domains, yet deployment remains limited by assumptions of unlimited resources and simplistic credit assignment. This paper introduces CORA-MARL, the first unified framework that jointly optimizes agent policies, tool use, and resource allocation under realistic constraints. CORAMARL combines: (i) a causal influence module that attributes outcomes to both primitive actions and costly tool invocations via counterfactual reasoning, (ii) heterogeneous agent policies with expanded action spaces that balance task performance against resource expenditures, and (iii) a system-level resource manager that dynamically allocates computation and communication capacity and adjusts tool-use penalties in response to load. Embedding costs of perception, communication, and API calls directly into training enables agents to learn when, why, and which tools to invoke, with causal credit reinforcing only pivotal actions. Experiments in collaborative software debugging show CORA-MARL improves coordination and efficiency, achieving higher bug-fix accuracy while reducing redundant calls. Two new metrics: Tool-Use Efficiency (TUE), reward per unit cost, and Causal Attribution Fidelity (CAF), fidelity of causal attribution formally capture these gains. Results are statistically significant across $\boldsymbol\{\geqslant\} \mathbf\{5\}$ random seeds with $\mathbf\{9 5 \%\}$ Confidence Intervals; a mixed-effects analysis shows large effects (partial $\eta^\{\wedge\} \mathbf\{2\} \geqslant \mathbf\{0. 1 8\}$) on success, TUE, and CAF.},
  publisher = {IEEE},
  isbn = {979-8-3315-6498-8},
  keywords = {Multi-agent Reinforcement Learning (MARL);Causal Credit Assignment;Resource Aware Learning;Adaptive Resource Management;Software Debugging Agents},
}

