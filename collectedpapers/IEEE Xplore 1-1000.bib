@article{multiagentpathfindingsimulatio2025,
  author = {N. I. Ismail; S. N. Ihsan; T. A. A. Kadir},
  title = {{Multi-Agent} {Pathfinding} {Simulation} for {Evacuation} in {Dynamic} {Indoor} {Environment}},
  journal = {2025 IEEE 9th International Conference on Software Engineering \& Computer Systems (ICSECS)},
  year = {2025},
  pages = {258--263},
  doi = {10.1109/ICSECS65227.2025.11279244},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11279244},
  abstract = {In January 2024, a five-alarm fire in a New Jersey office complex exposed the ongoing vulnerability of workplaces to dynamic emergency conditions, despite existing safety protocols. This study evaluates three Multi-Agent Pathfinding (MAPF) algorithms which include Conflict-Based Search (CBS), Learning- based Cooperative Multi-Agent Exploration (LC-MAE), and A*, in a simulated evacuation setting with both dynamic and static obstacles, including fire, smoke, boxes, and crowd congestion. An indoor evacuation simulator, which consists of a grid office layout, was developed to enable direct comparison of algorithm performance under identical emergency conditions. Victim agents adapt their routes in real time, optimizing for safety, speed, or shortest distance to exit. Evaluation metrics include evacuation time, exit selection, evacuation success rate, obstacles encountered, and obstacle avoidance. The results show that CBS achieves the highest rate of safe evacuations but with slightly longer times, while $\mathrm\{A\}^\{*\}$ is the fastest but less effective in congested scenarios. LC-MAE demonstrates a balance between adaptability and efficiency. Quantitatively, CBS reached a 95.8% success rate with the fewest timeouts, compared to 91.7% for both LC-MAE and A*, while all three algorithms achieved a 92.2% obstacle avoidance rate with similar average evacuation times ($3.32-3.33 \mathrm\{~s\}$). The findings highlight the importance of robust pathfinding in dynamic indoor emergencies. Future enhancements will include supporting multiple victim agents and random obstacle placement to further assess algorithm performance and scalability.},
  publisher = {IEEE},
  isbn = {979-8-3315-4441-6},
  keywords = {MAPF;simulation;evacuation;indoor environment},
}

@article{adistributedprivacypreservingl2023,
  author = {Y. Tao; S. Chen; F. Li; D. Yu; J. Yu; H. Sheng},
  title = {{A} {Distributed} {Privacy-Preserving} {Learning} {Dynamics} in {General} {Social} {Networks}},
  journal = {IEEE Transactions on Knowledge and Data Engineering},
  year = {2023},
  volume = {35},
  number = {9},
  pages = {9547--9561},
  doi = {10.1109/TKDE.2023.3241442},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10035414},
  abstract = {In this article, we study a distributed privacy-preserving learning problem in social networks with general topology. The agents can communicate with each other over the network, which may result in privacy disclosure, since the trustworthiness of the agents cannot be guaranteed. Given a set of options which yield unknown stochastic rewards, each agent is required to learn the best one, aiming at maximizing the resulting expected average cumulative reward. To serve the above goal, we propose a four-staged distributed algorithm which efficiently exploits the collaboration among the agents while preserving the local privacy for each of them. In particular, our algorithm proceeds iteratively, and in every round, each agent i) randomly perturbs its adoption for the privacy-preserving purpose, ii) disseminates the perturbed adoption over the social network in a nearly uniform manner through random walking, iii) selects an option by referring to the perturbed suggestions received from its peers, and iv) decides whether or not to adopt the selected option as preference according to its latest reward feedback. Through solid theoretical analysis, we quantify the trade-off among the number of agents (or communication overhead), privacy preserving and learning utility. We also perform extensive simulations to verify the efficacy of our proposed social learning algorithm.},
  publisher = {IEEE},
  issn = {1558-2191},
  keywords = {Distributed learning;privacy preservation;social networks},
}

@article{learningandrepairofdeepreinfor2024,
  author = {M. Tappler; A. Pferscher; B. K. Aichernig; B. KÃ¶nighofer},
  title = {{Learning} and {Repair} of {Deep} {Reinforcement} {Learning} {Policies} from {Fuzz-Testing} {Data}},
  journal = {2024 IEEE/ACM 46th International Conference on Software Engineering (ICSE)},
  year = {2024},
  pages = {38--50},
  doi = {10.1145/3597503.3623311},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10548388},
  abstract = {Reinforcement learning from demonstrations (RLfD) is a promising approach to improve the exploration efficiency of reinforcement learning (RL) by learning from expert demonstrations in addition to interactions with the environment. In this paper, we propose a framework that combines techniques from search-based testing with RLfD with the goal to raise the level of dependability of RL policies and to reduce human engineering effort. Within our framework, we provide methods for efficiently training, evaluating, and repairing RL policies. Instead of relying on the costly collection of demonstrations from (human) experts, we automatically compute a diverse set of demonstrations via search-based fuzzing methods and use the fuzz demonstrations for RLfD. To evaluate the safety and robustness of the trained RL agent, we search for safety-critical scenarios in the black-box environment. Finally, when unsafe behavior is detected, we compute demonstrations through fuzz testing that represent safe behavior and use them to repair the policy. Our experiments show that our framework is able to efficiently learn high-performing and safe policies without requiring any expert knowledge.},
  publisher = {IEEE},
  isbn = {979-8-4007-0217-4},
  issn = {1558-1225},
  keywords = {Deep reinforcement learning;Reinforcement learning from demonstrations;Search-based software testing;Policy repair},
}

@article{adaptiverandomtestingformultia2022,
