  journal = {IEEE Internet of Things Journal},
  year = {2025},
  volume = {12},
  number = {17},
  pages = {34863--34874},
  doi = {10.1109/JIOT.2025.3586089},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11071977},
  abstract = {Smart grids (SGs), powered by Industrial Internet of Things (IIoT) technologies, enable real-time monitoring and intelligent energy management, promoting carbon reduction and sustainability. However, integrating distributed energy resources like solar, wind, and prosumers introduces challenges, such as mismatches in production and consumption, grid imbalances, and energy losses. Centralized, static supplyâdemand balancing approaches struggle to address these complexities in carbon-aware intelligent IIoT. This article presents a cooperative distributed multiagent system (CD-MAS) for SG IIoT, fostering decentralized, real-time collaboration among producers, distributors, consumers, and prosumers. The system leverages self-optimizing agents to enhance carbon efficiency and grid resilience. Key features include consumer profile analysis to create adaptive virtual neighborhoods (VNs) for targeted energy programs and distributed energy prediction for accurate demand forecasting and demandâsupply balancing with localized load-shedding strategies. The proposed CD-MAS advances SG capabilities, optimizing energy use and achieving net-zero carbon goals.},
  publisher = {IEEE},
  issn = {2327-4662},
  keywords = {Carbon-aware;distributed agents;energy prediction;Industrial Internet of Things (IIoT);smart grids (SGs)},
}

@article{allinoneframeworkfordesignsimu2024,
  author = {L. Xue; G. -P. Liu; W. Hu},
  title = {{All-in-One} {Framework} for {Design,} {Simulation,} and {Practical} {Implementation} of {Distributed} {Multiagent} {Control} {Systems}},
