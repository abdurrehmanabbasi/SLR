@article{semanticallyawarellmagenttoenh2025,
  author = {J. Serenari; S. Lee},
  title = {{Semantically-Aware} {LLM} {Agent} to {Enhance} {Privacy} in {Conversational} {AI} {Services}},
  journal = {2025 IEEE International Conference on Big Data (BigData)},
