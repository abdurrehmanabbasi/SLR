@article{confidentbutincorrectmitigatin2025,
  author = {Y. Tripathi; V. Kohli; S. Misra},
  title = {{Confident} but {Incorrect:} {Mitigating} {Hallucination} and {Overconfidence} in {Agentic} {AI} {Coders}},
  journal = {2025 Eighth International Conference on Image Information Processing (ICIIP)},
  year = {2025},
  pages = {723--728},
  doi = {10.1109/ICIIP68302.2025.11346318},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11346318},
  abstract = {Agentic AI capable of independent software development is transforming productivity in engineering. But their increasing independence brings up important dependability issues that require careful thought. These systems typically produce code that seems technically sound at first glance but has underlying logical or functional errors; this issue is called hallucination. The problem worsens and there are fewer opportunities for human review or confirmation when such erroneous outputs are given excessive confidence. The study presented here claims that the systematic cause of these shortcomings is training approaches in big language models that emphasize reinforcement learning based on human feedback and aimed at terminal outcomes. Such methods, which prioritize seeming plausibility over substantive truth and encourage stylistic coherence at the expense of rigorous reasoning, jeopardize the software architecturesâ ongoing resilience. To counter this, a different training strategy is advised. The primary change, referred to as reinforcement learning from process supervision, causes supervisors to focus on intermediate reasoning paths rather than terminal products. This alignment includes tried-and-true engineering techniques that place a high value on sequential verification and clear justification articulation. A subsequent improvement includes formal verification and uncertainty estimates in the generative pipeline, which allows models to detect and signal epistemic constraints in code synthesis. These interventions are supported by empirical evaluations: on a defined benchmark group, the pass-at-one accuracy measure improved by 14 percentage points compared to the baseline, and the ROC curve area increased from 0.68 to 0.78, indicating improved failure anticipation efficacy. These results provide a viable path for agentic AI to participate in programming tasks as trustworthy, reflective partners, instead of assertive but faulty assistants.},
  publisher = {IEEE},
  isbn = {979-8-3315-5618-1},
  issn = {2640-074X},
  keywords = {agentic AI;code generation;hallucination;large language models;reinforcement learning;process supervision;uncertainty quantification;software reliability;formal verification},
}

