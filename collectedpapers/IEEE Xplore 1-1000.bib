  title = {{A} {Comprehensive} {Review} of {Parallel} {Autonomy} {Systems} {Within} {Vehicles:} {Applications,} {Architectures,} {Safety} {Considerations,} and {Standards}},
  journal = {IEEE Access},
  year = {2024},
  volume = {12},
