  title = {{A} {Multi-Agent} {Workflow} for {3D} {Visualization} {Code} {Generation} and {Evaluation} {Based} on {Spatial-MLLM}},
  journal = {2025 4th International Conference on Image Processing, Computer Vision and Machine Learning (ICICML)},
  year = {2025},
  pages = {512--518},
  doi = {10.1109/ICICML67980.2025.11333708},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11333708},
  abstract = {Large Language Models (LLMs) have demonstrated remarkable performance in code generation but still face significant limitations in specialized domains such as scientific visualization. First, they struggle to interpret spatial semantics in engineering modeling videos, resulting in incomplete task understanding when relying solely on textual descriptions. Second, directly generated code often suffers from structural instability and low accuracy. To address these challenges, this paper proposes a multi-agent collaborative 3D visualization code generation workflow based on Spatial-MLLM, which integrates the retrieval-augmented generation (RAG) capability of ChatVis with the stepwise logic of multi-stage guided code generation (MSG).The proposed workflow consists of five core modules: planning, design, generation, feedback, and evaluation. In the planning stage, Spatial-MLLM analyzes video and natural language inputs to generate a Directed Acyclic Graph (DAG) that explicitly defines task logic. The design stage transforms the DAG into a structured code sketch containing a Structure Chain of Thought (SCoT) to ensure controllable code structure. During the generation stage, RAG techniques are used to fill in API-level details, producing initial Python/VTK/ParaView scripts. The feedbackâgeneration loop refines the code through analysis of execution logs and rendering results, enabling iterative optimization. Finally, the system performs a dual-level evaluation using SSIM/PSNR for image-level similarity and AST structural matching for code-level accuracy. Experimental results demonstrate that the proposed workflow significantly reduces the semantic gap between video-based spatial understanding and executable visualization code. Compared to direct generation methods such as ChatGPT, our approach achieves notably higher task success rates and API invocation accuracy, providing domain experts with a low-barrier, high-reliability solution for automated visualization code generation.},
  publisher = {IEEE},
  isbn = {979-8-3315-6581-7},
  keywords = {engineering modeling videos;multi-agent;VTK;automated visualization},
}

