@article{cosqaenhancingcodesearchevalua2026,
  author = {J. Gong; Y. Wu; L. Liang; Y. Wang; J. Chen; M. Liu; Z. Zheng},
  title = {{CoSQA+:} {Enhancing} {Code} {Search} {Evaluation} {With} a {Multi-Choice} {Benchmark} and {Test-Driven} {Agents}},
