  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11252938},
  abstract = {Older men who live alone tend to face a heightened risk of social isolation, as masculine norms can limit emotional expression and help-seeking. This study examined how these individuals referenced social relationships and expressed emotions during daily conversations with a virtual agent named "Mei-chan." Using real-world data from dialogue logs with Mei-chan collected over ten months from two older men living alone, we applied a mixed-methods approach integrating machine learning-based sentiment analysis with qualitative interpretation. Three key findings emerged. First, mentions of social relationships were sometimes accompanied by emotionally negative expressions, suggesting that Mei-chan provided emotionally safe space for sharing sensitive concerns. Second, discrepancies between algorithmic and human-coded sentiments underscored the importance of contextual understanding in emotion detection. Third, participants demonstrated unconventional forms of connection, including a perceived sense of companionship with Mei-chan and a form of spiritual connectedness through references to sutra chanting. These results highlight the value of combining computational and interpretive methods to better understand emotional dynamics and relational expression in later life.},
