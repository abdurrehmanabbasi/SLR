@article{multiagentdebatestrategiestoen2025,
  author = {M. Oriol; Q. Motger; J. Marco; X. Franch},
  title = {{Multi-Agent} {Debate} {Strategies} to {Enhance} {Requirements} {Engineering} with {Large} {Language} {Models}},
  journal = {2025 IEEE 33rd International Requirements Engineering Conference (RE)},
