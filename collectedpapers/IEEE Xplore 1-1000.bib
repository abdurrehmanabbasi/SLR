@article{integratedreinforcementlearnin2025,
  author = {Y. Zhao; S. Lu; C. Wang; Y. Liu; Y. Ding; H. Wang},
  title = {{Integrated} {Reinforcement} {Learning} {Framework} for {UAV} {Swarm} {Two-Stage} {Cooperative} {Multitarget} {Detection} {Tasks}},
