@article{researchonmultimodaloptimizati2024,
  author = {Q. Chen; R. Tang},
  title = {{Research} on {Multimodal} {Optimization} {Mechanism} based on {Machine} {Learning}},
  journal = {2024 3rd International Conference on Cloud Computing, Big Data Application and Software Engineering (CBASE)},
  year = {2024},
  pages = {669--672},
  doi = {10.1109/CBASE64041.2024.10824625},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10824625},
  abstract = {As modern engineering optimisation problems become increasingly complex, a significant number of them exhibit multimodal characteristics. This implies that there are multiple local optimal solutions and a single global optimal solution. This not only increases the difficulty of problem-solving, but also necessitates the development of more sophisticated algorithms for optimisation. In this work, by constructing intelligent agents to continuously optimize their behavior strategies in the search process of multimodal optimization problems, they use environmental feedback to continuously optimize their behavior strategies, and at the same time simulate the process of natural selection and genetic variation to generate multiple candidate solutions, so as to conduct extensive searches on a global scale. Deep neural networks are used to build policy networks and value networks for reinforcement learning agents, enabling agents to accurately predict the potential benefits of different search strategies through a large amount of training data. Through real-time monitoring and analysis of feedback information, the model dynamically adjusts the search strategy to balance exploration and utilization, avoid falling into the local optimal solution, and finally find the global optimal solution. Experimental analysis shows that the model performs well in dealing with complex multimodal optimization problems, and significantly improves the efficiency and effect of solving.},
  publisher = {IEEE},
  isbn = {979-8-3315-0658-2},
  keywords = {multimodal optimization;machine learning;deep neural network;dynamic strategy},
}

@article{amarlagilemultiagentreinforcem2025,
