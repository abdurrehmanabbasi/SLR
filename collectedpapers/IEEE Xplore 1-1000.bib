  title = {{Debate,} {Verify,} and {Debug:} {A} {Multi-Agent} {Planning} {Framework} for {Reliable} {Code} {Generation}},
  journal = {2025 IEEE 8th International Conference on Computer and Communication Engineering Technology (CCET)},
