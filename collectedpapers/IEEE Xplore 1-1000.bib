@article{anaccountabilitybasedarchitect2025,
  author = {M. Becattini; R. Verdecchia; E. Vicario},
  title = {{An} {Accountability-Based} {Architectural} {Tactic} for {Agent} {Cooperation} in {LLM-Based} {Multi-Agent} {Systems}},
