@article{heterogeneousmultiagentreinfor2025,
  author = {X. Nie; X. Wan; S. Li; Q. Zhou; L. Liao; X. Zhu; J. Zhang},
  title = {{Heterogeneous} {Multi-Agent} {Reinforcement} {Learning} for {Resource} {Allocation} in {NOMA-Enabled} {mmWave} {IAB} {Networks}},
  journal = {IEEE Open Journal of the Communications Society},
  year = {2025},
  volume = {6},
  pages = {10816--10828},
  doi = {10.1109/OJCOMS.2025.3648044},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11313859},
  abstract = {The rapid densification of next-generation wireless networks has underscored the need for scalable and cost-effective backhaul solutions. Integrated access and backhaul (IAB) networks have emerged as a promising paradigm by replacing costly optical fiber with wireless connectivity. This paper investigates a multi-hop IAB architecture that jointly exploits Sub-6 GHz and millimeter-wave (mmWave) bands, where the Sub-6 GHz spectrum simultaneously supports access and cross-tier backhaul links, while the mmWave spectrum provides high-throughput intra-cluster transmissions. To further enhance spectral efficiency, power-domain non-orthogonal multiple access (PD-NOMA) is incorporated into the considered architecture. The resulting resource management problem requires the joint optimization of discrete subchannel assignment and continuous power allocation, which leads to a high-dimensional, non-convex mixed-integer nonlinear programming (MINLP) formulation. To address this challenge, we develop a heterogeneous multi-agent deterministic policy-dueling (HM2DP) framework that integrates adversarial learning with deterministic policy gradients. The proposed scheme enables efficient decision-making in mixed action spaces while ensuring convergence under complex network conditions. Simulation results demonstrate that HM2DP significantly improves user access rates and system capacity compared with state-of-the-art baselines, highlighting its effectiveness for next-generation IAB networks.},
  publisher = {IEEE},
  issn = {2644-125X},
  keywords = {Integrated access and backhaul;sub-channel allocation;power control;non-orthogonal multiple access;deep reinforcement learning},
}

@article{llmdrivencloudedgecollaboratio2025,
