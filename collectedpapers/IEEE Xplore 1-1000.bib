@article{fixingbrokengraphsllmpoweredau2025,
  author = {H. Wang; Y. Sui; Y. Xie; Y. Liu; Y. Sun; C. Shi; Y. Zhang},
  title = {{Fixing} {Broken} {Graphs:} {LLM-Powered} {Automatic} {Code} {Optimization} for {DNN} {Programs}},
  journal = {2025 40th IEEE/ACM International Conference on Automated Software Engineering (ASE)},
