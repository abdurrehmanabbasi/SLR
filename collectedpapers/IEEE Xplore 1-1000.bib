  doi = {10.1109/ICSEC67360.2025.11298019},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11298019},
  abstract = {Large Language Models have achieved impressive progress in natural-language understanding and generation, yet their reasoning remains fragile and prone to hallucinations. In high-stakes domains (e.g., law, finance, healthcare), reliability and interpretability are essential. This paper proposes a conceptual framework for Hybrid Reasoning Agents (HRA) that integrates symbolic logic with neural language models to enhance computational intelligence. The architecture couples the linguistic adaptability of LLMs with a symbolic reasoning engine for rule verification and consistency checks, a memory manager for scalable context compression and retrieval, and a controller that orchestrates component interactions. Through theoretical analysis and illustrative examples, we show how the hybrid design can reduce reasoning errors, produce interpretable outputs, and support trustworthy decision making. Our contributions are: (i) a unified agent architecture combining neural, symbolic, memory, and control modules; (ii) a conceptual analysis clarifying pathways to soundness, interpretability, and adaptability; and (iii) an application perspective for audit-ready reasoning in sensitive domains. While primarily conceptual, we outline a roadmap for empirical validation via a full-loop prototype and standardized benchmarks (e.g., GSM8K, RuleTaker, ProofWriter), reporting accuracy, logical violation rate, hallucination rate, latency, and computational overhead to substantiate reliability, scalability, and interpretability.},
  publisher = {IEEE},
  isbn = {979-8-3315-7383-6},
  issn = {2768-0592},
  keywords = {computational intelligence;hybrid reasoning;symbolic ai;large language models;agent framework},
}

