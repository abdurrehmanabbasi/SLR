@article{soen101codegenerationbyemulati2025,
  author = {F. Lin; D. J. Kim; T. -H. Chen},
  title = {{SOEN-101:} {Code} {Generation} by {Emulating} {Software} {Process} {Models} {Using} {Large} {Language} {Model} {Agents}},
