  keywords = {large language models;software engineering;AI agents},
}

@article{inprawebinaction2025,
  author = {A. Karunananda; T. Silva; D. Handapangoda; S. Sumanapala; L. Ariyasinghe},
  title = {{InPRAWeb} in {Action}},
  journal = {2025 9th SLAAI International Conference on Artificial Intelligence (SLAAI-ICAI)},
  year = {2025},
  pages = {1--6},
  doi = {10.1109/SLAAI-ICAI68534.2025.11318542},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11318542},
  abstract = {The Scientific Method, introduced over four centuries ago, brought a systematic approach to research. Yet, the process of discovering knowledge and making groundbreaking inventions remains a formidable challenge. Exceptional minds like Newton and Einstein emerge rarely, perhaps once in several centuries. Among various cognitive skills, research ability is one of the hardest to develop within formal education systems and often receives limited focus. In the era of Generative AI, numerous tools allow novice researchers to generate documents or simulate research tasks with ease. While convenient, this can hinder the organic development of core research skills. To address the above concern, we develop InPRAWeb â the Intelligent Personal Research Assistant for the Web. InPRAWeb is designed to guide novice researchers through the research process, helping them actively engage and develop skills, rather than outsourcing the process to automation. InPRAWeb features three intelligent agents: the Enthusiastic Research Assistant, the Incremental Writing Assistant, and the Elegant Presentation Assistant. These agents work together to support the user in developing research ideas, composing structured documents, and preparing presentations incrementally. Each agent operates based on a common architecture comprising three components: a Visualizer, Dashboard, and Organizer. Notably, InPRAWeb âwakes upâ thinking about the novice researcher, consciously building the organizer without relying on memory. Rather than doing research for the user, it encourages full cognitive engagement throughout the process. Evaluation of InPRAWeb highlights its potential to support efficient research processes. Overall, the findings show that users view the InPRA system as useful and supportive across key stages of the research process, enhancing productivity while offering an accessible experience. InPRAWeb fosters a more conscious and enjoyable research experience.},
  publisher = {IEEE},
  isbn = {979-8-3315-6123-9},
  keywords = {Research Methods;Multi-Agent Systems},
}

@article{llmpathyamultiagentllmapproach2025,
