  author = {Z. Cao; C. Xie; Y. Huang; Y. Li; J. Liu; Z. Gao},
  title = {{Hybrid} {Opinion} {Dynamics} {Model} {Based} on {Community} {Relations} and {Neighbourhood} {Similarity}},
