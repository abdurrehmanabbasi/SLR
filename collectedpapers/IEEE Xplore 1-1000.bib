@article{sdlcautopilotaiagenticautomati2025,
  author = {P. R. P; T. M; C. Q. Jaslin},
  title = {{SDLC} {AutoPilot} {AI:} {Agentic} {Automation} of {Software} {Development} {Life} {Cycle}},
