@article{distributedtaskallocationwithm2025,
  author = {S. Li; C. Wang; J. Sun; S. Zhang; G. Xie},
  title = {{Distributed} {Task} {Allocation} {With} {Minimum} {Makespan} for {Heterogeneous} {Multiplayer} {PursuitâEvasion} {Games}},
  journal = {IEEE Transactions on Automatic Control},
  year = {2025},
  volume = {70},
