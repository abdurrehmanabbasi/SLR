@article{anisochronbasedsolutiontopursu2025,
  author = {S. Li; C. Wang; G. Xie},
  title = {{An} {Isochron-Based} {Solution} to {PursuitâEvasion} {Games} of {Two} {Heterogeneous} {Players}},
  journal = {IEEE Transactions on Automatic Control},
  year = {2025},
