  title = {{Air-M:} {A} {Visual} {Reality} {Many-Agent} {Reinforcement} {Learning} {Platform} for {Large-Scale} {Aerial} {Unmanned} {System}},
  journal = {2023 IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS)},
  year = {2023},
