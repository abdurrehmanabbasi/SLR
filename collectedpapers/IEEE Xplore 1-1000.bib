  doi = {10.1109/FLLM67465.2025.11391011},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11391011},
  abstract = {The rapid evolution of 6G-enabled IoT ecosystems has significantly increased the risk of sophisticated cyberattacks, highlighting the need for adaptive and efficient intrusion detection systems. This paper presents a novel Differentiable Neural Architecture Search (DNAS) framework designed for cross-domain cyberattack detection. Unlike traditional intrusion detection models that rely on fixed or manually engineered architectures, our approach employs a differentiable optimization process to jointly refine both network structures and weights, ensuring an optimal balance between accuracy, robustness, and computational efficiency. To enhance resilience, the search space is extended with domain-aware operators, including temporal convolutions, lightweight attention blocks, and residual connections, allowing the model to effectively handle diverse IoT traffic patterns and complex attack vectors. In addition, a cross-domain consistency regularization mechanism enforces alignment of learned representations across heterogeneous IoT domains, minimizing false positives when exposed to unseen environments. The proposed approach achieves 99.2% accuracy, macro F1-score of 0.992, and a false alarm rate of 0.8%. Experimental analysis demonstrates that our framework achieves superior performance compared to conventional deep learning and baseline NAS methods. These findings confirm that embedding domain-specific operators and cross-domain regularization into NAS delivers a scalable, robust, and future-proof solution for intrusion detection in 6G-enabled IoT ecosystems.},
  publisher = {IEEE},
  isbn = {979-8-3315-9409-1},
  keywords = {Intrusion Detection IDS;IoT Security;6G;Differentiable Neural Architecture Search DNAS;Domain Adaptation},
}

@article{debateverifyanddebugamultiagen2025,
