@article{ahierarchicalhybridintelligenc2025,
  author = {T. Zhang; J. Lyu; Y. Cai},
  title = {{A} {Hierarchical} {Hybrid-Intelligence} {Architecture} with {Consensus,} {Debate,} and {Reflection} for {High-Fidelity} {NL-to-PPTL} {Conversion}},
  journal = {2025 32nd Asia-Pacific Software Engineering Conference (APSEC)},
  year = {2025},
  pages = {69--80},
  doi = {10.1109/APSEC66846.2025.00018},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11396571},
  abstract = {In aerospace engineering, ensuring system safety mandates the formal verification of requirements. Propositional Projection Temporal Logic (PPTL) is a critical formalism for this purpose, enabling the precise specification of complex temporal behaviors and state-based constraints for automated model checking. However, converting natural language (NL) requirements into PPTL is a significant challenge, as Large Language Models (LLMs) often produce unreliable outputs due to inherent non-determinism and hallucination. To overcome this, we propose a hierarchical hybrid-intelligence architecture that systematically mitigates these LLM weaknesses. Our framework orchestrates collaboration through three core mechanisms: Consensus and Debate to filter errors, Authoritative Reflection by a expert model (GPT-4o) to ensure logical correctness, and a Closed-Loop Self-Correction cycle driven by actionable feedback. The system is further enhanced with Knowledge-Augmented InContext Learning from a curated aerospace knowledge base. On a dataset of real-world aerospace requirements, our framework increased the accuracy of NL-to-PPTL conversion from a 69.4 % baseline to $\mathbf\{8 8. 4 \%\}$.In addition, $\mathbf\{2, 0 0 0\}$ pieces of data were randomly selected in an open source synthetic data set, and our accuracy reached 92.9%. By emulating an expert âpropose-review-correctâ workflow, our architecture effectively constrains LLMs for reliable application in high-stakes formal methods, paving a scalable path toward safer system development.},
  publisher = {IEEE},
  isbn = {979-8-3315-6653-1},
  issn = {2640-0715},
  keywords = {Formal Methods;Temporal Logic;Natural Language Processing;Large Language Models;Multi-Agent Systems},
}

@article{areviewoncodegenerationwithllm2023,
