}

@article{agentforusertestingmultiuserin2025,
  author = {S. Feng; C. Du; H. Liu; Q. Wang; Z. Lv; G. Huo; X. Yang; C. Chen},
  title = {{Agent} for {User:} {Testing} {Multi} - {User} {Interactive} {Features} in {TikTok}},
