  title = {{Let} the {Code} {Speak:} {Incorporating} {Program} {Dynamic} {State} for {Better} {Method-Level} {Fault} {Localization}},
  journal = {2025 40th IEEE/ACM International Conference on Automated Software Engineering (ASE)},
