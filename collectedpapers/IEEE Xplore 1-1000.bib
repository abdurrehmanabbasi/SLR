  abstract = {Automated program repair (APR) has emerged as a promising solution to mitigate the escalating cost and complexity of software maintenance, yet current approaches suffer from inefficiencies in problem localization and excessive token consumption when employing large language models (LLMs). To address this gap, this study proposes KeBugFix, a novel LLM-based framework that integrates code retrieval and feature extraction to enhance repair performance while minimizing computational overhead. The KeBugFix framework is composed of two stages: (1) an enhanced bug localization phase that utilizes SourceGraph, a semantic code search tool, in conjunction with LLM-driven keyword extraction to augment issue descriptions with relevant file paths; (2) an autonomous iterative repair phase involving two interacting agentsâTHOUGHT and ACTIONâthat emulate human-like reasoning and execution workflows. Evaluation was conducted on the SWE-bench Verified dataset, encompassing 500 manually validated software defects across 12 popular open-source Python repositories. Experimental results demonstrate that KeBugFix significantly outperforms the SWE-agent baseline. It reduces average input token usage from 480,000 to 220,000 and cuts LLM API calls by 60.5%, while slightly improving the repair success rate from 23.4% to 24.2%. Additionally, inference latency was reduced by 8.9%, reflecting improved operational efficiency without compromising accuracy.},
  publisher = {IEEE},
  isbn = {979-8-3315-9447-3},
  issn = {2573-2978},
  keywords = {Automated Program Repair;Large Language Models;Code Retrieval;Token Optimization},
}

@article{generativeaibasedchatbotforcus2025,
