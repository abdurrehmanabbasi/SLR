@article{acloudbased3ddigitaltwinforara2023,
  author = {M. Abduljabbar; M. Gochoo; M. T. Sultan; G. Batnasan; M. -E. Otgonbold; J. Berengueres; F. Alnajjar; A. A. Rasheed; A. Alshamsi; N. Alsaedi},
  title = {{A} {Cloud-Based} {3D} {Digital} {Twin} for {Arabic} {Sign} {Language} {Alphabet} {Using} {Machine} {Learning} {Object} {Detection} {Model}},
  journal = {2023 15th International Conference on Innovations in Information Technology (IIT)},
  year = {2023},
