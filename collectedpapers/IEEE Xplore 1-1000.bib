@article{ieeeaistandardsforagenticsyste2025,
  author = {R. J. Tong; H. Li; S. Raghavan; Q. Wen; S. Gray; A. Paul; J. Liang; J. Zalewski; Y. Yang; G. Tambouratzis; B. C. Ang},
  title = {{IEEE} {AI} {Standards} for {Agentic} {Systems}},
  journal = {2025 IEEE Conference on Artificial Intelligence (CAI)},
