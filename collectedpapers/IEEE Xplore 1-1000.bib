  title = {{Benchmarking} {AI} {Models} in {Software} {Engineering:} {A} {Review,} {Search} {Tool,} and {Unified} {Approach} for {Elevating} {Benchmark} {Quality}},
  journal = {IEEE Transactions on Software Engineering},
  year = {2026},
