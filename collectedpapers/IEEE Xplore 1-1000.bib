@article{fedlmaafederatedlearningframew2025,
  author = {J. Wang; Y. Wu; X. Xiong; Y. Zhang; Z. Lyu; A. Ghoneim; H. Zhao},
  title = {{FedLMA:} {A} {Federated} {Learning} {Framework} {Integrating} {LLM-Based} {Multi-Agent} {Reasoning} {With} {Knowledge} {Distillation}},
