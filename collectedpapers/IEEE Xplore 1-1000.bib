@article{ecoptiaiecommerceprocessoptimi2025,
  author = {O. -R. Alecsoiu; N. Faruqui; A. A. Panagoret; C. A. IonuÅ£; D. M. Panagoret; R. -V. Nitu; M. A. Mutu},
  title = {{EcoptiAI:} {E-Commerce} {Process} {Optimization} and {Operational} {Cost} {Minimization} {Through} {Task} {Automation} {Using} {Agentic} {AI}},
