@article{llmbasedgenerationoflowcodedev2025,
  author = {B. Schenkenfelder},
  title = {{LLM-Based} {Generation} of {Low-Code} {Development} {Platforms}},
  journal = {2025 ACM/IEEE 28th International Conference on Model Driven Engineering Languages and Systems Companion (MODELS-C)},
  year = {2025},
