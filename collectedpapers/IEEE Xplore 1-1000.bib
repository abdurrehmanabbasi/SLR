@article{rq2dslanaiagentforautomateddom2025,
  author = {T. Tsampouris; E. Tsardoulias; K. Panayiotou; A. L. Symeonidis},
  title = {{RQ2DSL:} {An} {AI} {Agent} for {Automated} {Domain-Specific} {Language} {Grammar} {Generation} from {Requirements}},
