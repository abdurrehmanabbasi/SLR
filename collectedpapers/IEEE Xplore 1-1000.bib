@article{acriticalreviewandevaluationof2026,
  author = {A. Ravindran; A. Patra; V. Babaey; S. Purini},
  title = {{A} {Critical} {Review} and {Evaluation} of {LLMs} for {RTL} {Generation}},
  journal = {IEEE Access},
  year = {2026},
  volume = {14},
