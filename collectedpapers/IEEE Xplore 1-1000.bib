@article{automaticallygeneratedmultiage2025,
  author = {A. Yang; B. Wang; A. Liu; H. Li},
  title = {{Automatically} {Generated} {Multi-Agent} {Framework} for {Jailbreaking} {Large} {Language} {Models}},
