  isbn = {979-8-4007-0560-1},
  keywords = {Autonomous Systems;Software Engineering;Knowledge Graphs;Data-Oriented Architectures;Large Language Models},
}

@article{leaderfollowingsecureoutputcon2024,
  author = {X. Jia; H. Li; X. Chi; B. Li},
  title = {{Leader-Following} {Secure} {Output} {Consensus} of {Heterogeneous} {Multiagent} {Systems} {Based} on {Two} {Sampling} {Mechanisms} {Under} {Hybrid} {Cyber-Attacks}},
  journal = {IEEE Transactions on Cybernetics},
