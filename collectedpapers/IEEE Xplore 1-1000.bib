  keywords = {Domain-specific languages;large language models;prompt engineering;grammar generation;model-driven engineering},
}

@article{emotionrelatedpedagogicalagent2024,
  author = {A. I. Septiana; K. Mutijarsa; B. L. Putro; Y. Rosmansyah},
  title = {{Emotion-Related} {Pedagogical} {Agent:} {A} {Systematic} {Literature} {Review}},
  journal = {IEEE Access},
  year = {2024},
  volume = {12},
  pages = {36645--36656},
  doi = {10.1109/ACCESS.2024.3374376},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10462142},
  abstract = {Pedagogical agent is a software agent that provides guidance, feedback, or intervention to learners in digital environments. It has the potential to address issues in computer-based learning, particularly online learning, which often neglects affective aspects, such as the emotions of its users. Most systematic literature reviews (SLR) on pedagogical agent have focused on their visual design, types of feedback, and other empirical elements. However, what underlies these agentsâ ability to provide interventions personalized to learnerâs emotions has not been examined. So, this SLR explores how pedagogical agent has addressed learnerâs emotional needs. The studyâs research questions include: 1) To what extent does research exist on models, frameworks, or architectures for pedagogical agent, especially those related to emotions? 2) How are pedagogical agent represented, what types of interventions do they use, and how do they affect learnerâs emotions? 3) What kinds of inputs are used to activate the pedagogical agentâs functions? This SLR applied the Kitchenham method to select reference sources from 2013 to 2023 and was indexed by Scopus in the Q1 to Q4 range. Our review revealed the absence of a specific model for mapping out interventions tailored to the learnerâs emotional needs. Most existing pedagogical agent provide learning interventions that are less adaptive and personalized based on the learnerâs emotional state and are applied to asynchronous learning systems such as e-learning. There are still very few pedagogical agents that use real-time input technology by utilizing artificial intelligence to recognize learnerâs emotion to trigger an adaptive and personalized intervention.},
  publisher = {IEEE},
  issn = {2169-3536},
  keywords = {Pedagogical agent;learning intervention;emotion;education;learner},
}

@article{benchmarkinglargelanguagemodel2024,
  author = {Y. Qi; S. Cai; Z. Zhao; J. Li; Y. Lin; Z. Wang},
