  isbn = {979-8-3315-4267-2},
  keywords = {Requirements Engineering(RE);Requirements Normalization;LLMs;NLP;EARS(Easy Approach to Requirements Syntax)},
}

@article{tpmarlmssthoughtperceptionmult2023,
