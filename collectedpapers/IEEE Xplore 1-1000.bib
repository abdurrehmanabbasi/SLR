  keywords = {software architecture;se4ai;llm},
}

@article{automatedstructuraltestingofll2025,
  author = {J. Kohl; O. Kruse; Y. Mostafa; A. Luckow; K. Schroer; T. Riedl; R. French; D. Katz; M. P. Luitz; T. Takher; K. E. Friedl; C. Laurent-Winter},
  title = {{Automated} {Structural} {Testing} of {LLM-Based} {Agents:} {Methods,} {Framework,} and {Case} {Studies}},
