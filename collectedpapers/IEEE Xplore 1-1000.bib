@article{llmfuzztestgenfromautomationto2025,
  author = {J. A. Nuh; T. W. Koh; M. H. Osman; B. Lawal; M. A. Ali; A. A. Jaharadak},
  title = {{LLMFuzzTestGen:} {From} {Automation} to {Robustness} via {Multi-Agent} {LLM-Driven} {Fuzzing} and {Feedback} {Loops}},
  journal = {2025 7th International Conference on Interdisciplinary Computer Science and Engineering (ICICSE)},
  year = {2025},
  pages = {105--112},
  doi = {10.1109/ICICSE67247.2025.11390823},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11390823},
  abstract = {Automated software testing is vital for software quality, yet manual unit test creation is costly, error-prone, and often neglected. Existing automated techniquesâstatic analysis, symbolic execution, and fuzzingâimprove coverage but fail to capture semantic intent or generate adversarial inputs. While Large Language Models (LLMs) show promise for code understanding and test generation, current single-shot methods yield brittle, âhappy-pathâ tests with low adaptability. To address these limitations, we present LLMFuzzTestGen, the first LLM-based test generator that systematically integrates semantic fuzzing with feedback refinement, implemented as a multi-agent, feedback-driven framework. Unlike single-agent tools, it distributes responsibilities across specialized agents for input generation, test construction, formatting, file management, execution, and feedback analysis. Central to the design is an adaptive loop: failing tests and runtime mismatches are reinjected to refine subsequent iterations. Our evaluation across three Python programs shows LLMFuzzTestGen achieves 63.0% correctness rate with 100% syntax-valid test generation and strong performance in negative test cases. The system uncovered logic errors, type mismatches, and robustness gaps overlooked by static test generation, demonstrating its potential as a practical alternative to manual test authoring in Continuous Integration/Continuous Deployment (CI/CD) workflows.},
  publisher = {IEEE},
  isbn = {979-8-3315-6969-3},
  keywords = {Unit Test Generation;Large Language Models;Multi-Agent Systems;Semantic Fuzzing;Feedback-Driven Test Generation},
}

@article{designingforinclusionhumancent2025,
  author = {J. P. Wieland; C. Werner},
  title = {{Designing} for {Inclusion:} {Human-Centered} {Multi-Agent} {Accessibility} {Repair} in {Modern} {Web} {Applications}},
  journal = {2025 IEEE 36th International Symposium on Software Reliability Engineering Workshops (ISSREW)},
  year = {2025},
  pages = {167--170},
  doi = {10.1109/ISSREW67781.2025.00067},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11262470},
  abstract = {Accessibility defects in modern web applications often stem from human factors such as cognitive overload, insufficient training, and the difficulty of interpreting complex accessibility audit reports. In Brazil, despite the legal requirements of the Brazilian Inclusion Law (Lei Brasileira de InclusÃ£oâLBI, Law 13.146/2015), recent studies show that less than 1of national websites comply with the Web Content Accessibility Guidelines (WCAG) 2.1. These gaps are not only technical but also cognitive and organizational, reflecting a persistent mismatch between detection capabilities and remediation practices. In large-scale React applications, the component-based architecture amplifies the challenge by introducing framework-specific pitfalls that require specialized expertise. This paper introduces AccessibilityAgent, a human-aware, multi-agent architecture that autonomously repairs accessibility violations using locally deployed Large Language Models (LLMs). By automating repetitive and error-prone tasks, the system reduces developers' decision fatigue and cognitive burden, while its validation agents preserve functional correctness and maintain trustworthiness. Unlike monolithic approaches, our design coordinates specialized agents for auditing, planning, retrieving, fixing, and validating repairs, enabling an adaptive workflow that integrates human oversight where necessary. We discuss how this architecture addresses human-factor-related risks in accessibility maintenance, improves software dependability, and supports inclusive design at scale.},
  publisher = {IEEE},
  isbn = {979-8-3315-5325-8},
  issn = {2994-810X},
  keywords = {accessibility;multi-agent systems;automated repair;React;WCAG;software quality},
}

@article{evaluatingstudentsattentionade2025,
  author = {F. Yeh; M. I. Hosen; F. M. HafizoÄlu},
  title = {{Evaluating} {Students'} {Attention:} {A} {Deep} {Learning} {Approach}},
