@article{agentrepairmultiagentastanchor2025,
  author = {H. Lee; G. Yang},
  title = {{AgentRepair:} {Multi-Agent,} {AST-Anchored,} {Retrieval-Augmented} {Program} {Repair} for {Cold-Start} {Environments}},
  journal = {2025 12th International Conference on Dependable Systems and Their Applications (DSA)},
  year = {2025},
  pages = {121--132},
  doi = {10.1109/DSA66321.2025.00025},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11320358},
  abstract = {Large Language Models (LLMs) have recently emerged as a promising tool for Automatic Program Repair (APR), but they remain challenged by new projects without past bug-fix history. Because current models primarily attend to surface-level code tokens, they often miss defects that manifest at deeper structural levels, which leads to incorrect or hallucinated patches and limits their practical applicability. To resolve this, we need a better method that uses solid proof to guide the LLM. For this, we propose AgentRepair, a system with multiple agents working together to fix bugs based on clear evidence. The process starts when one agent analyzes the buggy code's structure using an Abstract Syntax Tree (AST) to find reliable clues about the error. At the same time, another agent finds examples of similar bugs that were fixed in the past. These clues and examples are combined into a detailed, evidence-filled prompt. This prompt tells the LLM to create possible fixes, with strict rules to make only small, necessary changes. Finally, a validation agent runs the project's official tests to check if each fix is correct. We tested AgentRepair on 51 difficult bugs from the BugsInPy benchmark and successfully fixed 26 of them. It had a 50.98 % success rate when generating ten possible fixes, which was much better than other basic LLM methods. Specifically, AgentRepair outperformed Qwen, Gemma, and DeepSeek by +17.65, +21.57, and +11.76 percentage points. By basing fixes on real evidence and checking them with tests, our system offers a reliable and effective solution for real-world software repair, especially for projects without much historical data.},
  publisher = {IEEE},
  isbn = {978-1-6654-7769-7},
  issn = {2767-6684},
  keywords = {Automatic Program Repair;Large Language Models;Retrieval-Augmented Generation;Multi-Agent Systems;BugsInPy Benchmark},
}

@article{idenativefoundationmodelbaseda2025,
