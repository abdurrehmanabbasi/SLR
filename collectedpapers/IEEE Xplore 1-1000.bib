@article{evorlevolutionofagenticworkflo2025,
  author = {D. C. Attota; Y. Xie},
  title = {{EvoRL:} {Evolution} of {Agentic} {Workflows} {Using} {Reinforcement} {Learning}},
  journal = {2025 IEEE International Conference on Big Data (BigData)},
  year = {2025},
  pages = {4099--4106},
  doi = {10.1109/BigData66926.2025.11401641},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11401641},
  abstract = {Recent advances in Large Language Models (LLMs) have enabled multi-agent systems capable of tackling complex tasks. Nevertheless, the performance of these systems is often limited by rigid, manually crafted âagentic workflowsâ that govern agent interactions. Such workflows are either too simplistic to handle complex problems or unnecessarily complex for simpler tasks, resulting in high computational costs and latency. To address these limitations, we introduce EvoRL, a novel framework that leverages hierarchical reinforcement learning to automate the construction of agentic workflows. EvoRL frames workflow design as a sequential decision-making process, learning adaptive policies to dynamically assemble workflows tailored to each query. The framework employs a high-level Evolver agent to select modular agentic components that define the workflow structure, and a low-level LLM Selector agent to choose the most cost-effective language model for each component. Empirical validation of EvoRL on benchmarks including GSM8K, MATH, MultiArith, HumanEval, and MBPP demonstrates that EvoRL achieves up to 87.99 % average accuracy, surpassing static baselines such as Chain-of-Thought (CoT) at $\text\{8 0. 4 5\} \%$ as well as stochastic methods. In addition, EvoRL reduces the average number of episodes required to reach a solution by 38% and substantially lowers computational costs. These findings highlight EvoRL's robust generalization across both mathematical reasoning and code generation domains.},
  publisher = {IEEE},
  isbn = {979-8-3315-9447-3},
  issn = {2573-2978},
  keywords = {LLM;Evolution;Reinforcement Learning;Agents;Workflows},
}

@article{3dcircleformationcontrolofvtol2024,
  author = {S. Li; C. Wang; G. Xie},
  title = {{3D} {Circle} {Formation} {Control} of {VTOL} {Vehicles} {Without} {Distance} {Measurement}},
  journal = {IEEE Transactions on Intelligent Vehicles},
  year = {2024},
  volume = {9},
  number = {2},
  pages = {3305--3315},
  doi = {10.1109/TIV.2023.3340875},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10349938},
  abstract = {This paper studies a novel circle formation problem in 3D space using a team of vehicles that are able to vertically take off and land (VTOL). The target formation can be in any plane with any non-horizontal orientation in 3D space, which, combined with the complicated nonlinear dynamics of vehicles, makes the problem difficult. We design a distributed control law to solve this problem. The control law has three nice properties. The first is that it can be transformed into the local frame of each vehicle, and the resulting form is independent of any global values, which means it is fully distributed. The second is that the control law requires no distance measurements, which facilitates practical application. The third is that our controller generates bounded values of control inputs. To validate it, we carry out theoretical analysis using Lyapunov function and graph theory, where we show successively that the vehicles will move to the target plane, the target circle, and the desired spacing. Finally, we execute numerical simulations to show the effectiveness of the proposed control law and further perform formation tasks in our built multi-UAV simulation platform to demonstrate the applicability.},
  publisher = {IEEE},
  issn = {2379-8904},
  keywords = {Nonholonomic vehicles;circle formation;distributed control;three-dimensional;multi-agent systems},
}

