  title={Exploration of the Possibility for a Wider Range of the Discount Factor for Reinforcement Learning}, 
  year={2024},
  volume={},
  number={},
  pages={1536-1539},
  abstract={The discount factor for reinforcement learning has been constrained to the range [0, 1] to avoid overestimation of state values during training. Although theoretical studies have indicated that discount factors greater than 1 could be valid for certain tasks, experimental work has generally maintained the [0, 1] limit in flexible discount factor optimization. Our study explores the impact of allowing discount factors to exceed 1 across a variety of reinforcement learning algorithms and classic training environments. Our findings demonstrate that in some grid-based environments, reinforcement learning algorithms with discount factors above 1 can achieve comparable performance to those with discount factors within the [0, 1] range. However, performance tends to be more variable when the discount factor exceeds 1.},
  keywords={Training;Reinforcement learning;Task analysis;Optimization;Information systems;reinforcement learning;discount factor},
