@INPROCEEDINGS{10217876,
  author={Deng, Yuxuan and Li, Xiuhua and Sun, Chuan and Hao, Jinlong and Wang, Xiaofei and Leung, Victor C. M.},
  booktitle={2023 IEEE Symposium on Computers and Communications (ISCC)}, 
  title={Deep Reinforcement Learning for Joint Service Placement and Request Scheduling in Mobile Edge Computing Networks}, 
  year={2023},
  volume={},
  number={},
  pages={637-642},
  abstract={Mobile edge computing aims to provide cloud-like services on edge servers located near Mobile Devices (MDs) with higher Quality of Service (QoS). However, the mobility of MDs makes it difficult to find a global optimal solution for the coupled service placement and request scheduling problem. To address these issues, we consider a three-tier MEC network with vertical and horizontal cooperation. Then we formulate the joint service placement and request scheduling problem in a mobile scenario with heterogeneous services and resource limits, and convert it into two Markov decision processes to decouple decisions across successive time slots. We propose a Cyclic Deep Q-network-based Service placement and Request scheduling (CDSR) framework to find a long-term optimal solution despite future information unavailability. Specifically, to solve the issue of enormous action space, we decompose the system agent and train them cyclically. Evaluation results demonstrates the effectiveness of our proposed CDSR on user-perceived QoS.},
  keywords={Deep learning;Computers;Multi-access edge computing;Processor scheduling;Simulation;Quality of service;Reinforcement learning;Mobile edge computing;Deep reinforcement learning;Service placement;Request scheduling},
  doi={10.1109/ISCC58397.2023.10217876},
  ISSN={2642-7389},
  month={July},}@INPROCEEDINGS{10710947,
  author={İnce, Cemile and İnce, Kenan},
  booktitle={2024 8th International Artificial Intelligence and Data Processing Symposium (IDAP)}, 
  title={Investigating Effect of Optimization Algorithms on Chaos Based Image Encryption}, 
  year={2024},
  volume={},
  number={},
  pages={1-5},
  abstract={Image encryption is a specialized subfield of cryptography, distinguished by the high correlation between neighboring pixels, which necessitates unique approaches to disrupt this correlation. While all encryption approaches fundamentally involve confusion and diffusion operators, the specific implementations of these operators can vary significantly. In recent years, approaches that combine chaos theory with optimization techniques, which aim to find the optimal solution among numerous possibilities, have become prevalent. These studies, which aim to enhance the security and efficiency of the encryption process, such as by selecting the initial values of chaotic maps in regions with high chaotic behavior, show promise. This study examines the most commonly applied optimization methods in the field of cryptography within the context of image encryption, providing a comprehensive overview. Additionally, it empirically demonstrates that the optimization techniques employed in image encryption studies improve encryption quality.},
  keywords={Chaos;Measurement;Correlation;Metaheuristics;Optimization methods;Data processing;Encryption;Artificial intelligence;Optimization;Image Encryption;Chaos Theory;Optimization Algorithms},
  doi={10.1109/IDAP64064.2024.10710947},
  ISSN={},
  month={Sep.},}@ARTICLE{11180913,
  author={Awais, Zupash and Hussain, Muzammil and Elshenawy, Ayman and Arsalan, Ahmad and Anwar, Muhammad and Asif Habib, Muhammad and Jabbar, Sohail and Ahmad, Mudassar},
  journal={IEEE Access}, 
  title={ISCC: Intelligent Semantic Caching and Control for NDN-Enabled Industrial IoT Networks}, 
  year={2025},
  volume={13},
  number={},
  pages={169881-169898},
  abstract={Effective content caching plays a crucial role in meeting the latency and reliability requirements of Industrial Internet of Things (IIoT) networks. However, existing caching mechanisms in NDN-based IIoT networks often exhibit problems in adaptability, semantic awareness, and structural efficiency, resulting in limited performance in dynamic and resource-constrained environments. This paper introduces the Intelligent Semantic-Aware Caching and Control framework (ISCC), which integrates Cuckoo Hashing with Reinforcement Learning (RL) to enhance content replacement decisions in IIoT networks based on Named Data Networking (NDN). The framework presents a semantic scoring model that integrates content domain, source reliability, and criticality to enhance caching prioritisation. A reinforcement learning (RL) agent utilising Q-learning dynamically chooses actions by using unified caching scores that take into account frequency, time, and semantic fidelity. The results of the simulation indicate that ISCC outperforms conventional strategies, such as FIFO, LRU, and LRFU, in terms of cache hit ratio, semantic fidelity, and latency, achieving up to 23% fewer replacements and a 16% improvement in preserving semantic content. The results show ISCC’s capability to facilitate intelligent and adaptive caching in memory-constrained IIoT environments.},
  keywords={Industrial Internet of Things;Semantics;Electronic mail;Transformers;Quality of service;Context modeling;Computational modeling;Time-frequency analysis;Real-time systems;Decision making;Named data networking (NDN);industrial Internet of Things (IIoT);semantic caching;reinforcement learning;Cuckoo hashing},
  doi={10.1109/ACCESS.2025.3614984},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11043964,
  author={Chen, Yutong and Li, Hai and Gong, Lei and Wang, Chao},
  booktitle={2025 IEEE International Symposium on Circuits and Systems (ISCAS)}, 
  title={ResDDQN-FPGA: A Reinforcement Learning Framework for Dynamic and Efficient Control in Resonant DC-DC Converters}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={This paper presents a novel DC-DC loop control framework, ResDDQN-FPGA, which integrates reinforcement learning with field-programmable gate arrays (FPGAs) to enhance the dynamic response and stability of LLC resonant DC-DC converters. Traditional control strategies for LLC converters face difficulties in adapting to variations in operating conditions, especially with aging circuit components. To address these issues, we introduce the Double DQN algorithm, modified with a residual structure to form the ResDDQN control algorithm, which provides accurate estimation of control objectives with reduced computational demand. The ResDDQN algorithm is deployed on an FPGA platform, leveraging its parallel processing capabilities to improve execution speed and efficiency, while also reducing resource usage and energy consumption. Experimental validation on a 1kW full-bridge LLC circuit demonstrates the framework’s effectiveness, achieving superior dynamic performance, lower energy consumption, and greater stability. This highly efficient and responsive control solution is well-suited for real-time applications, maintaining scalability without compromising computational demand.},
  keywords={Energy consumption;Heuristic algorithms;Scalability;Reinforcement learning;DC-DC power converters;Parallel processing;Robustness;Real-time systems;Circuit stability;Field programmable gate arrays;LLC converter;Double Deep Q-Network;FPGA;reinforcement learning;dynamic control},
  doi={10.1109/ISCAS56072.2025.11043964},
  ISSN={2158-1525},
  month={May},}@INPROCEEDINGS{11297515,
  author={Racedo, Sebastian and Jaumard, Brigitte and Delgado, Oscar and Masoudi, Meysam},
  booktitle={2025 21st International Conference on Network and Service Management (CNSM)}, 
  title={QoS-Aware Dynamic CU Selection in O-RAN with Graph-Based Reinforcement Learning}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Open Radio Access Network (O-RAN) disaggregates conventional RAN into interoperable components, enabling flexible resource allocation, energy savings, and agile architectural design. In legacy deployments, the binding between logical functions and physical locations is static, which leads to inefficiencies under time-varying traffic and resource conditions. We address this limitation by relaxing the fixed mapping and performing dynamic service function chain (SFC) provisioning with on-the-fly O-CU selection. We formulate the problem as a Markov decision process and solve it using GRL-DyP, i.e., a graph neural network (GNN)-assisted deep reinforcement learning (DRL). The proposed agent jointly selects routes and the O-CU location (from candidate sites) for each incoming service flow to minimize network energy consumption while satisfying quality-of-service (QoS) constraints. The GNN encodes the instantaneous network topology and resource utilization (e.g., CPU and bandwidth), and the DRL policy learns to balance grade of service, latency, and energy. We perform the evaluation of GRL-DyP on a data set with $\mathbf{2 4}$-hour traffic traces from the city of Montreal, showing that dynamic O-CU selection and routing significantly reduce energy consumption compared to a static mapping baseline, without violating QoS. The results highlight DRL-based SFC provisioning as a practical control primitive for energy-aware, resource-adaptive O-RAN deployments.},
  keywords={Energy consumption;Service function chaining;Urban areas;Open RAN;Quality of service;Routing;Deep reinforcement learning;Graph neural networks;Energy efficiency;Resource management;O-RAN;Deep Reinforcement Learning;Graph Neural Networks;SFC Provisioning;Energy Efficiency},
  doi={10.23919/CNSM67658.2025.11297515},
  ISSN={2165-963X},
  month={Oct},}@ARTICLE{11224011,
  author={Zhang, Qingmiao and Liu, Minghao and Zhao, Junhui and Zhang, Chenxi and Zhang, Ming},
  journal={IEEE Transactions on Intelligent Transportation Systems}, 
  title={Computation Offloading Optimization for Digital Twin Assisted 5G-Enabled Edge Computing Network in Urban Rail Transit}, 
  year={2025},
  volume={26},
  number={12},
  pages={21574-21587},
  abstract={As urban rail transit evolves, the convergence of digitalization, networking and intelligence has emerged as a pivotal trend, accompanied by the surge of intensive computing tasks and real-time demand. Edge computing is a promising solution to address the local resource constraints of various application devices covered by various subsystems within Urban Rail Transit Systems (URTS). In this paper, a Digital Twin (DT) assisted 5G-enabled edge computing network in URTS is established. We consider the heterogeneous service requirements of Ultra-Reliable Low-Latency Communication (URLLC) and Enhanced Mobile Broadband (eMBB) in different intelligent applications, and accordingly, we develop a task execution queue model. Additionally, to improve the task processing performance of the system, a task offloading and resource allocation scheme based on the Multi-Agent Twin Delayed Deep Deterministic policy gradient (MATD3) algorithm is proposed. User Equipment (UEs) and Edge Servers (ESs) are treated as distinct agents, accounting for their collaborative computation capabilities and differences in decision-making. A framework is established for centralized training in a DT assisted system with decentralized execution by each agent. Simulation results demonstrate that the proposed approach ensures the stringent latency requirement for URLLC tasks, enhances the Transaction Per Time Slot (TPTS) for eMBB tasks, and significantly reduces processing delays across all tasks. In addition, the proposed scheme also achieves load balance between UEs and ESs.},
  keywords={Ultra reliable low latency communication;Edge computing;Delays;Rails;Resource management;Optimization;5G mobile communication;Reliability;Heuristic algorithms;Data communication;Urban rail transit;edge computing;5G;digital twin},
  doi={10.1109/TITS.2025.3621533},
  ISSN={1558-0016},
  month={Dec},}@INPROCEEDINGS{11408487,
  author={Alipour, Mina and Moghaddam, Mahyar T.},
  booktitle={2025 12th International Conference on Internet of Things: Systems, Management and Security (IOTSMS)}, 
  title={ABDA-IoB: Affective Behavior-Driven Adaptation for Internet of Behaviors}, 
  year={2025},
  volume={},
  number={},
  pages={168-175},
  abstract={Socio-technical systems need to increasingly account for human emotions and behaviors to effectively influence their decisions without compromising experience. The Internet of Behaviors (IoB) paradigm emphasizes closing the loop between sensing human behavior, system adaptation, and behavior change. This paper proposes Affective Behavior-Driven Adaptation for IoB (ABDA-IoB), a framework that integrates affective computing and behavior analytics into adaptive systems. The ABDA-IoB model defines key modules (Affective Computing, Behavior Analytics, Adaptation Policy Generator) and explicit feedback loops connecting human Quality of Experience (QoE) with system Quality of Service (QoS), enabling continuous adaptation. The framework supports the development of a reinforcement learning-based nudging system for energy conservation. We implement a prototype smart-home dashboard that monitors users' real-time emotional state (via facial expression analysis) and energy-use context, and adapts its feedback strategy through a model-free reinforcement learning agent. Experiments over multiple sessions provide empirical validation: participants in the affect-adaptive condition showed significantly higher positive affect, sustained engagement, and improved simulated energy-saving behavior compared to a static feedback baseline. Results show that ABDA-IoB's emotionally intelligent nudging leads to more receptive and effective behavior change interventions, without causing user discomfort.},
  keywords={Affective computing;Adaptation models;Analytical models;Computational modeling;Energy conservation;Quality of service;Reinforcement learning;Behavioral sciences;Quality of experience;Internet of Things;IoT;IoB;Emotions;Behaviors;Adaptation},
  doi={10.1109/IOTSMS68530.2025.11408487},
  ISSN={2832-3033},
  month={Dec},}@INPROCEEDINGS{10992751,
  author={Zou, Dingyang and Zhang, Gaoche and Sun, Kairui and Wen, Zhe and Wang, Meiqi and Wang, Zhongfeng},
  booktitle={2025 Design, Automation & Test in Europe Conference (DATE)}, 
  title={LLM4GV: An LLM-Based Flexible Performance-Aware Framework for GEMM Verilog Generation}, 
  year={2025},
  volume={},
  number={},
  pages={1-2},
  abstract={Advancements in AI have increased the demand for specialized AI accelerators, with design for general matrix multiplication (GEMM) module being crucial but time-consuming. While large language models (LLMs) show promise for automating GEMM design, challenges arise from GEMM's vast design space and performance requirements. Existing LLM-based frameworks for RTL code generation often lack flexibility and performance awareness. To overcome the challenges, we propose LLM4GV, a multi-agent LLM-based framework that integrates hardware optimization techniques (HOTs) and performance modeling, improving correctness and performance of the generated code over prior works.},
  keywords={Codes;Automation;Large language models;Europe;AI accelerators;Benchmark testing;Hardware;Hardware design languages;Optimization},
  doi={10.23919/DATE64628.2025.10992751},
  ISSN={1558-1101},
  month={March},}@INPROCEEDINGS{10755518,
  author={Shpur, Olha and Seliuchenko, Marian and Klymash, Mykhailo and Havryliv, Taras and Panchenko, Anna},
  booktitle={2024 IEEE 17th International Conference on Advanced Trends in Radioelectronics, Telecommunications and Computer Engineering (TCSET)}, 
  title={Designing the Monitoring System Architecture for Service-Oriented Systems}, 
  year={2024},
  volume={},
  number={},
  pages={1-4},
  abstract={In this paper we design an architecture of a monitoring system that allows building a holistic real-time view of the service-oriented system. While most of the existing monitoring tools focus on a few specific parameters of services or computing/networking resources, our design allows aggregating most of the key parameters of every component of a service-oriented system by integrating with service-oriented systems controllers or installing monitoring agents on-premises. Our design addresses such challenges as heterogeneity of monitoring objects and allows easy extension to support new parameters and monitoring objects regardless of the software development technologies that were used.},
  keywords={System performance;Systems architecture;Computer architecture;Quality of service;Real-time systems;Telecommunications;Security;Monitoring;System implementation;Software development management;service-oriented systems;monitoring system;QoS},
  doi={10.1109/TCSET64720.2024.10755518},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11250386,
  author={Wahid, Abdul and Ismail, Leila},
  booktitle={2025 International Symposium on Networks, Computers and Communications (ISNCC)}, 
  title={Deep Reinforcement Learning-Driven Quality of Service and Energy-Aware Adaptive Scheduling Framework for Vehicular Edge Computing}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Vehicular Edge Computing (VEC) is increasingly recognized as essential for managing intensive computational demands in connected and autonomous vehicles. Due to limited onboard processing capabilities, vehicles must offload computational tasks to edge computing nodes, such as Road Side Units, to meet stringent latency and energy efficiency requirements. However, the inherent dynamic mobility of vehicles, intermittent connectivity, and fluctuating resource availability pose significant challenges to efficient task scheduling and offloading. Traditional static or heuristic-based approaches frequently result in deadline violations and inefficient energy usage under such dynamic conditions. This paper proposes an adaptive task scheduling framework using Deep Reinforcement Learning (DRL) to address these challenges. Our framework dynamically manages computational offloading decisions, optimizing for minimal deadline violations and reduced energy consumption. By integrating real-time state information, including server loads, network bandwidth, and task parameters, the DRL agent autonomously learns optimal scheduling policies through interaction with the vehicular environment. Our results indicate that this DRL-based scheduling significantly enhances adherence to task deadlines and improves energy efficiency. Furthermore, this foundational framework sets the stage for future expansions to include comprehensive Quality of Service (QoS) metrics and Service Level Agreement (SLA) compliance.},
  keywords={Adaptive scheduling;Processor scheduling;Quality of service;Optimal scheduling;Dynamic scheduling;Deep reinforcement learning;Energy efficiency;Vehicle dynamics;Edge computing;Service level agreements;Deep Reinforcement Learning;Task Offloading;Vehicular Edge Computing;Deadline-aware;Task offloading;Energy Efficiency;QoS},
  doi={10.1109/ISNCC66965.2025.11250386},
  ISSN={2768-0940},
  month={Oct},}@INPROCEEDINGS{11338520,
  author={Guo, An and Zhang, Shuoxiao and Tang, Enyi and Gao, Xinyu and Pang, Haomin and Tian, Haoxiang and Mu, Yanzhou and Wen, Wu and Fang, Chunrong and Chen, Zhenyu},
  booktitle={2025 40th IEEE/ACM International Conference on Automated Software Engineering (ASE)}, 
  title={When Autonomous Vehicle Meets V2X Cooperative Perception: How Far Are We?}, 
  year={2025},
  volume={},
  number={},
  pages={1169-1181},
  abstract={Perceiving the complex driving environment precisely is crucial to the safe operation of autonomous vehicles. With the tremendous advancement of deep learning and communication technology, Vehicle-to-Everything (V2X) cooperative perception has the potential to address limitations in sensing distant objects and occlusion for a single-agent perception system. V2X cooperative perception systems are software systems characterized by diverse sensor types and cooperative agents, varying fusion schemes, and operation under different communication conditions. Therefore, their complex composition gives rise to numerous operational challenges. Furthermore, when cooperative perception systems produce erroneous predictions, the types of errors and their underlying causes remain insufficiently explored.To bridge this gap, we take an initial step by conducting an empirical study of V2X cooperative perception. To systematically evaluate the impact of cooperative perception on the ego vehicle’s perception performance, we identify and analyze six prevalent error patterns in cooperative perception systems. We further conduct a systematic evaluation of the critical components of these systems through our large-scale study and identify the following key findings: (1) The LiDAR-based cooperation configuration exhibits the highest perception performance; (2) Vehicle-to-infrastructure (V2I) and vehicle-to-vehicle (V2V) communication exhibit distinct cooperative perception performance under different fusion schemes; (3) Increased cooperative perception errors may result in a higher frequency of driving violations; (4) Cooperative perception systems are not robust against communication interference when running online. Our results reveal potential risks and vulnerabilities in critical components of cooperative perception systems. We hope that our findings can better promote the design and repair of cooperative perception systems.},
  keywords={Systematics;Vehicle-to-infrastructure;Vehicular ad hoc networks;Software systems;Software reliability;Sensors;Vehicle-to-everything;Autonomous vehicles;Testing;Software engineering;Autonomous Driving Systems;Cooperative Perception;Offline and Online Testing},
  doi={10.1109/ASE63991.2025.00101},
  ISSN={2643-1572},
  month={Nov},}@INPROCEEDINGS{10727067,
  author={Hsu, Tse-Chuan and Lu, Han-Sheng},
  booktitle={2024 IEEE 24th International Conference on Software Quality, Reliability, and Security Companion (QRS-C)}, 
  title={Exploring the Efficacy of Dynamic Approaches in Database Encryption and Translational Security}, 
  year={2024},
  volume={},
  number={},
  pages={163-169},
  abstract={In current information security management, many security protection standards based on network security have been established. Based on communication security, we will develop secure channels and data transmission rules to reduce the possibility of disclosure in data collection. This method is sufficient to meet the needs of all parties regarding the security maintenance services required for communication security. However, due to the software system development week, there are concerns about information security due to possible code vulnerabilities that may arise during software development. This study is based on the encryption design for secure maintenance and operation of the database and uses an intermediary system to encrypt data fields. In the study, a single encryption key design is designed for each data field, and an agent call for the data form encrypts each column. From different key data encryption operation ensures that the data has independent encryption operation procedures, which reduces the possibility of leaking a large amount of plaintext data when the database is attacked. In this study, an intermediate conversion encryption engine is constructed to automatically generate a set of independent security keys before each row of data is written to the database. At the same time, before each piece of data is written into the database, there is an independent key for the field information that lets encryption and decryption be performed. In our experiment result, we found that since each piece of data is encrypted by its independent writing method, it can be used to improve and solve the problem of data leakage caused by SQL injection into the database by SQL query, and at the same time, more strengthened the security technical difficulties of traditional data masking.},
  keywords={Databases;Software quality;Writing;Software systems;Encryption;Maintenance;Software reliability;Security;Protection;Standards;component;Information Security Management;Communication Security;Software Development;Database Encryption;SQL Injection Protection},
  doi={10.1109/QRS-C63300.2024.00031},
  ISSN={2693-9371},
  month={July},}@INPROCEEDINGS{11163946,
  author={Mogali, Jayanth Krishna and Ramesh, Sriram and Dammala, Aakash and Korupolu, Pradyot},
  booktitle={2025 IEEE 21st International Conference on Automation Science and Engineering (CASE)}, 
  title={Fast Rescheduling for Multi-Agent Plan Execution in Dynamic Urban Environments: A Machine Scheduling Perspective}, 
  year={2025},
  volume={},
  number={},
  pages={2422-2427},
  abstract={The Multi-Agent Path Finding (MAPF) problem is crucial for sidewalk delivery robots operating in dynamic urban environments. These robots frequently encounter unforeseen obstacles and delays, causing deviations from precomputed routes and schedules, necessitating rapid real-time replanning to maintain efficient operations. However, traditional MAPF approaches can be computationally intensive, particularly when recalculating both routes and schedules. We present a novel replanning approach that addresses this challenge by retaining the original routes and only adjusting the schedules. This constrained MAPF variant is closely related to the Blocking Job Shop (BJS) problem, allowing us to leverage existing BJS local search techniques to develop an anytime replanning procedure. We evaluated our method on various maps, including a real-world deployment site, demonstrating its efficiency in computing high-quality schedules essential for seamless operations.},
  keywords={Schedules;Computer aided software engineering;Automation;Processor scheduling;Urban areas;Dynamic scheduling;Search problems;Real-time systems;Delays;Robots},
  doi={10.1109/CASE58245.2025.11163946},
  ISSN={2161-8089},
  month={Aug},}@INPROCEEDINGS{11181419,
  author={Meng, Xiangyun and Peng, Baoyun and Ma, Xingkong and Liu, Bo and Dong, Zixuan},
  booktitle={2025 6th International Conference on Big Data & Artificial Intelligence & Software Engineering (ICBASE)}, 
  title={Knowledge-Augmented Planning and Pruning for Multi-Hop Question Answering}, 
  year={2025},
  volume={},
  number={},
  pages={90-96},
  abstract={While large language models (LLMs) excel at language understanding and generation, their application to multi-hop knowledge graph question answering (KGQA) faces challenges from structural and semantic mismatches. Current approaches primarily adopt an agent-based paradigm involving planning (decomposing queries), exploration (searching subgraphs), and reflection. However, previous methods suffer from two limitations: For planning, agent-based paradigms heavily rely on LLMs to decompose questions without continuous grounding in KG structures, leading to unanchored subgoal hallucinationsfactually inconsistent reasoning steps; For KG exploration, previous retrieval strategies prioritise isolated entity matching over contextualised relational triplets, resulting in semantically fragmented retrieval that propagates redundant subgraph exploration and semantic drift. To address these challenges, this work proposes a novel KAPP (Knowledge-Augmented Planning and Pruning) framework that synergizes dynamic knowledge grounding with semantic-aware subgraph optimisation. Specifically, KAPP introduces two innovations: a dynamic knowledge-guided planner that interleaves LLM-driven subgoal generation with KG-validated path correction, eliminating hallucinated steps through iterative verification, and a triple-level semantic pruner that evaluates relational relevance via joint question-triplet encoding, preserving contextual coherence while reducing redundant retrievals. Extensive experiments on CWQ and WebQSP benchmarks demonstrate KAPP’s effectiveness, achieving 5.6-7% accuracy gains over existing KG-augmented methods and reducing LLM API calls by $\mathbf{3 2. 4 \%}$.},
  keywords={Technological innovation;Accuracy;Grounding;Semantics;Benchmark testing;Question answering (information retrieval);Cognition;Reflection;Planning;Software engineering;Multi-Hop Question Answering;Knowledge-Based Question Answering;KG-Augmented LLM},
  doi={10.1109/ICBASE66587.2025.11181419},
  ISSN={},
  month={July},}@INPROCEEDINGS{11228375,
  author={Zhu, Qin},
  booktitle={2025 International Joint Conference on Neural Networks (IJCNN)}, 
  title={SRF - A Structured Method for Enhancing Large Model Reasoning}, 
  year={2025},
  volume={},
  number={},
  pages={1-7},
  abstract={Large Language Models (LLMs) tend to exhibit "hallucinations" in tasks involving complex reasoning and calculations, often providing incorrect answers. To address this issue, we propose an innovative method called the Structured Reasoning Framework (SRF), which aims to enhance the reasoning performance of LLMs by incorporating code generation and Chain of Thought (CoT) mechanisms. SRF employs a multi-agent collaborative strategy that breaks down complex tasks into actionable steps, significantly improving the model’s accuracy and robustness. Experimental validation on multiple datasets demonstrates that SRF achieves outstanding performance improvements in reasoning accuracy, logical consistency, and richness. In the GPT-4o mini model, the overall score improved by 10.99% compared to the baseline, with accuracy and logic scores increasing by 22.5% and 11.0%, respectively. Enhancements from SRF are particularly notable in smaller-scale models (such as GPT-3.5), with the overall performance score improving by 23.79% over the baseline.},
  keywords={Adaptation models;Accuracy;Codes;Large language models;Computational modeling;Neural networks;Debugging;Cognition;Robustness;Logic;Model reasoning;computational tasks;Chain of Thought (CoT);Large Language Models (LLMs)},
  doi={10.1109/IJCNN64981.2025.11228375},
  ISSN={2161-4407},
  month={June},}@INPROCEEDINGS{11194021,
  author={Nuţeanu, Dorin and Guzu, Alexandru and Nicolae, Georgian},
  booktitle={2025 International Symposium ELMAR}, 
  title={Analyzing Compliance with Safety Standards in C Code via Large Language Models}, 
  year={2025},
  volume={},
  number={},
  pages={331-335},
  abstract={Ensuring code compliance with safety standards such as MISRA C:2012 is essential for the development of reliable and secure embedded systems in domains like automotive software. Traditional compliance checks rely on rule-based static analyzers, but recent advances in large language models (LLMs) suggest potential for automating such tasks. This paper investigates the zero-shot capabilities of four general-purpose LLMs, such as GPT-4o, LLaMA 3.1, O3-mini, and Mixtral, in identifying violations of 20 undecidable MISRA C:2012 rules. We build a private dataset annotated for MISRA compliance, used to evaluate LLMs under zero-shot prompting. While the data cannot be released, the methodology is generalizable and applicable to public codebases. Our findings show that while LLMs can correctly classify simple rule violations, they struggle with context-dependent rules. No single model excels across all categories, highlighting the need for rule-specific prompting strategies, multi-agent architectures or fine-tuning. These insights pave the way for more effective LLM-driven compliance tools tailored to high-assurance software development.},
  keywords={Hands;Codes;Large language models;Switches;Software;Safety;Software reliability;Standards;Automotive engineering;Software development management;MISRA C:2012;Safety-critical software;Large Language Models (LLMs);Code compliance;Software verification},
  doi={10.1109/ELMAR66948.2025.11194021},
  ISSN={2835-3781},
  month={Sep.},}@INPROCEEDINGS{10487427,
  author={Qu, Yanzhen and Vsevolozhsky, Gregory and Yue, Chuan},
  booktitle={2023 Congress in Computer Science, Computer Engineering, & Applied Computing (CSCE)}, 
  title={Assessing the Positive Impact of the Process for Ensuring Diffusion and Adhesion of Cybersecurity Innovations to Reduce Software Vulnerability Severity}, 
  year={2023},
  volume={},
  number={},
  pages={2244-2250},
  abstract={Effective cybersecurity risk management requires an enhanced software development process that includes a feedback loop to facilitate diffusion and adhesion of cybersecurity innovations. Our Innovation Adhesion Evaluation Process (IAEP) model outlines how a team of SMEs led by a CIO/CISO can evaluate the feasibility, timeliness, suitability, and sustainability of cybersecurity innovations during the software's operational phase. To enable the comprehensive evaluation of cybersecurity innovations, we propose extending the CVSS v3.1 score model by introducing a process metric group. Each metric in this group represents a cybersecurity innovation that addresses a specific cyber risk associated with the software during its life cycle. Our approach enables the explicit inclusion of all cybersecurity innovations in the CVSS v3.1 score model and quantifies their impact in reducing the severity of corresponding software vulnerabilities. With this extension, the CVSS v3.1 score model becomes a valuable tool for the CIO/CISO, SMEs, and software development team to plan and validate the software's competency in resisting cybersecurity risks. By combining our IAEP model and the CVSS v3.1 score model extension, we provide a comprehensive and timely solution for managing cybersecurity risks during the software life cycle.},
  keywords={Measurement;Technological innovation;Feedback loop;Adhesives;Computational modeling;Software;Planning;Cybersecurity;Innovation Adhesion;SDLC;CVSS;software vulnerability severity},
  doi={10.1109/CSCE60160.2023.00366},
  ISSN={},
  month={July},}@INPROCEEDINGS{10889187,
  author={Tang, Yi},
  booktitle={ICASSP 2025 - 2025 IEEE International Conference on Acoustics, Speech and Signal Processing (ICASSP)}, 
  title={Poisoning The Diffusion: A Simple and Robust Watermarking Method for Audio Generation}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={As the capabilities of diffusion-based audio generation models advance, intellectual property protection for both generated audio and model weights becomes important. However, current audio watermarking methods mainly integrate separate encode and decode modules to watermark the generated audio, which not only imposes unnecessary computational overhead, but also neglects crucial protection of model weights. In this paper, we introduce a novel, simple yet robust watermarking algorithm, termed Poisoning The Diffusion(PTD), tailored for diffusion models. Specifically, PTD incorporates a "poison" vector K during the training phase, modifying the noise distribution in the forward process. Subsequently, the "poisoned" diffusion outputs audio with a unique noise distribution that can be quantitatively identified using numerical testing methods, thus effectively serving as an audio watermark. Furthermore, in the reverse process, in the absence of the "antidote" vector (i.e. authorization), the model is unable to perform correct sampling operations, thereby preventing unauthorized use and fine-tuning. Rigorous experimental validation on datasets comprising vocal and musical compositions confirms the efficacy of PTD, underscoring its stability and robustness.},
  keywords={Training;Toxicology;Computational modeling;Noise;Watermarking;Diffusion models;Vectors;Stability analysis;Protection;Speech processing;watermarking;diffusion models;audio generation},
  doi={10.1109/ICASSP49660.2025.10889187},
  ISSN={2379-190X},
  month={April},}@ARTICLE{10015857,
  author={Sun, Chuan and Li, Xiuhua and Wen, Junhao and Wang, Xiaofei and Han, Zhu and Leung, Victor C. M.},
  journal={IEEE Journal on Selected Areas in Communications}, 
  title={Federated Deep Reinforcement Learning for Recommendation-Enabled Edge Caching in Mobile Edge-Cloud Computing Networks}, 
  year={2023},
  volume={41},
  number={3},
  pages={690-705},
  abstract={To support rapidly increasing services and applications from users, multi-tier computing is emerged as a promising system-level computing architecture by distributing computing/caching/communication/networking capabilities between cloud servers to users, especially deploying edge servers at network edges (e.g., base stations). However, due to heterogeneous content requests of users and a high-cost hit manner with direct hits, edge caching is still a most serious issue to be addressed. In this paper, we investigate the issue of recommendation-enabled edge caching in mobile two-tier (edge-cloud) computing networks. Particularly, we integrate recommender systems and edge caching to support both direct hits and soft hits and thus improve the resource utilization of edge servers. We model the factors affecting the user quality of experience as a comprehensive system cost and further formulate the problem as a multi-agent Markov decision process with the goal of minimizing the long-term average system cost. To address the formulated problem, we propose a decentralized recommendation-enabled edge caching framework that leverages a discrete multi-agent variant of soft actor-critic and federated learning. The proposed framework enables each edge server to learn its best policy locally and generate judicious decisions independently. Finally, trace-driven simulation results demonstrate that the proposed framework converges to a better caching policy and outperforms several existing algorithms on average system cost reduction.},
  keywords={Servers;Costs;Quality of experience;Computer architecture;Recommender systems;Optimization;Deep learning;Multi-tier computing;recommendation-enabled edge caching;soft hits;federated learning;discrete soft actor-critic},
  doi={10.1109/JSAC.2023.3235443},
  ISSN={1558-0008},
  month={March},}@ARTICLE{10412086,
  author={Jin, Yixiang and Li, Dingzhe and A, Yong and Shi, Jun and Hao, Peng and Sun, Fuchun and Zhang, Jianwei and Fang, Bin},
  journal={IEEE Robotics and Automation Letters}, 
  title={RobotGPT: Robot Manipulation Learning From ChatGPT}, 
  year={2024},
  volume={9},
  number={3},
  pages={2543-2550},
  abstract={We present RobotGPT, an innovative decision framework for robotic manipulation that prioritizes stability and safety. The execution code generated by ChatGPT cannot guarantee the stability and safety of the system. ChatGPT may provide different answers for the same task, leading to unpredictability. This instability prevents the direct integration of ChatGPT into the robot manipulation loop. Although setting the temperature to 0 can generate more consistent outputs, it may cause ChatGPT to lose diversity and creativity. Our objective is to leverage ChatGPT's problem-solving capabilities in robot manipulation and train a reliable agent. The framework includes an effective prompt structure and a robust learning model. Additionally, we introduce a metric for measuring task difficulty to evaluate ChatGPT's performance in robot manipulation. Furthermore, we evaluate RobotGPT in both simulation and real-world environments. Compared to directly using ChatGPT to generate code, our framework significantly improves task success rates, with an average increase from 38.5% to 91.5%. Therefore, training a RobotGPT by utilizing ChatGPT as an expert is a more stable approach compared to directly using ChatGPT as a task planner.},
  keywords={Chatbots;Codes;Robot learning;Natural languages;Artificial intelligence;Robot learning;Manipulators;AI-enabled robotics;learning from demonstration;manipulation planning},
  doi={10.1109/LRA.2024.3357432},
  ISSN={2377-3766},
  month={March},}@ARTICLE{9831029,
  author={Xia, Shichao and Yao, Zhixiu and Wu, Guangfu and Li, Yun},
  journal={IEEE Transactions on Intelligent Transportation Systems}, 
  title={Distributed Offloading for Cooperative Intelligent Transportation Under Heterogeneous Networks}, 
  year={2022},
  volume={23},
  number={9},
  pages={16701-16714},
  abstract={With the rapid advancement of the Internet of Vehicles and artificial intelligence (AI) technologies, the cooperative intelligent transportation system (C-ITS) has drawn great attention in recent years. To provide an ultra-reliable, low-latency computation experience of C-ITS, computation offloading is deemed indispensable by working with edge-cloud servers. In this paper, we first investigate a distributed dynamic computation offloading model for multi-access edge computing (MEC) enabled C-ITS under a heterogeneous road network, in which the multiple and heterogeneous computing power sources cooperatively provide computation offloading services for vehicles. Considering the autonomous offloading manner of the vehicles, we formulate the task offloading and computing power allocation as a distributed Stackelberg game, where the MEC servers as the leader to allocate computing resources and manage local energy, and the vehicles as the followers to offload local computation task. Since the observable states in the game is incomplete, the problem of resolving the optimal strategies for each game player is modeled as a partially observable Markov decision process (POMDP) to maximize the long-term cumulative reward. Then we develop a computation offloading algorithm using Stackelberg game-based multi-agent deep deterministic policy gradient (SG-MADDPG), which uses a centralized training and decentralized execution method to learn the optimal computing power allocation and computation offloading policies. Finally, extensive simulations are carried out and show the rationality and effectiveness of the proposed algorithm.},
  keywords={Task analysis;Servers;Computational modeling;Games;Resource management;Delays;Cloud computing;Cooperative intelligent transportation system (C-ITS);multi-access edge computing (MEC);Stackelberg game;multi-agent deep deterministic policy gradient (MADDPG)},
  doi={10.1109/TITS.2022.3190280},
  ISSN={1558-0016},
  month={Sep.},}@ARTICLE{10504774,
