  number={},
  pages={834-842},
  abstract={Deep Reinforcement Learning (DRL) is critical in modern Artificial Intelligence (AI), powering innovations from gaming to autonomous vehicles. As DRL continues its rapid ascent, ensuring its systems are both trustworthy and effective is crucial. This research focuses on different DRL techniques and the challenges faced in real-life scenarios. The paper also describes various formal verification techniques and the challenges related to their application. It sheds light on the different frameworks and tools that can enhance the credibility of systems. We performed an extensive literature survey to present the existing methodologies, tools, and frameworks. The analysis systematically reviews and categorizes various formal verification techniques and frameworks employed in DRL. The insights garnered from this study are anticipated to foster an enriched understanding of the processes and contribute to decision-making in Safety Critical Systems using DRL and verification.},
  keywords={Deep learning;Industries;Decision making;Reinforcement learning;Safety;Artificial intelligence;Formal verification;Reinforcement Learning;Formal Methods;Formal Verification;Deep Reinforcement Learning;Safety Critical Systems;Decision making},
  doi={10.1109/QRS-C60940.2023.00112},
  ISSN={2693-9371},
  month={Oct},}@INPROCEEDINGS{10170482,
  author={Rahul, Rahul and Durgapal, Vartika Hari and Chaudhry, Vinshu},
  booktitle={2023 4th International Conference for Emerging Technology (INCET)}, 
  title={Crime Evaluation Using Neural Networks by GPS Trajectory Dataset}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={One of the many irregularities of the world includes crime. It clumps in some areas and is absent in others. Various daily activities require this knowledge. They seek out particular locations while avoiding others. Their decisions on neighborhoods, schools, stores, roadways, and recreational opportunities are influenced in part by the knowledge that Some of these locations have higher victimization rates than others. These choices further create a reason of developing crime concentrated areas also known as hot spots. Thus, a need to analyze the crime levels and to determine the causes of such concentrations is really useful. Tracking every route of the area with possible reason is only possible by using Global Positioning Systems (GPS) which makes the data availability easier and more accurate on minute level. A study is done this research which finds the best features that might explain the possible criminal activities in a region by building a machine learning neural network (NN) model and minimizing the errors. By the end of this study the top features that came out are ‘accidents’, ‘traffic’, ‘tourist attraction, ‘length of the route’, ‘duration of the route’ which majorly effect the crime rates of an area.},
  keywords={Buildings;Machine learning;Artificial neural networks;Trajectory;Global Positioning System;GPS networks;Crime Evaluation;Neural Networks},
  doi={10.1109/INCET57972.2023.10170482},
  ISSN={},
  month={May},}@INPROCEEDINGS{9922889,
  author={Kiss, Dániel and Lovrics, Anna},
  booktitle={2022 IEEE 10th Jubilee International Conference on Computational Cybernetics and Cyber-Medical Systems (ICCC)}, 
  title={On-lattice Approximation of a Grid-free Individual-based Model of Growing Cell Populations}, 
  year={2022},
  volume={},
  number={},
  pages={000057-000062},
  abstract={We compare a lattice-based computational model to an off-lattice individual-based approach for growing cell populations. After summarizing the fundamental properties of the existing off-lattice model, we present its on-lattice approximation and a possible way of their simulation. By performing in silico experiments, including single-cell and multicellular simulations, we show that the collective behavior of the agents is similar in both models, even though there are differences in the individual-level attributes.},
  keywords={Adhesives;Shape;Computational modeling;Aggregates;Sociology;Kinetic theory;Behavioral sciences;individual-based model;agent-based model;cellular automaton;lattice-based cell growth},
  doi={10.1109/ICCC202255925.2022.9922889},
  ISSN={},
  month={July},}@INPROCEEDINGS{11417034,
  author={Gowdanakatte, Shwetha and Rojas, Kevin Gonzales and Shirazi, Hossein and Ray, Indrakshi},
  booktitle={2025 IEEE 7th International Conference on Cognitive Machine Intelligence (CogMI)}, 
  title={Automated Threat Emulation Framework with LLMs for Cyber Physical Systems}, 
  year={2025},
  volume={},
  number={},
  pages={449-459},
  abstract={Securing cyber-physical systems (CPS), which often form a nation’s critical infrastructure, is becoming increasingly challenging. New threats are arising due to vulnerabilities in the Information Technology (IT), Operational Technology (OT), and their interactions. Moreover, the growth in artificial intelligence (AI) technologies have made it easy for attackers to exploit system vulnerabilities. A primary concern is the insufficient effectiveness of cyber operations and automated decision-making processes, which currently rely heavily on manual evaluation and subject matter experts (SMEs). A primary concern is the limited effectiveness of security evaluation methodologies in understanding a system’s behavior during an attack. Current methodologies are generally suited for IT environments and do not easily adapt to OT due to their complexity. In addition, cybersecurity evaluation methods in OT often depend on manual evaluation and subject matter experts (SMEs).This paper introduces a novel framework based on LLMs and AI planning to automate threat emulation, facilitating the evaluation of the cybersecurity posture of OT systems. The newly introduced ‘Automated Threat Emulation Framework’ integrates with MITRE ATT&CK for automatic execution of various Tactics, Techniques, and Procedures (TTPs) employed by the real-time attacks for emulating the threats. Our framework employs multiple specialized LLM-driven agents that collaboratively perform tasks of context summarization, strategic planning, decision-making, external data retrieval, automated code generation, and secure execution. Central to our methodology is the incorporation of AI Planning and Causal Loop Diagrams (CLD) to accurately simulate cyber-attacks and systematically analyze cascading effects across interconnected CPS components. Through a comprehensive prototype implementation and a detailed case study involving a digital substation automation system, we demonstrate the practical effectiveness and robustness of our approach. Our research contributes significantly to the domain by providing a systematic, adaptive, and scalable solution for real-time cyber security threat assessment, enhancing the resilience and security posture of critical CPS infrastructure against emerging threats.},
  keywords={Substation automation;Systematics;Subject matter experts;Emulation;Decision making;Strategic planning;Real-time systems;Threat assessment;Robustness;Smart grids;Cyber Physical Systems (CPS);MITRE ATT&CK;Threat emulation;Substation Automation System;Causal Loop Diagram (CLD);Large Language Model (LLM);AI planning;Machine Learning (ML);Smart grids},
  doi={10.1109/CogMI67134.2025.00059},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11344468,
  author={Karamchandani, Aaditya and Seyeddabbaghi, Fatemeh and Fokaefs, Marios},
  booktitle={2025 IEEE International Conference on Collaborative Advances in Software and COmputiNg (CASCON)}, 
  title={From Requirements to Models: A Case Study of Large Language Models on Epidemiological Modeling}, 
  year={2025},
  volume={},
  number={},
  pages={516-521},
  abstract={Epidemiological modeling is a critical step in understanding and studying diseases. Although conventional modeling techniques exist, such as compartmental or agentic models, supporting tools are not necessarily standardized. Consequently, learning a new tool may take a significant amount of effort. In this work, we explore the use of Large Language Models (LLMs) as a means to quickly transition from requirements, in the form of graphical model representations and initial parameters, to a software-aided modeling platform with simulation and verification capabilities. Our methodology employs a metamodelbased language specification for prompt engineering, combined with multimodal inputs comprising textual descriptions and epidemiological diagrams. We evaluated LLM performance in three epidemiological models of varying complexity: a simple SIR compartmental model, a COVID-19 pandemic model, and an HIV transmission model. Initial results demonstrate the potential of LLMs to significantly reduce manual modeling effort while maintaining accuracy in structural representation and parameter extraction. The study provides insights into optimal input configurations and identifies key challenges in automated epidemiological model generation.},
  keywords={Visualization;Accuracy;Translation;Computational modeling;Large language models;XML;Manuals;Mathematical models;Cognition;Prompt engineering;Epidemiological Modeling;Large Language Models;Model-Driven Engineering;Automated Code Generation;SEIR Models;Prompt Engineering},
  doi={10.1109/CASCON66301.2025.00082},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11374913,
  author={Rajyaguru, MihirHarishbhai and Gupta, Devdas and Rekha, G. Sunitha and YM, Manu and P, Rakshitha Kiran and SChhajed, Ajay},
  booktitle={2025 Tenth International Conference on Science Technology Engineering and Mathematics (ICONSTEM)}, 
  title={Reinforcement Learning-Optimized Resource Allocation Framework for Edge Computing}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={The research introduces a Reinforcement Learning-Optimized Framework of Resource Allocation in Edge Computing based on the Centralized Training, Decentralized Implementation (CTDE) Multi-Agent Actor-Critic algorithm, which is applied in Ray RLlib with Ray Cluster. The objective of the framework is to optimize dynamic resource distribution among heterogeneous edge nodes and minimize the latency, energy use and communication overheads. The system assumes the efficient coordination and quick adaptation to changing workloads through the employment of centralized critic in case of global policy learning and a decentralized actor in case of local decision-making. Experimental assessments show the proposed model is better than the classic model which is DQN, PPO, and FDRL with significant gains in the reduction of task latency, resource usage and scalability. Much more efficiency in distributed training and robustness in large-scale edge networks is achieved with the integration with Ray Cluster. Altogether, the suggested CTDE framework has the potential to be utilized as a scalable, intelligent, energy-demanding solution to the next-generation edge computing environment.},
  keywords={Training;Adaptation models;Scalability;Reinforcement learning;Robustness;Resource management;Synchronization;Optimization;Edge computing;STEM;Reinforcement Learning;Edge Computing;Resource Allocation;Multi-Agent Actor-Critic;Centralized Training Decentralized Execution;Ray RLlib;Distributed Optimization},
  doi={10.1109/ICONSTEM65670.2025.11374913},
  ISSN={2996-2986},
  month={Nov},}@INPROCEEDINGS{11356802,
  author={Wang, Huaiyuan and Jiang, Changkun},
  booktitle={2025 IEEE International Conference on Bioinformatics and Biomedicine (BIBM)}, 
  title={ProtAgent-ESM2: an Efficient Framework for Long Protein Sequences Modeling in Protein-Protein Interaction Prediction}, 
  year={2025},
  volume={},
  number={},
  pages={196-201},
  abstract={Existing sequence-based protein-protein interaction (PPI) prediction methods face a critical bottleneck: the quadratic computational complexity of standard Transformer attention mechanisms often necessitates models to truncate protein sequences, leading to information loss and performance limitations. This paper introduces ProtAgent-ESM2, a novel framework that overcomes this limitation by integrating a protein-specific Agent Attention mechanism into the ESM-2 backbone. Our framework decomposes dense attention interactions into two sparse stages through learnable agent tokens, reducing computational complexity from quadratic to near-linear while maintaining global context modeling capabilities. We implement protein-specific adaptations, including asymmetric rotary position embeddings, local structure modeling through depthwise separable convolutions, and a hybrid embedding strategy that combines static ESM-2 representations with dynamic task-specific features. To validate our framework, we construct Intra-2-Long, a challenging benchmark specifically designed to evaluate performance on long protein sequences. Experimental results demonstrate that ProtAgent-ESM2 achieves competitive performance on standard benchmarks while maintaining consistent performance across varying sequence lengths, advancing the state-of-the-art in computational PPI prediction.},
  keywords={Proteins;Protein engineering;Attention mechanisms;Computational modeling;Biological system modeling;Benchmark testing;Predictive models;Transformers;Computational complexity;Standards;Protein-Protein Interactions;Agent Attention;Protein Language Models;Long Protein Sequences Modeling},
  doi={10.1109/BIBM66473.2025.11356802},
  ISSN={2156-1133},
  month={Dec},}@ARTICLE{11417765,
  author={Oesch, Sean and Hutchins, Jack and Kurian, Kevin and Koch, Luke},
  journal={IEEE Security & Privacy}, 
  title={Living Off the LLM: How LLMs Will Change Adversary Tactics}, 
  year={2026},
  volume={},
  number={},
  pages={2-7},
  abstract={In living-off-the-land (LOTL) attacks, malicious actors use legitimate tools and processes already present on a system to avoid detection. This article examines how threat actors will leverage on-device large language models into LOTL attack pipelines and how to mitigate this threat.},
  keywords={Codes;Malware;Safety;Vectors;Security;Training;Organizations;Machine learning;Libraries;Critical infrastructure},
  doi={10.1109/MSEC.2026.3659035},
  ISSN={1558-4046},
  month={},}@ARTICLE{11367020,
  author={Qaisar, Muhammad Umar Farooq and Yuan, Weijie and Zhang, Lin and Ashraf Chaudhry, Shehzad and Han, Guangjie and Zhang, Yunyang},
  journal={IEEE Transactions on Network and Service Management}, 
  title={A Robust Trust Management System for V2X Networks Integrating ISAC With Blockchain Smart Contracts}, 
  year={2026},
  volume={23},
  number={},
  pages={2428-2439},
  abstract={Vehicle-to-everything (V2X) networks face critical security challenges due to their dynamic nature, stringent latency requirements, and susceptibility to malicious attacks. Traditional trust management approaches often rely on centralized authorities or historical data, creating vulnerabilities and scalability limitations. This paper presents a new trust management system that leverages integrated sensing and communication (ISAC) technology and blockchain-based smart contracts to provide secure and decentralized trust evaluation in V2X networks. The proposed framework leverages real-time ISAC signal processing to compute five comprehensive trust metrics: behavior score, reputation score, safety score, uptime score, and response time score. These metrics are derived through advanced Kalman filtering and statistical anomaly detection applied to physical-layer measurements, enabling immediate detection of malicious activities that traditional approaches might miss. Trust records are securely stored and validated through smart contracts deployed on 5G base station blockchains, ensuring tamper-proof storage and automated policy enforcement. Numerical results demonstrate that the proposed protocol achieves faster trust convergence, higher communication reliability, significant reduction in false positive rates, improved detection accuracy, acceptable end-to-end latency, and lower computational overhead compared to state-of-the-art approaches.},
  keywords={Vehicle-to-everything;Blockchains;Trust management;Integrated sensing and communication;Vehicle dynamics;Real-time systems;Computer architecture;Anomaly detection;Smart contracts;Base stations;Vehicle-to-everything;trust management;ISAC;blockchain;5G networks},
  doi={10.1109/TNSM.2026.3658589},
  ISSN={1932-4537},
  month={},}@ARTICLE{11301040,
  author={He, Qiang and Qiu, Tianyi and Wang, Xingwei and Hawbani, Ammar and Ma, Lianbo and Yu, Keping and Zhao, Liang},
  journal={IEEE Transactions on Services Computing}, 
  title={Blockchain-Enabled Elastic Task Offloading and Migration Scheme in Edge Computing System}, 
  year={2025},
  volume={},
  number={},
  pages={1-15},
  abstract={Mobile edge computing (MEC), which improves the quality of experience of mobile devices by offloading tasks to edge servers, has become a promising paradigm. This method can effectively reduce computational latency and lower energy consumption. However, traditional task offloading and migration schemes only consider a single static scenario, making it difficult to provide users with elastic computing services in changing environments. Moreover, the quality and cost of the same task vary depending on the service level. To tackle this problem, we propose a reinforcement learning approach called LSTM-SAC, which integrates long short-term memory (LSTM) with soft actor-critic (SAC). LSTM-SAC provides elastic computing services to users in MEC systems by adaptively selecting models based on the current environment, thereby enhancing the flexibility of MEC systems. In addition, we deploy the blockchain on the MEC system to enhance its security. All users must authenticate their identities by running a smart contract deployed on the blockchain before offloading tasks. The experimental results show that our proposed method outperforms benchmark methods in terms of convergence and security.},
  keywords={Blockchains;Servers;Edge computing;Security;Smart contracts;Optimization;Peer-to-peer computing;Mobile handsets;Internet of Things;Long short term memory;Mobile edge computing;task offloading and migration;blockchain;elastic computing},
  doi={10.1109/TSC.2025.3634215},
  ISSN={1939-1374},
  month={},}@INPROCEEDINGS{11352940,
  author={Kanikanti, Venkata Sai Nageen and Tiwari, Sujeet Kumar and Nayan, Vishal and Suryawanshi, Shubhangi and Banerjee, Vivek and Ahmed, Imad Eldin},
  booktitle={2025 10th International Conference on Information Technology Trends (ITT)}, 
  title={Deep Q-Learning Driven Dynamic Optimal Task Scheduling for Cloud Computing Using Optimal Queuing}, 
  year={2025},
  volume={},
  number={},
  pages={112-117},
  abstract={With the rapid expansion of cloud computing infrastructures, energy consumption and efficient resource utilization have become critical concerns impacting operational costs and environmental sustainability. Traditional task scheduling methods often fail to optimize energy use while meeting strict task deadlines, leading to inefficiencies in largescale cloud environments. This research addresses the challenge of energy-efficient task scheduling in cloud computing by proposing a dynamic scheduling framework that integrates an optimal M/M/S queuing for task dispatching with deep Q-learning (DQL) based scheduler for task prioritization and allocation. The primary objective is to minimize energy consumption and task response time while maximizing server utilization and meeting user-defined deadlines. The M/M/S queuing model distributes incoming tasks evenly among servers, reducing bottlenecks, and the DQL scheduler prioritizes tasks based on their laxity and lifetime, adapting dynamically through continuous learning. Experiments were conducted on the Alibaba Cluster Traces v2018 dataset, which includes over 4.5 million workload records from a production environment. Compared to baseline models such as RC-GA and AMTS, the proposed model reduces average task response time by up to 36.7%, lowers energy consumption per task by 25%, and improves server CPU utilization by 15.4%. These results confirm the efficacy of combining queuing theory with DRL for optimizing cloud task scheduling in terms of both performance and energy efficiency.},
  keywords={Cloud computing;Adaptation models;Energy consumption;Q-learning;Processor scheduling;Heuristic algorithms;Dynamic scheduling;Servers;Time factors;Resource management;cloud computing;energy-efficient scheduling;task prioritization;resource optimization;workload management},
  doi={10.1109/ITT69610.2025.11352940},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11280285,
  author={Kusper, Gábor and Szabó, Csaba},
  booktitle={2025 International Conference on Emerging eLearning Technologies and Applications (ICETA)}, 
  title={Vibe Coding in Education}, 
  year={2025},
  volume={},
  number={},
  pages={506-511},
  abstract={Vibe coding is an emerging approach to programming education in which students collaborate with AI assistants in a creative and immersive manner. In this paper we present the development of an educational material designed to practice vibe coding and position it in relation to project-based learning, highlighting the novel perspective that AI can act as a teammate in the learning process. The present version of this paper reports a preliminary analysis based on data from the earlier study "We Are Not Afraid of the Wolf!". From this dataset, two hypotheses were examined: (H1) vibe coding increases students’ confidence in their programming solutions, and (H2) vibe coding enhances productivity, enabling more tasks to be completed in a given time. Preliminary results suggest that while confidence is only weakly improved, it is strongly associated with enjoyment and flow experiences, and that students perceive and demonstrate increased productivity when using AI support. The next version of this study will include the results of a dedicated, targeted experiment using a questionnaire specifically designed for vibe coding. This instrument will allow us to capture multiple dimensions of confidence, align subjective and objective productivity, and explore students’ perception of AI as a collaborator.},
  keywords={Productivity;Electronic learning;Instruments;Education;Collaboration;Encoding;Artificial intelligence;Programming profession;vibe coding;programming education;AI collaboration},
  doi={10.1109/ICETA67772.2025.11280285},
  ISSN={},
  month={Nov},}@ARTICLE{11223998,
  author={Liang, Shuang and Yin, Minghao and Sun, Geng and Xie, Wenwen and Wang, Yiyuan and Sun, Zemin and Li, Jiahui and Leung, Victor C. M.},
  journal={IEEE Transactions on Cognitive Communications and Networking}, 
  title={Low-Altitude UAV-Assisted Reliable Communication for Disaster Relief IoT Networks via Diffusion Model- Enhanced Deep Reinforcement Learning}, 
  year={2026},
  volume={12},
  number={},
  pages={3555-3572},
  abstract={In disaster-stricken areas, maintaining reliable communication networks is essential for effective rescue operations. This paper proposes a novel approach to enhance the connectivity of rescue networks by integrating collaborative beamforming with low-altitude uncrewed aerial vehicle (UAV) trajectory planning. We model a scenario where Internet of Things (IoT) devices transmit collected environmental data to the rescue control center (RCC) through a ground-based virtual antenna array (GVAA), with UAVs serving as relays in this disaster-affected network. The primary objective is to minimize communication outages and reduce the energy consumption of both the UAVs and ground-based devices. Due to the dynamic movement of the RCC toward target areas, the system exhibits significant dynamism, requiring long-term optimization of UAV positions to maintain consistent connectivity. To address this, we propose a diffusion model-based proximal policy optimization (DMPPO) algorithm, which optimizes UAV trajectories and other system parameters to minimize communication outage rate while also reducing energy consumption. Simulation results demonstrate that the proposed DMPPO reduces the outage probability and energy consumption of UAVs and IoT devices by 88.71%, 3.02%, and 50.31%, respectively, compared to the suboptimal benchmark. This indicates that DMPPO is more suitable for the considered emergency scenarios. Furthermore, the DMPPO algorithm consistently outperforms benchmark methods across various challenging configurations, such as different UAV numbers and distances, demonstrating its scalability and robustness.},
  keywords={Disasters;Internet of Things;Autonomous aerial vehicles;Optimization;Energy consumption;Collaboration;Reliability;Trajectory;Spread spectrum communication;Real-time systems;Low-altitude wireless networks;collaborative beamforming;network connectivity;energy efficiency;deep reinforcement learning},
  doi={10.1109/TCCN.2025.3627922},
  ISSN={2332-7731},
  month={},}@ARTICLE{11397202,
  author={Zhao, Zeyu and Che, Yueling and Luo, Sheng and Wu, Kaishun and Leung, V. C. M.},
  journal={IEEE Transactions on Mobile Computing}, 
  title={Toward Adaptive IoT Service Balance in Low-Altitude Economy: Multi-UAV-Aided Bi-Objective Wireless Data Collection and Wireless Energy Transfer}, 
  year={2026},
  volume={},
  number={},
  pages={1-15},
  abstract={The rapid development of the low-altitude economy (LAE) has significantly enhanced the service diversity of the Internet of Things (IoT) networks, necessitating efficient coordination among the unmanned aerial vehicles (UAVs). In this work, we utilize multiple UAVs to provide both wireless data collection (WDC) service and wireless energy transfer (WET) service, and divide the IoT devices into the I-devices that only need the WDC service and the E-devices that only need the WET service, respectively, from the multiple UAVs. Due to their conflicting service demands on the UAVs with limited resources, we formulate the bi-objective optimization problem (BOOP) to minimize the age of information (AoI) for the I-devices and the hungry-level of energy (HoE) for the E-devices at the same time, by jointly optimizing all the UAVs' trajectories and WET decisions over time slots and their WDC decisions over sub-slots. To efficiently solve the complex BOOP, we innovatively transform it into a single-objective optimization problem (SOOP), in which the two conflicting objectives are scalarized via a self-adaptive objective weight. Unlike the conventional approach reliant on fixed and pre-defined objective weights, we optimize the objective weight jointly with other decision variables, enabling automatic adaptation to various network environments without human intervention. However, the proposed SOOP is NP-hard with a large number of decision variables. Accordingly, we propose a new Multi-Agent Adaptive and Hierarchical Deep Reinforcement Learning (MA $^{2}$ HDRL) framework, which leverages a central controller (CC) to guide the local training of multiple individual UAV agents. In this framework, each UAV agent employs a two-tier hierarchical DRL model: tier-1 optimizes the trajectory and WET policies over the time slots, while tier-2 optimizes the WDC policy across the sub-slots. Meanwhile, the CC trains the global reward preference for all the UAV agents over the training episodes, to adaptively balance the WDC and WET service demands. Finally, extensive simulation results are conducted to demonstrate the outstanding performance of the proposed MA $^{2}$ HDRL approach as compared to state-of-the-art benchmarks.},
  keywords={Internet of Things;Autonomous aerial vehicles;Trajectory;Wireless communication;Training;Optimization;Performance evaluation;Adaptation models;Wireless sensor networks;Data collection;Deep reinforcement learning (DRL);low - altitude economy (LAE);unmanned aerial vehicles (UAVs);wireless data collection (WDC);wireless energy transfer (WET);bi-objective optimization},
  doi={10.1109/TMC.2026.3664903},
  ISSN={1558-0660},
  month={},}@INPROCEEDINGS{10972958,
  author={Khan, Omar and Nguyen, Anh and Nam, Hyeongil and Kim, Kangsoo},
  booktitle={2025 IEEE Conference on Virtual Reality and 3D User Interfaces Abstracts and Workshops (VRW)}, 
  title={Investigating Visual Guide Cues in VR: Impacts of Virtual Humans and Symbol-Based Navigation on Real-World Performance and Experience}, 
  year={2025},
  volume={},
  number={},
  pages={504-509},
  abstract={Virtual experiences can significantly influence our perception and behavior in the real world, shaping how we interact with and navigate physical environments. In this paper, we examine the impact of learning navigation routes in an immersive virtual environment (IVE) on navigation performance and user experience in a corresponding real-world indoor setting. We developed a guide system with two distinct audiovisual representations: a human agent guide and a symbol-based guide. A preliminary user study (N = 10) was conducted to evaluate the system. While no significant differences were observed between the two guide conditions, the findings reveal valuable insights into user-perceived confidence and enjoyment during real-world navigation tasks. Contrary to our expectations, the symbol-based guide elicited slightly higher positive scores compared to the human agent guide. We discuss these findings and outline directions for future research.},
  keywords={Visualization;Three-dimensional displays;Navigation;Conferences;Virtual environments;User interfaces;User experience;Real-Virtual influence;navigation;visual cues;virtual human;enjoyment;confidence;task load},
  doi={10.1109/VRW66409.2025.00110},
  ISSN={},
  month={March},}@INPROCEEDINGS{10752222,
  author={Islam, Md. Adnanul and Abdullah Sayeedi, Md. Faiyaz and Deepti, Jannatul Ferdous and Bappy, Shahanur Rahman and Islam, Safrin Sanzida and Hafiz, Fahim},
  booktitle={2024 IEEE Region 10 Symposium (TENSYMP)}, 
  title={MosquitoMiner: A Light Weight Rover for Detecting and Eliminating Mosquito Breeding Sites}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={In this paper, we present a novel approach to the development and deployment of an autonomous mosquito breeding place detector rover with the object and obstacle detection capabilities to control mosquitoes. Mosquito-borne diseases continue to pose significant health threats globally, with conventional control methods proving slow and inefficient. Amidst rising concerns over the rapid spread of these diseases, there is an urgent need for innovative and efficient strategies to manage mosquito populations and prevent disease transmission. To mitigate the limitations of manual labor and traditional meth-ods, our rover employs autonomous control strategies. Leveraging our own custom dataset, the rover can autonomously navigate along a pre-defined path, identifying and mitigating potential breeding grounds with precision. It then proceeds to eliminate these breeding grounds by spraying a chemical agent, effectively eradicating mosquito habitats. Our project demonstrates the effectiveness that is absent in traditional ways of controlling and safeguarding public health. The code for this project is available on GitHub at -https://github.com/faiyazabdullah/MosquitoMiner},
  keywords={Navigation;Microcontrollers;Spraying;Manuals;Detectors;Hardware;Public healthcare;Diseases;Software development management;IEEE Regions;Autonomous;Rover;Mosquito;Breeding place;Object detection},
  doi={10.1109/TENSYMP61132.2024.10752222},
  ISSN={2642-6102},
  month={Sep.},}@INPROCEEDINGS{11389096,
  author={Mba, Onyedikachukwu Tochukwu and Ahakonye, Love Allen Chijioke and Lee, Jae Min and Kim, Dong-Seong},
  booktitle={2025 16th International Conference on Information and Communication Technology Convergence (ICTC)}, 
  title={I Understand Understand You: A Reliable Multi-Agent Facilitator for Reducing Communication Breakdowns}, 
  year={2025},
  volume={},
  number={},
  pages={1055-1060},
  abstract={Imagine a mediator who fosters active listening and effective communication between English speakers, without judgment, but by encouraging each party involved to be themselves. Imagine that this speaker not only hears you, but "understands understands" you! Picture that conversations between English-speaking professionals from across the globe can be possible and seamless, and all the while, without any form of prejudice! Think about it, for a moment, that there would no longer be any need for code-switching! This is why I Understand Understand You (IUUY), an active-listening facilitator and a coach that helps promote multi-culturally competent conversations, might just be the answer you have been waiting for. IUUY, though still in its early research and development stages, is a multi-agent AI system (MAS) augmented by blockchain technology to facilitate great conversations and reduce communication breakdowns, both ethically and securely. Currently a 4-agent entity, it aims to foster fair, inclusive, and trustworthy conversations in culturally diverse professional and personal spaces. An Agile methodology, particularly the Scrum framework, will guide its continuous iterative development, user-centric prototyping, and responsive learning cycles.},
  keywords={Ethics;Electric breakdown;Oral communication;Blockchains;Information and communication technology;Reliability;Iterative methods;Artificial intelligence;Sustainable development;Research and development;Active Listening;Code-switching;Blockchain;Collaboration;Dialtectal Variation;MAS},
  doi={10.1109/ICTC66702.2025.11389096},
  ISSN={2162-1241},
  month={Oct},}@INPROCEEDINGS{10901701,
  author={Zeng, Peigen and He, Ying and Yu, F. Richard and Du, Jianbo},
  booktitle={GLOBECOM 2024 - 2024 IEEE Global Communications Conference}, 
  title={A Quantum Temporal Difference Learning Method Based on Quantum World Model}, 
  year={2024},
  volume={},
  number={},
  pages={4010-4015},
  abstract={Based on quantum parallelism theory and quantum phenomena such as superposition and entanglement, quantum reinforcement learning (QRL) has the potential to surpass classical reinforcement learning (RL). Although some excellent works have been done on QRL, existing RL methods encounter chanllenges when performing in environments with sparse rewards. In this paper, we provide a new perspective on conducting temporal difference (TD) learning in quantum computing, which can eliminate redundant exploration steps compared to classical methods. Specifically, we first use environment information to construct a world model with quantum circuits, enabling it to interact in a quantum way. Then, we perform the learning process by using the quantum world model and Grover’s algorithm to query backwards how to reach the recorded states with high TD-errors. Simulation results show that our proposed method has superior performance compared to classical RL algorithms.},
  keywords={Quantum entanglement;Computational modeling;Simulation;Temporal difference learning;Parallel processing;Global communication;Integrated circuit modeling;Quantum circuit;Reinforcement learning;Quantum information;Temporal difference learning;Grover’s algorithm;Sparse reward environment},
  doi={10.1109/GLOBECOM52923.2024.10901701},
  ISSN={2576-6813},
  month={Dec},}@ARTICLE{10643216,
  author={Pei, Manlin and Wang, Chenyu and Wang, Xia and Zheng, Zhigao and Huang, Jianhui and Wang, Shengling and Guo, Yufei},
  journal={IEEE Transactions on Consumer Electronics}, 
  title={Hierarchical Reverse Games for the Resource Ecosystem in Cloud–Edge Computing}, 
  year={2025},
  volume={71},
  number={2},
  pages={4039-4052},
  abstract={Edge computing has emerged as a killer technology for a hyper-connected world due to its distributed architecture and customer-proximity property. Combined edge nodes with the cloud data center, a cloud-edge computing paradigm is formed, whose resource ecosystem calls for competitive pricing and optimal resource allocation. However, it is not feasible to realize global information-based optimization since some information is kept private to their owners. To solve this challenge, this paper develops the user-independent hierarchical reverse game and the user-assisted hierarchical reverse game to depict the relationship among the resource provider, the resource tenant, and the resource user. The aim is to seek the optimal strategies for players without revealing any private information. The common trait of both games is to force the players to report the optimal strategies based on their actual private information. This salient trait can produce privacy-preservation optimization since there is no requirement for the players to release their individual information directly, and the optimal strategies of other players can be deduced naturally. The difference between the user-independent hierarchical reverse game and the user-assisted one is that the game rules are stipulated entirely by the provider and the tenants (edge nodes) in the former, while some game rules can be customized according to the advice of users in the latter. This leads the user-independent hierarchical reverse game is more concise and easy to guarantee the incentive compatibility constraint, while the user-assisted hierarchical reverse game can attract more users since the game rules can adapt to their economic status, requirements, and preferences.},
  keywords={Games;Resource management;Cloud computing;Pricing;Optimization;Ecosystems;Privacy;Cloud-edge computing;resource allocation;hierarchical reverse game;privacy-preservation},
  doi={10.1109/TCE.2024.3415572},
  ISSN={1558-4127},
  month={May},}@ARTICLE{9151374,
  author={Wang, Yu and Zhao, Shengjie and Zhang, Rongqing and Cheng, Xiang and Yang, Liuqing},
  journal={IEEE Transactions on Intelligent Transportation Systems}, 
  title={Multi-Vehicle Collaborative Learning for Trajectory Prediction With Spatio-Temporal Tensor Fusion}, 
  year={2022},
  volume={23},
  number={1},
  pages={236-248},
  abstract={Accurate behavior prediction of other vehicles in the surroundings is critical for intelligent transportation systems. Common practices to reason about the future trajectory are through their historical paths. However, the impact of traffic context is ignored, which means the beneficial environment information is deserted. Although a few methods are proposed to exploit the surrounding vehicle information, they simply model the influence according to spatial relations without considering the temporal information among them. In this paper, a novel multi-vehicle collaborative learning with spatio-temporal tensor fusion model for vehicle trajectory prediction is proposed, which introduces a novel auto-encoder social convolution mechanism and a fancy recurrent social mechanism to model spatial and temporal information among multiple vehicles, respectively. Furthermore, the generative adversarial network is incorporated into our framework to handle the inherent multi-modal characteristics of the agent motion behavior. Finally, we evaluate the proposed multi-vehicle collaborative learning model on NGSIM US-101 and I-80 benchmark datasets. Experimental results demonstrate that the proposed approach outperforms the state-of-the-art for vehicle trajectory prediction. Additionally, we also present qualitative analyses of the multi-modal vehicle trajectory generation and the impacts of surrounding vehicles on trajectory prediction under various circumstances.},
  keywords={Trajectory;Predictive models;Generative adversarial networks;Collaborative work;Tensile stress;Intelligent vehicles;Gallium nitride;Collaborative learning;spatio-temporal tensor fusion;vehicle trajectory prediction;generative adversarial networks},
  doi={10.1109/TITS.2020.3009762},
  ISSN={1558-0016},
  month={Jan},}@INPROCEEDINGS{10009772,
  author={Seyyedabbasi, Amir},
  booktitle={2022 International Conference on Theoretical and Applied Computer Science and Engineering (ICTASCE)}, 
  title={Solve the Inverse Kinematics of Robot Arms using Sand Cat Swarm Optimization (SCSO) Algorithm}, 
  year={2022},
  volume={},
  number={},
  pages={127-131},
  abstract={Inverse kinematics of robot arms is one of the optimization problems. The six joints of the Six degrees of freedom PUMA 560 robot arm are considered as an inverse kinematics system in this study. There are many possibilities for joint angles in this problem, making the analysis difficult to determine using deterministic rules. Several metaheuristic algorithms are presented in this paper for solving the inverse kinematics problem of robot arms, including the sand cat swarm optimization algorithm (SCSO). Additionally, we compare the particle swarm optimization (PSO), grey wolf optimization (GWO), and whale optimization algorithm (WOA) optimization algorithms to see which is most efficient. In this study, meta-heuristic algorithms are used to determine the inverse kinematics of the robotic arm, which are essential to tracking a rectangular trajectory in three dimensions. A cost function analysis was conducted in order to further analyze the results. In addition, the results of the comparison of the meta-heuristic algorithms to the inverse kinematics task showed that the SCSO algorithm performed better than the competitors.},
  keywords={Simulation;Metaheuristics;Kinematics;Arms;Manipulators;Cost function;Whale optimization algorithms;Inverse Kinematics;metaheuristic algorithms;sand cat swarm optmization;optimization problems;robotics},
  doi={10.1109/ICTACSE50438.2022.10009772},
  ISSN={},
  month={Sep.},}@ARTICLE{10024303,
  author={Sarthou, Guillaume},
  journal={IEEE Robotics and Automation Letters}, 
  title={Overworld: Assessing the Geometry of the World for Human-Robot Interaction}, 
  year={2023},
  volume={8},
  number={3},
  pages={1874-1880},
  abstract={For a robot to interact with humans in a given environment, a key need is to understand its environment in terms of the objects composing it, the other agents acting in it, and the relations between all of them. This capability is often called the geometrical situation assessment and is mainly related to spatial reasoning in time. In this letter, we present Overworld, a novel lightweight and open-source framework, merging the key features of a decade of research in the domain. It permanently maintains a geometric state of the world from the point of view of the robot by aggregating perceptual information from several sources and reasoning on them to create a coherent world. Furthermore, Overworld implements perspective-taking by emulating the humans' ability to perceive to estimate the state of the world from their perspective. Finally, thanks to a strong link with an ontology framework, it ensures knowledge coherence in the whole robotic architecture. This work is part of a broader effort to develop a complete, stable, and shareable decisional robotic architecture for Human-Robot Interaction.},
  keywords={Robot kinematics;Robot sensing systems;Computer architecture;Sensors;Human-robot interaction;Cognition;Knowledge based systems;Multi-modal perception for HRI;human-robot collaboration;software architecture for robotic and automation},
  doi={10.1109/LRA.2023.3238891},
  ISSN={2377-3766},
  month={March},}@INPROCEEDINGS{10611168,
  author={Nardelli, Alice and Sgorbissa, Antonio and Recchiuto, Carmine Tommaso},
  booktitle={2024 IEEE International Conference on Robotics and Automation (ICRA)}, 
  title={Personality- and Memory-Based Software Framework for Human-Robot Interaction}, 
  year={2024},
  volume={},
  number={},
  pages={17388-17394},
  abstract={The synergic orchestration of the cognitive and psychological dimensions characterizes human intelligence. Accordingly, carefully designing this mechanism in artificial intelligence can be a successful strategy to increase human likeness in a robot, enhancing mutual understanding and building a more natural and intuitive interaction. For this purpose, the main contribution of this work is a psychological and cognitive architecture tailored for HRI based on the interplay between robotic personality and memory-based cognitive processes. Indeed, the artificial personality manifests itself not only in various aspects of the behavior but also within the action selection process, which is closely intertwined with personality-dependent hedonic experiences linked to memories. Within this paper, we propose a task- and platform-independent framework, evaluated in a multiparty collaborative scenario. Obtained results show that a robot connected to our proposed framework is perceived as a cognitive agent capable of manifesting perceivable and distinguishable personality traits.},
  keywords={Software architecture;Taxonomy;Buildings;Psychology;Human-robot interaction;Collaboration;Vectors;Artificial personality;Human-Robot Interaction;Personality-adaptive architecture;Social Robotics},
  doi={10.1109/ICRA57147.2024.10611168},
  ISSN={},
  month={May},}@INPROCEEDINGS{10581812,
  author={Huang, Luosen and Liu, Hengyuan and Liu, Yong and Shang, Ying and Li, Zheng},
  booktitle={2024 5th International Seminar on Artificial Intelligence, Networking and Information Technology (AINIT)}, 
  title={A Generative Adversarial Imitation Learning Method for Continuous Integration Testing}, 
  year={2024},
  volume={},
  number={},
  pages={1084-1089},
  abstract={In Continuous Integration (CI), Test Case Prioritization (TCP) is crucial for the efficiency and effectiveness of the software testing. While Reinforcement Learning (RL) offers a promising approach for TCP, it struggles with the low failure rates of test cases in industrial CI environment, leading to sparse rewards and unstable learning efficiency. Furthermore, designing a proper reward function is challenging due to its dependency on the abstracted features of the test cases. To address these issues, we propose a Generative Adversarial Imitation Learning (GAIL) method for TCP, which allows agents to learn directly from the expert experience rather than through potentially biased reward functions. We use the Copeland method as a pairwise ranking strategy and train the agent using optimal rankings, considered as expert experience generated from previous CI cycles, leading to more stable and efficient learning. In addition, we introduce a new metric, the Average of the Percentage of Faults Detected based on Execution Time (APFDET), to evaluate the effectiveness of the proposed approach. Empirical studies are performed on six industrial datasets. The results show that GAIL has a better fault detection capability on TCP problems.},
  keywords={Software testing;Seminars;Measurement;Imitation learning;Fault detection;Reinforcement learning;Continuous integration;Continuous Integration;Test Case Prioritization;Generative Adversarial Imitation Learning},
  doi={10.1109/AINIT61980.2024.10581812},
  ISSN={},
  month={March},}@INPROCEEDINGS{10571207,
  author={Tang, Yaxin and Li, Xiuhua and Li, Hui and Yang, Zhengyi and Wang, Xiaofei and Leung, Victor C. M.},
  booktitle={2024 IEEE Wireless Communications and Networking Conference (WCNC)}, 
  title={Collaborative DNNs Inference with Joint Model Partition and Compression in Mobile Edge-Cloud Computing Networks}, 
  year={2024},
  volume={},
  number={},
  pages={01-06},
  abstract={Mobile edge-cloud computing utilizes the computing resources of edge devices and cloud servers to execute complex deep neural networks (DNNs) for collaborative inference. However, many existing collaborative inference methods do not fully consider the limited resources of edge devices, resulting in high inference latency. In this paper, we design an integrated computational framework that combines model partition and compression to reduce inference latency. Specifically, we partition a DNN model at the middle layer and deploy the previous layer on the edge device and the subsequent layer on the cloud server respectively. We propose a collaborative dual-agent reinforcement learning algorithm called CPCDRL to determine partition point and compression ratios. It enables adaptive adjustments of compression ratios based on various partition points, with the overarching goal of minimizing the inference latency across the entire DNN model. The proposed algorithm can significantly reduce computational latency while minimizing accuracy loss compared to the baseline schemes.},
  keywords={Performance evaluation;Adaptation models;Computational modeling;Simulation;Collaboration;Artificial neural networks;Reinforcement learning},
  doi={10.1109/WCNC57260.2024.10571207},
  ISSN={1558-2612},
  month={April},}@INPROCEEDINGS{9843331,
  author={Herrmann, Adam and Schaub, Hanspeter},
  booktitle={2022 IEEE Aerospace Conference (AERO)}, 
  title={Autonomous On-board Planning for Earth-Orbiting Spacecraft}, 
  year={2022},
  volume={},
  number={},
  pages={1-9},
  abstract={This work explores on-board planning and scheduling for the multi-target, single spacecraft Earth-observing satellite (EOS) scheduling problem. The problem is formulated as a Markov decision process (MDP) where the number of targets included in the state and action space is an adjustable parameter that may account for clusters of targets with varying priorities. As targets are passed or imaged, they are replaced in the state and action space with the next set of upcoming targets. Unlike prior EOS problem formulations, this work explores how the size of the state and action space can be reduced to produce optimal, generalized policies that may be executed on board the spacecraft in a fraction of a second. Performance of the agents is shown to increase with the number of targets in the state and action space. The number of imaged and downlinked targets stays relatively constant, but the reward increases significantly, demonstrating that the agents are prioritizing high priority targets over low priority targets.},
  keywords={Space vehicles;Geometry;Satellites;Monte Carlo methods;Earth Observing System;Markov processes;Search problems},
  doi={10.1109/AERO53065.2022.9843331},
  ISSN={1095-323X},
  month={March},}@INPROCEEDINGS{10132174,
  author={Diemert, Simon and Casey, Adam and Robertson, Jeremiah},
  booktitle={2023 IEEE International Conference on Software Testing, Verification and Validation Workshops (ICSTW)}, 
  title={Challenging Autonomy with Combinatorial Testing}, 
  year={2023},
  volume={},
  number={},
  pages={214-222},
  abstract={This paper describes an input space modelling and test generation method called CACTus (Challenging Autonomy with Combinatorial Testing) that creates a suite of ‘challenge scenarios’ for autonomous systems. Though the parameter space for autonomous systems is vast, CACTus helps to reduce the parameter space using combinatorial testing and by incorporating expert judgement into the formulation of the scenarios. The resulting scenarios can be executed on appropriate test infrastructure, such as simulators or hardware-in-loop testing. CACTus may be used by practitioners to exercise systems as part of efforts to obtain compliance with standards like ISO 21448 or UL 4600. The method is applied to generate test scenarios for the perception system of a commercial autonomous vehicle.},
  keywords={Combinatorial testing;ISO Standards;Conferences;Test pattern generators;Standards;Autonomous vehicles;combinatorial testing;input modeling;autonomous systems;autonomous vehicles},
  doi={10.1109/ICSTW58534.2023.00046},
  ISSN={2159-4848},
  month={April},}@INPROCEEDINGS{10711327,
  author={Maoudj, Abderraouf and Mekid, Samir Nadir and Lyhne Christensen, Anders},
  booktitle={2024 IEEE 20th International Conference on Automation Science and Engineering (CASE)}, 
  title={Lifelong MAPF for Shipment Preparation in Stochastic Warehouses}, 
  year={2024},
  volume={},
  number={},
  pages={1006-1011},
  abstract={The Multi-Agent Path Finding (MAPF) problem focuses on deriving collision-free paths for multiple agents in a shared environment. However, the traditional formulation of the MAPF problem does not incorporate critical aspects and requirements of shipment preparation tasks, which are essential for efficiency in modern warehouse operations. In this context, we introduce a specialized version of the MAPF problem, termed Lifelong Multi-Agent Path Finding for Shipment Preparation (lifelong MAPF-SP). Unlike the traditional MAPF paradigm, the lifelong MAPF-SP formulation includes unique features tailored to shipment preparation: (i) each robot must perform several pickup and delivery tasks until the shipment is ready, (ii) both pickup actions and delivery actions have unknown stochastic durations, and (iii) all deliveries must be made to a designated shipment loading area. The lifelong MAPF-SP problem involves first deciding which robot is assigned what task (i.e., task assignment) followed by a subsequent coordination problem requiring robots to complete their tasks without colliding with one another (i.e., MAPF). Both task assignment and MAPF are NP-hard, rendering lifelong MAPF-SP a challenging problem. In this work, we present the problem, a benchmark dataset, and a zone-based task assignment algorithm that minimizes traffic congestion. We show that a combination of our zone-based task assignment algorithm and a completely decentralized multi-agent path finding algorithm can effectively solve a range of lifelong MAPF-SP scenarios.},
  keywords={Computer aided software engineering;Automation;Robot kinematics;Loading;Machine learning;Benchmark testing;Rendering (computer graphics);Path planning;Mobile robots;Traffic congestion},
  doi={10.1109/CASE59546.2024.10711327},
  ISSN={2161-8089},
  month={Aug},}@INPROCEEDINGS{10698508,
  author={Khan, Imran and Khan, Fazlullah and Ali, Asad and Alshawi, Bandar and Alturki, Ryan and Wedyan, Mohammad},
  booktitle={2024 International Conference on Electrical, Computer and Energy Technologies (ICECET}, 
  title={A Secured and Optimized Clustering Approch in Vehicular Ad-hoc Network}, 
  year={2024},
  volume={},
  number={},
  pages={1-6},
  abstract={Vehicular ad hoc networks (VANETs) take vital role in intelligent transportation systems, but they face challenges due to dynamic network topology, impacting communication efficiency, especially with increasing active nodes. Security and privacy concerns are paramount, necessitating authentication to ensure only legitimate vehicles access the network. Secure vehicular clustering offers a solution, yet the number of clusters affects network dependability and efficiency. To tackle this, we present a secure clustering mechanism using Bat optimization algorithm, mimicking echolocation behavior to optimize clusters. We introduce an authentication technique for cluster heads to admit approved members, enhancing vehicular authentication. Simulations using MATLAB evaluate our approach, showing improved performance in end-to-end delay, overhead, and cluster head count compared to similar methods.},
  keywords={Privacy;Network topology;Authentication;Vehicular ad hoc networks;Security;Vehicle dynamics;Optimization;Intelligent transportation systems;Faces;Matlab;VANET;Security Authentication;Optimization;Abnormal Behavior},
  doi={10.1109/ICECET61485.2024.10698508},
  ISSN={},
  month={July},}@INPROCEEDINGS{10312970,
  author={Ruban, Igor and Khudov, Hennadii and Makoveichuk, Oleksandr and Khizhnyak, Irina and Khudov, Vladyslav and Shamrai, Nazar},
  booktitle={2023 IEEE 4th KhPI Week on Advanced Technology (KhPIWeek)}, 
  title={The Two Stage Method for Detecting Objects of Interest on Optical Satellite RGB Imagery of the Urban Infrastructure}, 
  year={2023},
  volume={},
  number={},
  pages={1-4},
  abstract={It is proposed to develop the two stages method for detecting objects of interest on optical satellite RGB imagery of the urban infrastructure. The paper analyzes approaches to the detection of urban infrastructure objects on remote sensing imagery of the earth. It presents their advantages and disadvantages. It is proposed to use one of the methods of swarm intelligence, namely, the ant colony optimization algorithm at the first stage. At the second stage, the Hough transform is used to extract straight lines from the total number of detectted edges at the first stage. It is presented the results of segmentation of optical satellite RGB image of the urban infrastructure by the proposed method after each of the stages. The evaluation of the quality of the results of the method was only visual.},
  keywords={Visualization;Image segmentation;Satellites;Image edge detection;Transforms;Optical imaging;Optical sensors;optical satellite RGB imagery;imagery of the urban infrastructure;detecting;the object of interest;edge detection;ant colony optimization algorithm;Hough transform},
  doi={10.1109/KhPIWeek61412.2023.10312970},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{10033246,
  author={Nyandongo, Kwete Mwana and Madumo, Mmammule Grace},
  booktitle={2022 IEEE 28th International Conference on Engineering, Technology and Innovation (ICE/ITMC) & 31st International Association For Management of Technology (IAMOT) Joint Conference}, 
  title={The adoption of the Scaled Agile Framework (SAFe) in non-agile organizations}, 
  year={2022},
  volume={},
  number={},
  pages={1-8},
  abstract={The high project failure rate has been recognized as one of the challenges within the project management space and agile methodologies have been proposed to solve this challenge. In the last several years, many organizations have been using traditional project management methodologies, but they are now in the process of choosing an appropriate agile methodology as a substitute for the control-oriented, rigid, and inflexible traditional methodologies. Some are thinking about the move. The Scaled Agile Framework (SAFe) is an agile approach that brings into line collaboration between various teams in agile software development. It is not clear how non-agile organizations can implement the SAFe to derive organizational benefit and achieve transformation. The purpose of this study is to develop best practices to help in guiding agile adoption in non-agile organizations and determine the benefits, and challenges inherent to organizations implementing SAFe. The study outlines a 10-step implementation roadmap to be followed by non-agile organizations and identifies additional benefits experienced by the project team which includes defect reduction, skills sharing, and improved quality and productivity. The top three steps include (1) Train Lean-agile change agents, (2) Train executive manager leaders, and (3) Identifying value streams & ARTs.},
  keywords={Productivity;Art;Subspace constraints;Memory management;Project management;Process control;Collaboration;Agile methodologies;SAFe framework;Agile Release Train (ART)},
  doi={10.1109/ICE/ITMC-IAMOT55089.2022.10033246},
  ISSN={},
  month={June},}
