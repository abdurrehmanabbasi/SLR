@article{ WOS:001611114300001,
Author = {Liu, Xianhui and Liu, Yueying and Zhuang, Yiheng and Hou, Wenlong},
Title = {UCD-LLM: A use case diagram requirement modeling multi-agent framework
   with large language model},
Journal = {INFORMATION AND SOFTWARE TECHNOLOGY},
Year = {2026},
Volume = {190},
Month = {FEB},
Abstract = {Context: Requirement modeling is a critical step in software
   development, especially in industrial manufacturing, where system
   failures often result from ambiguous or incomplete requirements.
   Traditional approaches struggle to accurately capture essential
   information from natural language descriptions, particularly complex
   relationships in use case diagrams beyond actors and use cases.
   Objectives: This study aims to leverage Large Language Models (LLMs) to
   automatically extract complex use case diagram elements from natural
   language text, addressing the limitations of conventional requirement
   modeling and improving its accuracy and efficiency. Methods: UCD-LLM
   employs LLMs guided by carefully designed prompts to extract use case
   diagram elements. It incorporates a self-reflection mechanism to
   mitigate hallucinations and introduces a multi-agent debate mechanism to
   emulate requirement modeler discussions, thereby enhancing the
   recognition of complex relationships among functional entities. Results:
   UCD-LLM is evaluated on the extraction of actors, use cases, and various
   relationships. Compared with a traditional machine-learning method and
   three zero-shot LLM baselines, it achieves superior results on most
   metrics. In five classic modeling cases, UCD-LLM improves FEF by
   148\%-167\% over the traditional method. On the ReqUCD60 dataset,
   UCD-LLMQwe attains an RNF of 0.693, 16.2\% higher than the basic model
   Qwen. Ablation studies confirm that self-reflection and debate
   mechanisms substantially enhance model accuracy and robustness.
   Conclusion: UCD-LLM effectively captures use case diagram elements and
   their relationships from natural language texts. Built on pre-trained
   LLMs, it requires no complex architectures or large-scale training. Its
   strong performance and ease of deployment demonstrate a practical and
   scalable approach to applying LLMs in requirement modeling. The code is
   available at https://github.com/UCD-LLM/UCD-LLM.},
