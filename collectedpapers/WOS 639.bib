@inproceedings{ WOS:001324524206041,
Author = {Ding, Hao and Fan, Ziwei and Guehring, Ingo and Gupta, Gaurav and Ha,
   Wooseok and Huan, Jun and Liu, Linbo and Omidvar-Tehrani, Behrooz and
   Wang, Shiqi and Zhou, Hao},
