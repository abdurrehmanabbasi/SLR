Language = {English},
Affiliation = {Qiu, YJ (Corresponding Author), San Jose State Univ, Dept Mech Engn, San Jose, CA 95112 USA.
   Ji, Hao, Univ Southern Calif, Ctr Adv Res Comp, Los Angeles, CA 90007 USA.
   Aditya, Kotha; Escalante, Sebastian, Univ Southern Calif, Dept Comp Sci, Los Angeles, CA 90007 USA.
   Qiu, Yunjian, San Jose State Univ, Dept Mech Engn, San Jose, CA 95112 USA.},
DOI = {10.1109/ACCESS.2026.3654948},
ISSN = {2169-3536},
