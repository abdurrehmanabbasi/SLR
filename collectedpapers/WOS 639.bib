Pages = {671-675},
Note = {33rd International Symposium on Foundations of Software Engineering-FSE,
   Trondheim, NORWAY, JUN 23-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {This paper introduces UniTranslator, a framework, that uses multiple,
   compact LLMs working together for code translation. By orchestrating the
   interaction of specialized agents, each focused on different aspects of
   the translation process and grounded in a deep understanding of
   programming concepts, UniTranslator achieves a level of accuracy and
   efficiency that rivals larger, monolithic models. Our preliminary
   evaluation demonstrates the potential of UniTranslator to overcome the
   limitations of existing approaches and unlock the power of smaller LLMs
   for complex code translation tasks. We explore the effectiveness of this
   dynamic multi-agent paradigm in handling diverse language pairs,
   including low-resource languages, and in reducing common errors like
   code artifacts and hallucinations using Natural Language Inference (NLI)
   and iterative feedback..},
