@inproceedings{ WOS:001554359800061,
Author = {Pai, Kunal and Devanbu, Premkumar and Ahmed, Toufique},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {CoDocBench: A Dataset for Code-Documentation Alignment in Software
   Maintenance},
Booktitle = {2025 IEEE/ACM 22ND INTERNATIONAL CONFERENCE ON MINING SOFTWARE
   REPOSITORIES, MSR},
Series = {International Mining Software Repositories},
Year = {2025},
Pages = {451-455},
Note = {2025 International Conference on Mining Software
   Repositories-MSR-Annual, Ottawa, CANADA, APR 27-29, 2025},
Abstract = {One of the central tasks in software maintenance is being able to
   understand and develop code changes. Thus, given a natural language
   description of the desired new operation of a function, an agent (human
   or AI) might be asked to generate the set of edits to that function to
   implement the desired new operation; likewise, given a set of edits to a
   function, an agent might be asked to generate a changed description, of
   that function's new workings. Thus, there is an incentive to train a
   neural model for change-related tasks. Motivated by this, we offer a
   new, ``natural{''}, large dataset of coupled changes to code and
   documentation mined from actual high-quality GitHub projects, where each
   sample represents a single commit where the code and the associated
   docstring were changed together. We present the methodology for
   gathering the dataset, and some sample, challenging (but realistic)
   tasks where our dataset provides opportunities for both learning and
   evaluation. We find that current models (specifically Llama-3.1 405B,
   Mixtral 8x22B) do find these maintenance-related tasks challenging.},
