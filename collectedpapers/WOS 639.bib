@article{ WOS:001614865500024,
Author = {Medina-Barrera, Maria Guadalupe and Gibaja-Romero, Damian Emilio and
   Canton-Croda, Rosa Maria},
Title = {A Bayesian Equilibrium in the Game of Effort Estimation in Agile Global
   Software Development},
Journal = {INTERNATIONAL JOURNAL OF COMBINATORIAL OPTIMIZATION PROBLEMS AND
   INFORMATICS},
Year = {2025},
Volume = {16},
Number = {4},
Pages = {335-344},
Month = {SEP-DEC},
Abstract = {This research examines leader-team interactions in agile software
   development within a global context, with a focus on effort estimation.
   Drawing on principal-agent theory, we analyse the interaction on the
   assumption that the Scrum Master guides the development team under
   imperfect information. We model the interaction as a sequential game
   with incomplete information. Inthe first stage, the Scrum Master
   allocates resources to the development team; in the second stage, the
   team exerts effort. Both parties are characterised by types that capture
   their knowledge and skills. As these types are private information, we
   derive the Bayesian Nash equilibrium to determine the equilibrium effort
   levels.},
