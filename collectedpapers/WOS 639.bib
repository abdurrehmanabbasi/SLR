@inproceedings{ WOS:001585757900017,
Author = {Yu, Chen-Yeou and Su, Paige and Zhang, Wensheng},
Editor = {Arabnia, HR and Deligiannidis, L and Shenavarmasouleh, F and Amirian, S and Mohammadi, FG},
Title = {TruDevOps: Towards Pairing Agile Software Development Curriculum with
   AI-Agile DevOps},
Booktitle = {COMPUTATIONAL SCIENCE AND COMPUTATIONAL INTELLIGENCE, CSCI 2024, PT V},
Series = {Communications in Computer and Information Science},
