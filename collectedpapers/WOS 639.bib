@inproceedings{ WOS:001556376200002,
Author = {Parra, Esteban and Willingham, Sophia},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Towards Implementing and Evaluating AI-Assisted Pull Requests in
   Software Engineering Education},
Booktitle = {2025 IEEE/ACM 37TH INTERNATIONAL CONFERENCE ON SOFTWARE ENGINEERING
   EDUCATION AND TRAINING, CSEE\&T},
Series = {International Conference on Software Engineering-Software Engineering
   Education and Training},
Year = {2025},
