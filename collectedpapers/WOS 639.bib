Title = {Integration of Test Generation Into Simulation-Based Platforms: An
   Experience Report},
Booktitle = {3RD ACM/IEEE INTERNATIONAL CONFERENCE ON AUTOMATION OF SOFTWARE TEST
   (AST 2022)},
Year = {2022},
