@inproceedings{ WOS:001593214400197,
Author = {Li, Ziyou and Izadi, Maliheh},
Editor = {Li, J},
Title = {Enhancing Human-IDE Interaction in the SDLC using LLM-based Mediator
   Agents},
Booktitle = {COMPANION PROCEEDINGS OF THE 33RD ACM INTERNATIONAL CONFERENCE ON THE
   FOUNDATIONS OF SOFTWARE ENGINEERING, FSE COMPANION 2025},
Year = {2025},
Pages = {1363-1367},
Note = {33rd International Symposium on Foundations of Software Engineering-FSE,
   Trondheim, NORWAY, JUN 23-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {Large Language Model (LLM)-based autonomous agents provide
   state-of-the-art performance in various tasks throughout the Software
   Development Lifecycle (SDLC). Although these agents can be integrated
   into Integrated Development Environments (IDEs), standalone applications
   impose cognitive burdens on programmers due to fragmented tool usage
   across the SDLC. This paper proposes a framework for a mediator agent
   that serves as the unified interface between the programmer, IDE tools,
   agentic tools, and external multi-agent systems. The framework aims to
   simplify interaction, reduce context switching, and automate the
   orchestration of the IDE tools. By aligning with proposed levels of SE
   automation, the mediator agent sets the stage for next-generation
   human-computer collaboration, enhancing productivity, and advancing
   software engineering automation.},
