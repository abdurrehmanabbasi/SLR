Title = {An Industrial Experience Leveraging the iv4XR Framework for BDD Testing
   of a 3D Sandbox Game},
Booktitle = {RESEARCH CHALLENGES IN INFORMATION SCIENCE, PT I, RCIS 2024},
Series = {Lecture Notes in Business Information Processing},
Year = {2024},
