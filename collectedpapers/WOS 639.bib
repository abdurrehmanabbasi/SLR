Title = {GOBEAT: Towards a Methodology to Support MAS Test Case Definition},
Booktitle = {2023 LATIN AMERICAN ROBOTICS SYMPOSIUM, LARS, 2023 BRAZILIAN SYMPOSIUM
   ON ROBOTICS, SBR, AND 2023 WORKSHOP ON ROBOTICS IN EDUCATION, WRE},
