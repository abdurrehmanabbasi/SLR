@inproceedings{ WOS:001593214400160,
Author = {Ma, Minghua and Clark, Jackson and Zhang, Shenglin},
Editor = {Li, J},
Title = {AIOpsLab in Action: An Open Platform for AIOps Research},
Booktitle = {COMPANION PROCEEDINGS OF THE 33RD ACM INTERNATIONAL CONFERENCE ON THE
   FOUNDATIONS OF SOFTWARE ENGINEERING, FSE COMPANION 2025},
Year = {2025},
Pages = {1223-1227},
Note = {33rd International Symposium on Foundations of Software Engineering-FSE,
   Trondheim, NORWAY, JUN 23-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {The significant advances in AI have been driving a blooming landscape of
   research on developing AI agents for various kinds of cloud system
   operations, which is often referred to as AIOps. For example, AI-based
   fault detection, root cause analysis, and failure mitigation have been a
   hot topic in recent years with many research papers published at
   Software Engineering conferences like FSE, ICSE, ASE, and ISSTA.
   However, AIOps research today faces major practical challenges such as
   benchmarking, workload simulation, and reproducibility.
   This tutorial introduces AIOpsLab, an open platform and benchmark suites
   designed with the goal of significantly boosting the design,
   implementation, and evaluation of AI agents for cloud system operations.
   Specifically, AIOpsLab addresses following needs:
   Standard benchmark suites for evaluating AIOps techniques
   comprehensively and fairly;
   Ausable platform with push-button deployment to let researchers focus on
   the essence of AIOps research and development;
   An extensible framework that can be easily enriched and customized for
   different AIOps tasks and scenarios;
   Reproducibility of the research results and artifacts. Specifically, we
   will cover the following topics in the tutorial:
   The vision and objectives of AIOpsLab;
   The design and implementation of AIOpsLab;
   The use cases of AIOpsLab with a hands-on session;
   The benchmark suites in AIOpsLab and how to extend them;
   The design of a fault localization agent and the results obtained using
   AIOpsLab;
   A discussion on next steps and future endeavors of AIOpsLab. The source
   code, blog, and additional resources for AIOpsLab are available at
   https://aka.ms/aiopslab.},
