@inproceedings{ WOS:001273423600030,
Author = {Hassan, Ahmed E. and Lin, Dayi and Rajbahadur, Gopi Krishnan and
   Gallaba, Keheliya and Cogo, Filipe Roseiro and Chen, Boyuan and Zhang,
   Haoxiang and Thangarajah, Kishanthan and Oliva, Gustavo and Lin, Jiahuei
   (Justina) and Abdullah, Wali Mohammad and Jiang, Zhen Ming (Jack)},
Editor = {D'Amorim, M},
Title = {Rethinking Software Engineering in the Era of Foundation Models},
Booktitle = {COMPANION PROCEEDINGS OF THE 32ND ACM INTERNATIONAL CONFERENCE ON THE
   FOUNDATIONS OF SOFTWARE ENGINEERING, FSE COMPANION 2024},
Year = {2024},
Pages = {294-305},
Note = {32nd ACM International Conference on the Foundations of Software
   Engineering (FSE), Porto de Galinhas, BRAZIL, JUL 15-19, 2024},
Organization = {Assoc Comp Machinery; ACM SIGSOFT; Huawei; Technol Innovat Inst; Google;
   JetBrains; Uber},
Abstract = {Foundation models (FMs), such as Large Language Models (LLMs), have
   revolutionized software development by enabling new use cases and
   business models. We refer to software built using FMs as FMware. The
   unique properties of FMware (e.g., prompts, agents and the need for
   orchestration), coupled with the intrinsic limitations of FMs (e.g.,
   hallucination) lead to a completely new set of software engineering
   challenges. Based on our industrial experience, we identified ten key
   SE4FMware challenges that have caused enterprise FMware development to
   be unproductive, costly, and risky. For each of those challenges, we
   state the path for innovation that we envision. We hope that the
   disclosure of the challenges will not only raise awareness but also
   promote deeper and further discussions, knowledge sharing, and
   innovative solutions.},
