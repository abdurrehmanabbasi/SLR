@article{ WOS:001620365800001,
Author = {Jiang, Maowei and Wang, Qi and Ai, Hongfeng and Dong, Zhiyong and Hu,
   Yusong and Liang, Ao and Wang, Yifan and Li, Ruiqi and Li, Quangao and
   Chen, Moquan and Bus, Peter and Zeng, Long},
Title = {Prompt2Act: Mapping prompts into sequence of robotic actions with large
   foundation models},
Journal = {INFORMATION FUSION},
Year = {2026},
Volume = {127},
Number = {C},
Month = {MAR},
Abstract = {With the rapid advancement of large foundation models like
   Vision-Language Models (VLMs), AI is increasingly empowering robots to
   interpret and process complex multimodal inputs, including natural
   language and visual data. However, bridging the gap between
   understanding these inputs and executing intricate actions remains a
   significant challenge. To address this, we propose Prompt2Act, a
   framework that effectively maps multimodal prompts into a series of
   robotic actions using large foundation models. Prompt2Act leverages VLMs
   to perceive and reason about the robot's environment, combining visual
   and textual inputs to interpret user commands with flexibility. We
   introduce the VG-Marker algorithm, which utilizes open-vocabulary
   perception models (e.g., SAM) to enhance the visual grounding
   capabilities of VLMs, allowing for more precise identification and
   localization of visual elements within a scene. To further improve the
   flexibility and efficiency of task execution, we incorporate the Mixed
   Execution Agent (MEA), a VLM-based agent that combines predefined skills
   with dynamic code generation policy. Extensive experiments in both
   real-world and simulated environments demonstrate that Prompt2Act
   consistently outperforms existing methods in various open-world
   manipulation tasks, validating its effectiveness and reliability in
   handling complex scenarios. Our code and data are available on GitHub at
   https://github.com/Zero-coder/Prompt2Act.},
