@inproceedings{ WOS:001391776307009,
Author = {Trivedi, Harsh and Khot, Tushar and Hartmann, Mareike and Manku, Ruskin
   and Dong, Vinty and Li, Edward and Gupta, Shashank and Sabharwal, Ashish
   and Balasubramanian, Niranjan},
