@inproceedings{ WOS:000908031000053,
Author = {Voria, Gianmario and Pentangelo, Viviana and Della Porta, Antonio and
   Lambiase, Stefano and Catolino, Gemma and Palomba, Fabio and Ferrucci,
   Filomena},
Book-Group-Author = {IEEE Comp Soc},
Title = {Community Smell Detection and Refactoring in SLACK: The CADOCS Project},
Booktitle = {2022 IEEE INTERNATIONAL CONFERENCE ON SOFTWARE MAINTENANCE AND EVOLUTION
   (ICSME 2022)},
Series = {Proceedings-IEEE International Conference on Software Maintenance},
Year = {2022},
Pages = {469-473},
Note = {39th IEEE International Conference on Software Maintenance and Evolution
   (ICSME), Limassol, CYPRUS, OCT 02-07, 2022},
Organization = {IEEE; Univ Cyprus; IEEE Comp Soc; Cyprus Tourist Org; Lufthansa Grp},
Abstract = {Software engineering is a human-centered activity involving various
   stakeholders with different backgrounds that have to communicate and
   collaborate to reach shared objectives. The emergence of conflicts among
   stakeholders may lead to undesired effects on software maintainability,
   yet it is often unavoidable in the long run. Community smells, i.e.,
   sub-optimal communication and collaboration practices, have been defined
   to map recurrent conflicts among developers. While some community smell
   detection tools have been proposed in the recent past, these can be
   mainly used for research purposes because of their limited level of
   usability and user engagement. To facilitate a wider use of community
   smell-related information by practitioners, we present CADOCS, a
   client-server conversational agent that builds on top of a previous
   community smell detection tool proposed by Almarini et al. to (1) make
   it usable within a wellestablished communication channel like SLACK and
   (2) augment it by providing initial support to software analytics
   instruments useful to diagnose and refactor community smells. We
   describe the features of the tool and the preliminary evaluation
   conducted to assess and improve robustness and usability.
   Tool repository: https://github.com/gianwario/CADOCS Tool video:
   https://www.youtube.com/watch?v=a2hOoE1M8hk},
