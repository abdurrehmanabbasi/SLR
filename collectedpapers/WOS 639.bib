Note = {26th Conference on Towards Autonomous Robotic Systems-TAROS-Annual,
   York, ENGLAND, AUG 20-22, 2025},
Organization = {Brunel University London College of Engineering Design and Physical
   Sciences},
Abstract = {Code generation through Large Language Models (LLMs) has made
   significant progress in recent years. However, when the code generation
   involves a lesser-known Domain-Specific Language (DSL), a standard tool
   in software development for cyber-physical systems, LLMs' performance
   significantly decreases. We present an exploratory study assessing LLMs'
   performance in generating LIrAs (Language for Interactive Agents) code,
   a DSL for robotic and multi-agent tasks specification. This work is a
   stepping stone towards improving LLM-generated DSL code through
   iterative specification repair techniques driven by formal verification
   results.},
