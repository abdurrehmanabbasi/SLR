@inproceedings{ WOS:000972671800004,
Author = {Zhu, Chenyang and Cai, Yujie and Hu, Can and Bi, Jia},
Book-Group-Author = {IEEE},
Title = {Efficient Reinforcement Learning with Generalized-Reactivity
   Specifications},
Booktitle = {2022 29TH ASIA-PACIFIC SOFTWARE ENGINEERING CONFERENCE, APSEC},
