Title = {Backup of Cloud Data to On-Premises Locations},
Booktitle = {2025 24TH INTERNATIONAL SYMPOSIUM INFOTEH-JAHORINA, INFOTEH},
Series = {International Symposium on INFOTEH-JAHORINA},
Year = {2025},
Note = {24th International Symposium INFOTEH JAHORINA-INFOTEH-Annual, BOSNIA \&
   HERCEG, MAR 19-21, 2025},
Organization = {University of East Sarajevo Faculty of Electrical Engineering; Institute
   of Electrical and Electronics Engineers Industry Applications Society;
   IEEE Bosnia and Herzegovina Section; IEEE Serbia and Montenegro Section;
   Univerziteta u Beogradu Fakultet Elektrotehnicki; Univerzitet u Novom
   Sadu Fakultet tehnickih nauka; Univerzitet u Kragujevcu Fakultet
   tehnickih nauka u Cacku; Sveuciliste u Splitu Fakultet elektrotehnike
   strojarstva i brodogradnje; Ss Cyril and Methodius University in Skopje
   (UKiM); Alumni Association of Electrical Engineers of East Sarajevo},
Abstract = {The paper focuses on maintaining backup copies of data transferred from
   a cloud platform to an on-premises location. When transferring data to
   an on-premises location to increase the security of system continuity,
   an additional backup copy of the data was made. Data security follows
   the legal and regulatory frameworks and prescribed standards, these
   standards are presented in the paper for both the European Union and the
   USA. The importance of the 3-2-1 backup rule is presented, as well as
   the advantages and disadvantages of this rule. The functionality of
   cloud platforms such as Azure, AWS and Google Cloud for data protection
   and methods for transferring backup copies using backup agents are
   presented, the paper describes an example in which Veeam Backup Agent is
   used. The advantages and disadvantages of backup storage tools such as
   Veeam, Acronis, Commvault, etc. are presented. The paper offers
   practical suggestions for implementing secure and efficient strategies
   in an IT environment.},
