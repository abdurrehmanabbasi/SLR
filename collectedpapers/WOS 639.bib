@inproceedings{ WOS:001316097300008,
Author = {Monti, Flavia and Leotta, Francesco and Mangler, Juergen and Mecella,
   Massimo and Rinderle-Ma, Stefanie},
Editor = {Marrella, A and Resinas, M and Jans, M and Rosemann, M},
Title = {NL2ProcessOps: Towards LLM-Guided Code Generation for Process Execution},
Booktitle = {BUSINESS PROCESS MANAGEMENT FORUM, BPM 2024},
Series = {Lecture Notes in Business Information Processing},
Year = {2024},
Volume = {526},
Pages = {127-143},
