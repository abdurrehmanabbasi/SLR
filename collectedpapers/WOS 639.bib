Editor = {Marrella, A and Matulevicius, R and Gabryelczyk, R and Axmann, B and Vuksic, VB and Gaaloul, W and Stemberger, MI and Ko, A and Lu, Q},
Title = {A Systematic Local Fork Management Framework for Blockchain Sandbox
   Environments},
Booktitle = {BUSINESS PROCESS MANAGEMENT: BLOCKCHAIN, ROBOTIC PROCESS AUTOMATION, AND
   CENTRAL AND EASTERN EUROPE FORUM},
Series = {Lecture Notes in Business Information Processing},
Year = {2022},
Volume = {459},
Pages = {36-50},
Note = {20th International Conference on Business Process Management (BPM) /
   Business Process Management (BPM) Forum, Munster, GERMANY, SEP 11-16,
   2022},
Organization = {Celonis; SAP Signavio; MR KNOW; Cronos; Provinzial; Viadee; German Res
   Fdn; Springer; Univ Munster; European Res Ctr Informat Syst},
Abstract = {Blockchain technology presently permeates multiple industries, resulting
   in an increasing number of agents (primarily end-users and engineers)
   interacting with it in a variety of contexts. This, in turn, has
   introduced the practical need for a sufficient tooling ecosystem for
   blockchain solutions testing and evaluation under secure environment
   conditions. To that end, this study presents a robust framework for the
   creation and management of customisable, persistent, private, scalable
   blockchain environments that fulfill precisely the need for live sandbox
   platforms with on-chain interaction capabilities. We extend the concept
   of local chain forking, emphasising the limitations of existing tooling
   and methodologies and propose how our framework mitigates identified
   weaknesses and bridges some of the resulting gaps in desirable
   non-functional attributes. We offer a reference implementation for our
   framework and discuss how it can be applicable to a broad array of
   DevOps and securityoriented Use Cases. Finally, emerging challenges are
   discussed and potential directions for further research are drawn.},
