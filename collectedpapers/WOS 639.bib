   organizations},
Booktitle = {2022 IEEE 28TH INTERNATIONAL CONFERENCE ON ENGINEERING, TECHNOLOGY AND
   INNOVATION (ICE/ITMC) \& 31ST INTERNATIONAL ASSOCIATION FOR MANAGEMENT
   OF TECHNOLOGY, IAMOT JOINT CONFERENCE},
Series = {International ICE Conference on Engineering Technology and Innovation},
