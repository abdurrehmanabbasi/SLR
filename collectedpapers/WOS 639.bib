@inproceedings{ WOS:001553878700015,
Author = {Zanfardino, Gennaro and Di Marco, Antinisca and Tucci, Michele},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Designing a Tool for Evacuation Plan Validation: Multi-Agent Simulations
   with Persona-Based UI},
Booktitle = {2025 IEEE/ACM 47TH INTERNATIONAL CONFERENCE ON SOFTWARE ENGINEERING:
   SOFTWARE ENGINEERING IN SOCIETY, ICSE-SEIS},
