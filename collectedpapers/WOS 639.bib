Title = {Unveiling the Potential of a Conversational Agent in Developer Support:
   Insights from Mozilla's PDF.js Project},
Booktitle = {PROCEEDINGS OF THE 1ST ACM INTERNATIONAL CONFERENCE ON AI-POWERED
