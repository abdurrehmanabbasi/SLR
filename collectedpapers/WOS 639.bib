@inproceedings{ WOS:001249454300041,
Author = {Bisante, Alba and Datla, Venkata Srikanth Varma and Panizzi, Emanuele
   and Trasciatti, Gabriella and Zeppieri, Stefano},
Book-Group-Author = {Assoc Computing Machinery},
Title = {Enhancing Interface Design with AI: An Exploratory Study on a
   ChatGPT-4-Based Tool for Cognitive Walkthrough Inspired Evaluations},
Booktitle = {PROCEEDINGS OF THE INTERNATIONAL CONFERENCE ON ADVANCED VISUAL
   INTERFACES, AVI 2024},
Year = {2024},
Note = {17th International Conference on Advanced Visual Interfaces (AVI),
   Arenzano, ITALY, JUN 03-07, 2024},
Organization = {Univ Genoa; Assoc Comp Machinery; ACM Special Interest Grp Comp Human
   Interact; ACM Special Interest Grp Multimedia; ACM Special Interest Grp
   Hypertext \& Web; ACM In Cooperat; SIGCHI},
Abstract = {This paper introduces CWGPT, a ChatGPT-4-based tool designed for
   Cognitive Walkthrough (CW) inspired evaluations of web interfaces. The
   primary goal is to assist users, particularly students and inexperienced
   designers, in evaluating web interfaces. Our tool, operating as a
   conversational agent, provides detailed evaluations of a user-specified
   task by intelligently guessing the subtasks and actions required to
   accomplish them, answering the standard CW questions, and providing
   helpful feedback and practical suggestions to improve the usability of
   the analyzed interface. For our study, we selected a group of web
   applications designed by students from a Web and Software Architecture
   course. We compare the outcome of the CWs we executed on ten web apps
   against the corresponding CWGPT analyses. We then describe the study we
   conducted involving five author-students to assess the tool's efficacy
   in helping them recognize and solve usability issues. In addition to
   introducing a novel adaptation of ChatGPT, the outcomes of the described
   experience underscore the promising potential of AI in usability
   evaluations.},
