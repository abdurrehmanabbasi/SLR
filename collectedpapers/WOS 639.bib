Editor = {Bianculli, D and Sartaj, H and Andrikopoulos, V and Pautasso, C and Mikkonen, T and Perez, J and Bures, T and DeSanctis, M and Muccini, H and Navarro, E and Soliman, M and Zdun, U},
Title = {AI-Powered Architecting for Industry 4.0 Cyber-Physical Production
   Systems: A Novel Approach, Research Problems and Challenges},
