Year = {2025},
Pages = {469-477},
Note = {6th WORLD AI IoT Congress-AIIoT-Annual, Seattle, WA, MAY 28-30, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The emergence of Large Language Models (LLMs) has reshaped agent
   systems. Unlike traditional rule-based agents with limited task scope,
   LLM-powered agents offer greater flexibility, cross-domain reasoning,
   and natural language interaction. Moreover, with the integration of
   multi-modal LLMs, current agent systems are highly capable of processing
   diverse data modalities, including text, images, audio, and structured
   tabular data, enabling richer and more adaptive real-world behavior.
   This paper comprehensively examines the evolution of agent systems from
   the pre-LLM era to current LLM-powered architectures. We categorize
   agent systems into software-based, physical, and adaptive hybrid
   systems, highlighting applications across customer service, software
   development, manufacturing automation, personalized education, financial
   trading, and healthcare. We further discuss the primary challenges posed
   by LLM-powered agents, including high inference latency, output
   uncertainty, lack of evaluation metrics, and security vulnerabilities,
   and propose potential solutions to mitigate these concerns.},
