@inproceedings{ WOS:001532176400017,
Author = {Dabrowski, Jacek and Bennaceur, Amel and Rajbahadur, Gopi Krishnan and
   Nuseibeh, Bashar and Alrimawi, Faeq},
Editor = {Hess, A and Susi, A},
Title = {Prompt Me: Intelligent Software Agent for Requirements Engineering - A
   Vision Paper},
Booktitle = {REQUIREMENTS ENGINEERING: FOUNDATION FOR SOFTWARE QUALITY, REFSQ 2025},
