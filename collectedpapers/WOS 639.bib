@inproceedings{ WOS:001674181700004,
Author = {Kwok, Ya Ting Crystal and Adil, Mahum},
Editor = {Peter, S and Kropp, M and Dingsoyr, T and Dillon, C and Diebold, P and Jain, D and Lunesu, ML and Pinna, A},
Title = {AI and Teamwork in Agile Software Development: A Systematic Mapping
   Study},
Booktitle = {AGILE PROCESSES IN SOFTWARE ENGINEERING AND EXTREME
   PROGRAMMING-WORKSHOPS, XP 2025},
Series = {Lecture Notes in Business Information Processing},
