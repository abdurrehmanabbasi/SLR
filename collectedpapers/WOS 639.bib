Organization = {Consejo Nacional de Humanidades Ciencias y Tecnologias},
Abstract = {This paper explores the integration of Multi-Agent Systems (MAS) and
   Large Language Models (LLMs) for automatic code generation, addressing
   the limitations of traditional manual coding. By conducting a
   comprehensive review of existing literature and analyzing a practical
   case study, we demonstrate how MAS and LLMs can collaboratively enhance
   software development processes. The research focuses on the technical
   and theoretical challenges of this integration, highlighting the
   potential for improved productivity, adaptability, and quality in code
   generation. The findings contribute to AI-based software engineering by
   revealing new research directions in collective intelligence and
   automated programming.},
