   Bamidele and Abiodun, Moses Kazeem and Awokola, Jinmisayo and Lawrence,
   Morolake Oladayo},
Editor = {Gervasi, O and Murgante, B and Misra, S and Rocha, AMAC and Garau, C},
Title = {Augmented Intelligence Multilingual Conversational Service for Smart
   Enterprise Management Software},
