@inproceedings{ WOS:001315628100123,
Author = {Sgambelluri, Andrea and Castoldi, Piero and Cugini, Filippo},
Editor = {Prudenzano, F and Marciniak, M},
Title = {Open Optical Software Development Kit (OpenOSDK) for Optical Line System
   Components<bold> </bold>},
Booktitle = {2024 24TH INTERNATIONAL CONFERENCE ON TRANSPARENT OPTICAL NETWORKS,
   ICTON 2024},
Series = {International Conference on Transparent Optical Networks-ICTON},
Year = {2024},
Note = {24th International Conference on Transparent Optical Networks (ICTON),
   Bari, ITALY, JUL 14-18, 2024},
Organization = {IEEE; IEEE Photon Soc; Natl Inst Telecommunicat; Dept Transmiss \& Opt
   Technologies; Dipartimento Ingn Elettrica \& Informazione Politecnico
   Bari},
Abstract = {In the last years, different working groups have tried to define
   comprehensive and standard YANG data models, representing the devices
   architecture. However, not a concrete adoption of those models has
   happened, with clear open issues on the way. In fact, many initiatives
   (i.e., OpenROADM, OpenConfig and IETF) have been working to define their
   own data models, without any cooperation resulting in a differentiation
   on the model to follow by the different vendors. In addition, each
   vendor has performed an interpretation of the considered models,
   preparing a customized version. In example, considering the
   disaggregated optical line systems (OLS), this has led to
   interoperability issues, breaking the origin idea of fully vendor
   agnostic management and control.
   In this work the concept of Open Optical Software Development Kit
   (OOSDK) is proposed for the control of the OLS components, relying on
   standard and well known South Bound Interfaces to enforce a real
   vendorneutral control of hardware. In particular, no specific models are
   adopted in the communication among SDN Controller and devices, while,
   relying on the soft virtualization techniques (i.e., containers) a
   vendor specific SDN agent is adopted to control the data-plane device. A
   PoC has been adopted to perform the experimental validation encompassing
   a heterogeneous ROADM architecture including a Lumentum degree, WSSs and
   EDFA amplifiers.<bold> </bold>},
Publisher = {IEEE},
