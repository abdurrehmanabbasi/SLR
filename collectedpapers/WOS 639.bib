@inproceedings{ WOS:001296006200024,
Author = {Cordova, Paulo Roberto and de Souza Filho, Iderli Pereira and Araujo
   Guedes, Gilleanes Thorwald and Vicari, Rosa Maria},
Editor = {Frasson, C and Mylonas, P and Troussas, C},
Title = {ETHOSCHOOL: An Artificial Moral Agent Model for Collaborative Learning},
Booktitle = {AUGMENTED INTELLIGENCE AND INTELLIGENT TUTORING SYSTEMS, ITS 2023},
Series = {Lecture Notes in Computer Science},
Year = {2023},
Volume = {13891},
Pages = {281-289},
Note = {19th International Conference on Augmented Intelligence and Intelligent
   Tutoring Systems (ITS), Corfu, GREECE, JUN 02-05, 2023},
Abstract = {The growing popularization of Artificial Intelligence (AI) technologies
   to support most different human activities, including education, has
   been a subject of research and concern among researchers in the area. In
   this sense, how to translate ethical principles into computational
   models; how to avoid biases; how to make intelligent systems
   accountable; and how to make them more predictable and able to explain
   their actions are among the main issues raised. Such questions also
   extend to the Education area, where it is necessary to address this
   matter with the same seriousness. Despite this, few proposals in ethics
   by design have been observed for the Education area. To help fill this
   gap, this work presents a proposal for an Artificial Moral Agent (AMA)
   to aid in collaborative learning. The proposed AMA implements a hybrid
   approach between deontological and utilitarian ethical frameworks, using
   the Belief, Desire, and Intention (BDI) architecture. For this, through
   Agent-Oriented Software Engineering (AOSE) techniques, which is the
   focus of this paper, the functional requirements of the proposed AMA
   will be described, as well as its structural model.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
