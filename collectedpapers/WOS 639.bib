DOI = {10.1109/ICLAD65226.2025.00033},
ISBN = {979-8-3315-2598-9; 979-8-3315-2597-2},
Keywords = {LLM-Aided Hardware Design; ASIC Design Automation; Agent Systems;
   Benchmarking LLM Agents},
Research-Areas = {Computer Science; Engineering},
Web-of-Science-Categories  = {Computer Science, Artificial Intelligence; Computer Science, Hardware \&
   Architecture; Computer Science, Software Engineering; Engineering,
