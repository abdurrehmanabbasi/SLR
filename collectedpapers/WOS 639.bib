@inproceedings{ WOS:001573680300031,
Author = {Takerngsaksiri, Wannita and Pasuksmit, Jirat and Thongtanunam, Patanamon
   and Tantithamthavorn, Chakkrit and Zhang, Ruixiong and Jiang, Fan and
   Li, Jing and Cook, Evan and Chen, Kun and Wu, Ming},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Human-In-the-Loop Software Development Agents},
Booktitle = {2025 IEEE/ACM 47TH INTERNATIONAL CONFERENCE ON SOFTWARE ENGINEERING:
   SOFTWARE ENGINEERING IN PRACTICE, ICSE-SEIP},
Series = {International Conference on Software Engineering-Software Engineering in
   Practice Track},
Year = {2025},
Pages = {342-352},
Note = {47th ACM/IEEE International Conference on Software Engineering and
   Software Engineering in Practice-ICSE-SEIP, Ottawa, CANADA, APR 27-MAY
   03, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Association for
   Computing Machinery},
Abstract = {Recently, Large Language Models (LLMs)-based multi-agent paradigms for
   software engineering are introduced to automatically resolve software
   development tasks (e.g., from a given issue to source code). However,
   existing work is evaluated based on historical benchmark datasets,
   rarely considers human feedback at each stage of the automated software
   development process, and has not been deployed in practice. In this
   paper, we introduce a Human-in-the-loop LLM-based Agents framework
   (HULA) for software development that allows software engineers to refine
   and guide LLMs when generating coding plans and source code for a given
   task. We design, implement, and deploy the HULA framework into Atlassian
   JIRA for internal uses. Through a multi-stage evaluation of the HULA
   framework, Atlassian software engineers perceive that HULA can minimize
   the overall development time and effort, especially in initiating a
   coding plan and writing code for straightforward tasks. On the other
   hand, challenges around code quality remain a concern in some cases. We
   draw lessons learned and discuss opportunities for future work, which
   will pave the way for the advancement of LLM-based agents in software
   development.},
