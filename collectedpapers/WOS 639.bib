@inproceedings{ WOS:001483187700002,
Author = {Mani, Nariman and Attaranasl, Salma},
Editor = {Fasolino, AR and Panichella, S and Aleti, A and Mesbah, A},
Title = {Adaptive Test Healing using LLM/GPT and Reinforcement Learning},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON SOFTWARE TESTING, VERIFICATION AND
   VALIDATION WORKSHOPS, ICSTW},
Series = {IEEE International Conference on Software Testing Verification and
   Validation Workshops},
Year = {2025},
Pages = {9-16},
Note = {2025 International Conference on Software Testing, Verification and
   Validation Workshops-ICSTW, Naples, ITALY, MAR 31-APR 04, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Hitachi Limited;
   Google Research; Micron Pharmaceuticals},
Abstract = {Flaky tests disrupt software development pipelines by producing
   inconsistent results, undermining reliability and efficiency. This paper
   introduces a hybrid framework for adaptive test healing, combining Large
   Language Models (LLMs) like GPT with Reinforcement Learning (RL) to
   address test flakiness dynamically. LLMs analyze test logs to classify
   failures and extract contextual insights, while the RL agent learns
   optimal strategies for test retries, parameter tuning, and environment
   resets. Experimental results demonstrate the framework's effectiveness
   in reducing flakiness and improving CI/CD pipeline stability,
   outperforming traditional approaches. This work paves the way for
   scalable, intelligent test automation in dynamic development
   environments.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Mani, N (Corresponding Author), Nutrosal Inc, Engn R\&D Dept, Ottawa, ON, Canada.
   Mani, Nariman; Attaranasl, Salma, Nutrosal Inc, Engn R\&D Dept, Ottawa, ON, Canada.},
