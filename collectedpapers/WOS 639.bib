Note = {38th International Conference on Legal Knowledge and Information
   Systems-JURIX, University of Turin, ITALY, DEC 09-11, 2025},
Organization = {Masaryk University},
Abstract = {Accountability is a central notion in both political science and
   software engineering, where it underpins trust, transparency, and
   responsibility in complex systems. Multi-agent systems (MAS) provide
   fertile ground for investigating accountability as a first-class
   computational construct. While earlier approaches in MAS research
   relegated accountability to an implicit property, recent extensions
   model it explicitly. This paper explores accountability in the
   well-known multi-agent JaCaMo framework as an organizational, normative,
   and structural mechanism. We argue that formalizing accountability in
   MAS provides a robust foundation for legal reasoning, compliance
   verification, and transparent governance of complex distributed systems,
   ensuring traceable responsibilities and structured feedback flows. We
   introduce its conceptual foundations, the JaCaMo implementation, and its
   implications for legal knowledge systems, showing how accountability
   provides a formal bridge between normative theories and executable
   systems.},
