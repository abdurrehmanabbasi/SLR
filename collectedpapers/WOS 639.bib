@inproceedings{ WOS:001413201600075,
Author = {Karaduman, Burak and Tezel, Baris Tekin and Kardas, Geylani and
   Challenger, Moharram},
Editor = {Bolanowski, M and Ganzha, M and Maciaszek, L and Paprzycki, M and Slezak, D},
Title = {DSML4JaCaMo: A Modelling tool for Multi-agent Programming with JaCaMo},
Booktitle = {2024 19TH CONFERENCE ON COMPUTER SCIENCE AND INTELLIGENCE SYSTEMS,
   FEDCSIS 2024},
