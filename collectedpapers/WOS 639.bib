@inproceedings{ WOS:001593214400068,
Author = {Nguyen, Duc S. H. and Truong, Bach G. and Nguyen, Phuong T. and Di
   Rocco, Juri and Di Ruscio, Davide},
Editor = {Li, J},
Title = {Teamwork makes the dream work: LLMs-Based Agents for GitHub README.MD
   Summarization},
Booktitle = {COMPANION PROCEEDINGS OF THE 33RD ACM INTERNATIONAL CONFERENCE ON THE
   FOUNDATIONS OF SOFTWARE ENGINEERING, FSE COMPANION 2025},
Year = {2025},
Pages = {621-625},
Note = {33rd International Symposium on Foundations of Software Engineering-FSE,
   Trondheim, NORWAY, JUN 23-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {The proliferation of Large Language Models (LLMs) in recent years has
   realized many applications in various domains. Being trained with a huge
   of amount of data coming from various sources, LLMs can be deployed to
   solve different tasks, including those in Software Engineering (SE).
   Though they have been widely adopted, the potential of using LLMs
   cooperatively has not been thoroughly investigated. In this paper, we
   proposed Metagente as a novel approach to amplify the synergy of various
   LLMs. Metagente is a Multi-Agent framework based on a series of LLMs to
   self-optimize the system through evaluation, feedback, and cooperation
   among specialized agents. Such a framework creates an environment where
   multiple agents iteratively refine and optimize prompts from various
   perspectives. The results of these explorations are then reviewed and
   aggregated by a teacher agent. To study its performance, we evaluated
   Metagente with an SE task, i.e., summarization of README.MD files, and
   compared it with three well-established baselines, i.e., GitSum,
   LLaMA-2, and GPT-4o. The results show that our proposed approach works
   efficiently and effectively, consuming a small amount of data for
   fine-tuning but still getting a high accuracy, thus substantially
   outperforming the baselines. The performance gain compared to GitSum,
   the most relevant benchmark, ranges from 27.63\% to 60.43\%. More
   importantly, compared to using only one LLM, Metagente boots up the
   accuracy to multiple folds.},
