Title = {Architecture of Multi-agent System for Automatic Code Template
   Maintenance},
Booktitle = {NEW TRENDS IN DATABASE AND INFORMATION SYSTEMS, ADBIS 2025},
Series = {Communications in Computer and Information Science},
Year = {2026},
