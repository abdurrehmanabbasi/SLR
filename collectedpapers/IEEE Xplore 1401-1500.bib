  booktitle={2023 IEEE Conference on Games (CoG)}, 
  title={Believable Minecraft Settlements by Means of Decentralised Iterative Planning}, 
  year={2023},
  volume={},
  number={},
  pages={1-8},
  abstract={Procedural city generation that focuses on believability and adaptability to random terrain is a difficult challenge in the field of Procedural Content Generation (PCG). Dozens of researchers compete for a realistic approach in challenges such as the Generative Settlement Design in Minecraft (GDMC), in which our method has won the 2022 competition. This was achieved through a decentralised, iterative planning process that is transferable to similar generation processes that aims to produce "organic" content procedurally.},
  keywords={Urban areas;Buildings;Games;Software;Planning;Iterative methods;Creativity;Procedural Content Generation;Settlement Generation;Agent-based;Minecraft},
  doi={10.1109/CoG57401.2023.10333146},
  ISSN={2325-4289},
  month={Aug},}@ARTICLE{11203882,
  author={Tang, Xiao and Zhao, Kexin and Shen, Chao and Lin, Chenhao and Liu, Shuai and Wang, Bohui and Niyato, Dusit and Han, Zhu},
  journal={IEEE Transactions on Wireless Communications}, 
  title={Graph Attention Network-Driven Hierarchical Learning for Anti-Jamming UAV Communications}, 
  year={2026},
  volume={25},
  number={},
  pages={5432-5445},
  abstract={Jamming attacks pose a significant threat to the security of air-ground communications, where the challenge becomes more severe when involving multiple unmanned aerial vehicles (UAVs) incurring complex interference. To address this issue, this paper proposes a graph attention-based reinforcement learning strategy for anti-jamming UAV communications. Specifically, we consider the multi-UAV transmission and deployment in the presence of jamming attacks. Then, we formulate a zero-sum game with the legitimate side and adversary to maximize and minimize the overall transmission rate, respectively. Given the complicated structure of the game, we decompose it into two layers, tackled in a hierarchical learning framework. Particularly, the inner layer addresses the legitimate beamforming, for which we establish the graph attention network (GAT) to track the complicated interference and jamming relationship based on the graph representation of the UAV network. The outer layer address the legitimate UAV deployment and adversarial jamming policy, which is reinterpreted in a multi-agent deep reinforcement learning framework to obtain the strategies of both sides. The inner GAT is then nested within the outer multi-agent learning framework in a hierarchical manner to approximate the equilibrium of the original game model. Simulation results demonstrate the convergence and the performance superiority of the proposed learning scheme in terms of anti-jamming transmission rate. Also, the results exhibit significant generalization capability to cover different network configurations and parameters with reliable communication performance.},
  keywords={Jamming;Autonomous aerial vehicles;Optimization;Games;Deep reinforcement learning;Array signal processing;Reconfigurable intelligent surfaces;Prevention and mitigation;Interference;Hidden Markov models;UAV communications;anti-jamming communications graph attention network;deep reinforcement learning},
  doi={10.1109/TWC.2025.3618614},
  ISSN={1558-2248},
  month={},}@INPROCEEDINGS{9931571,
  author={Kenoui, Mouna and Mehdi, Mohamed Ait},
  booktitle={2022 International Conference on Advanced Aspects of Software Engineering (ICAASE)}, 
  title={Collaborative Learning Environment over Internet Using Augmented Reality and Voice Interaction}, 
  year={2022},
  volume={},
  number={},
  pages={1-8},
  abstract={In this paper, we describe how we combined augmented reality based on marker tracking, 3D natural interaction using IBM Watson speech recognition capabilities on the cloud, and collaborative work allowing multiple users (students, teachers) to visualize in real-time and over the internet a same shared space mixing real scene with 3D contents of a biology course. Teachers and learners are able in such a way to interact collaboratively with the virtual objects in an intuitive and a natural manner by using voice commands and/or vocal inquiries to participate in the course and acquire knowledge. Each user is able to perform, during a real-time educational session, their own actions (selection, rotation, scale) over virtual objects and see and/or hear else’s actions and/or effects synchronously. Visual clues are added to enhance the context awareness and allow each user to recognize who else is acting/speaking at a given time in the group.},
  keywords={Visualization;Three-dimensional displays;Federated learning;Education;Collaboration;Speech recognition;Context awareness;collaboration;augmented reality;3D interaction;HCI;collaborative learning environment;voice interaction;speech recognition;education.},
  doi={10.1109/ICAASE56196.2022.9931571},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11374370,
  author={Sardana, Jiten and Hariharan, Ramanan and Pudi, Rama Samanta},
  booktitle={2025 Tenth International Conference on Science Technology Engineering and Mathematics (ICONSTEM)}, 
  title={AI-Driven Secure and Resilient Healthcare Data Platforms with Intelligent Search and Personalized Communication}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={This work presents a Secure and Resilient Healthcare Data Platform based on AI, which guarantees privacy-sensitive analytics, smart information retrieval, and personalized interaction of the patient. The system makes use of Z-Score Normalization to standardize the data and Recursive Feature Elimination (RFE) to choose the most relevant clinical features. BiLSTM with Attention is a model of distributed learning based on TensorFlow Federated (TFF), which can be used to learn in many healthcare facilities without the centralization of sensitive information. The federated structure increases the security of the data and interoperability, and blockchain implementation is guaranteed to provide transparency and trust to the data sharing. Besides, it has an intelligent search engine, which facilitates query processing with encryptions and an adaptive communication module, which offers context-based, patient-specific responses. The accuracy of the experimental results is high, and the trust can be better checked and latency is reduced which proves the efficacy and the power of the system. The suggested platform creates a powerful base of scalable, secure and patient-centered healthcare intelligence in contemporary medical ecosystems.},
  keywords={Accuracy;Query processing;Ecosystems;Bidirectional long short term memory;Medical services;Standardization;Search engines;Predictive models;Optimization;STEM;AI-Driven Healthcare;Federated Learning;Data Privacy;BiLSTM with Attention;Intelligent Search;Personalized Communication;TensorFlow Federated},
  doi={10.1109/ICONSTEM65670.2025.11374370},
  ISSN={2996-2986},
  month={Nov},}@INPROCEEDINGS{11375026,
  author={Camacho, Michael and Ortega, John Heland Jasper},
  booktitle={TENCON 2025 - 2025 IEEE Region 10 Conference (TENCON)}, 
  title={Ethical Design Framework for Enhancing Accessibility in Graphic Platforms for Colorblind Users}, 
  year={2025},
  volume={},
  number={},
  pages={1476-1480},
  abstract={Color is a foundational element in digital design, yet individuals with color vision deficiency (CVD) often encounter significant barriers when engaging with mainstream graphic design platforms. This study explores the ethical and practical implications of designing for users with CVD, focusing on the experiences of Filipino creatives in both professional and academic settings. It aims to uncover common usability challenges, evaluate the effectiveness of existing accessibility features, and propose improvements that reflect user needs and promote inclusive design practices. Employing a qualitative, exploratory methodology, the study integrates word cloud analysis and the Diffusion of Innovation theory to interpret user feedback and assess attitudes toward accessible tools such as colorblind-friendly palettes and vision simulators. Results show strong support for built-in, customizable accessibility features, with many users expressing openness to adoption if these tools are integrated seamlessly into their workflows. The study contributes to the discourse on digital inclusion by presenting an ethical design framework that promotes accessibility as a standard, not optional, element in graphic design platforms.},
  keywords={Graphics;Ethics;Technological innovation;Focusing;Color;Tag clouds;Digital divide;Usability;Standards;Digital Accessibility;Inclusive Design;Color Vision Deficiency;Ethical Design;Graphic Design Platforms;Diffusion of Innovation;Word Cloud Analysis},
  doi={10.1109/TENCON66050.2025.11375026},
  ISSN={2159-3450},
  month={Oct},}@ARTICLE{11131604,
  author={Hussain, Shoaib and Farrokhabadi, Mostafa and Zareipour, Hamidreza},
  journal={IEEE Transactions on Smart Grid}, 
  title={A Hybrid Imitation–Reinforcement Learning Framework for Optimal Operation of Soft Open Points in Unbalanced Distribution Networks}, 
  year={2025},
  volume={16},
  number={6},
  pages={4563-4575},
  abstract={This paper proposes a hybrid actor-critic framework for the optimal operation of a phase-changing soft open point (PCSOP) in an unbalanced distribution network. The framework combines algorithmic features of off-policy reinforcement learning and imitation learning. The reinforcement learning component comprises a policy-guiding module based on the PCSOP physics and an adaptive dynamic experience replay buffer. The policy-guiding module facilitates the agent’s navigation of the complex action space of the PCSOP. The dynamic experience replay accelerates agent training by leveraging expert demonstrations through imitation learning. As part of the design process, the paper also proposes a data-driven linearization of operational power losses in PCSOPs to enhance the convergence of nonlinear AC optimal power flow calculations without compromising accuracy. The proposed framework was trained and tested on a modified three-phase IEEE-33 bus and the multiphase IEEE-123 bus test feeders. Results demonstrate the superiority of our framework compared to three different methods, including the conventional nonlinear AC optimal power flow.},
  keywords={Training;Optimization;Load flow;Distribution networks;Imitation learning;Power system stability;Voltage control;Vehicle dynamics;Reinforcement learning;Reinforcement learning;imitation learning;unbalanced distribution networks;soft open point},
  doi={10.1109/TSG.2025.3600714},
  ISSN={1949-3061},
  month={Nov},}@ARTICLE{10755950,
  author={Wang, Xiaowen and Zhu, Hongming and Liu, Qi and Liu, Qin},
  journal={IEEE Journal of Biomedical and Health Informatics}, 
  title={Fusing Micro- and Macro-Scale Information to Predict Anticancer Synergistic Drug Combinations}, 
  year={2025},
  volume={29},
  number={3},
  pages={2297-2309},
  abstract={Drug combination therapy is highly regarded in cancer treatment. Computational methods offer a time- and cost-effective opportunity to explore the vast combination space. Although deep learning-based prediction methods lead the field, their generalization ability remains unsatisfactory. Few previous studies have the ability to finely characterize drugs and cell lines at both the micro-scale and macro-scale. Furthermore, the interaction of cross-scale information is often overlooked. These two points limit models' ability of predicting the synergism of drug combinations in cell lines. To address the issues, we propose a novel anticancer synergistic drug combination prediction method termed MMFSynergy in this article. The construction of MMFSynergy involves three phases. First, MMFSynergy pretrains two micro encoders and a macro graph encoder, which can capture micro- or macro-scale information from large volumes of unlabeled data and generate generic features for drugs and proteins. Second, it represents drugs and proteins by fusing cross-scale information through a self-supervised task. Finally, it employs a Transformer Encoder-based model to predict synergy scores, taking representations of drugs in the combinations and the associated proteins of cell lines as input. We compared our method with eight advanced methods across three typical scenarios based on two public datasets. The results consistently demonstrated that the proposed method's generalization ability outperforms six advanced methods'. We also conducted experiments including but not limited to ablation study and case study to further exhibit the effectiveness of MMFSynergy.},
  keywords={Drugs;Predictive models;Proteins;Data models;Computational modeling;Biological system modeling;Diffusion tensor imaging;Computer architecture;Transformers;Microprocessors;Combination therapy;drug combination prediction;pretraining;multi-scale feature fusion;transformer encoder},
  doi={10.1109/JBHI.2024.3500789},
  ISSN={2168-2208},
  month={March},}@INPROCEEDINGS{10211593,
  author={Di, Xinyue and Guan, Yalin and Yu, Weijia and Lin, Heyun},
  booktitle={2023 3rd International Conference on Information Communication and Software Engineering (ICICSE)}, 
  title={A Fast Decentralized Scheduling Method of Cooperative Localization Based on Actor-Critic Deep Reinforcement Learning}, 
  year={2023},
  volume={},
  number={},
  pages={26-31},
  abstract={With the emergence of more and more automated vehicles, localization of vehicles has attracted a lot of attention. Among multiple localization methods, cooperative localization is very attractive due to its high coverage and accuracy. However, it is costly and leads to larger delays to exhaustively measure and exchange information between all adjacent vehicles. Thus, it is a challenge to schedule the transmissions for the cooperative localization. In this paper, we describe the cooperative localization as a partially observable Markov process and propose an actorcritic deep reinforcement learning algorithm to bring the vehicles to a given localization accuracy threshold as quickly as possible. The proposed algorithm allows the transmissions to be optimally scheduled in a distributed manner. Simulation results show that, compared with random, greedy, and two existing deep reinforcement learning algorithms, the proposed algorithm has better performance and is more adaptable to large-scale complex networks.},
  keywords={Location awareness;Deep learning;Schedules;Simulation;Software algorithms;Reinforcement learning;Scheduling;vehicular localization;cooperative localization;scheduling problem;deep reinforcement learning;actor-critic algorithm},
  doi={10.1109/ICICSE58435.2023.10211593},
  ISSN={},
  month={April},}@INPROCEEDINGS{11234601,
  author={Maddula, Lakshmi Priyanka and Cherukuri, Praneet Amul Akash and Jaiswal, Ishu Anand and Ganesan, Siva Kannan and Rana, Nisha and Khera, Mayank},
  booktitle={2025 2nd International Conference on New Frontiers in Communication, Automation, Management and Security (ICCAMS)}, 
  title={Optimization of Code Efficiency with the Utilization of Artificial Intelligence}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
  abstract={The requirement for optimized code that ensures high efficiency as well as speed has risen due to the fast development in the usage of software applications. Conventional code optimization methods, which often place an emphasis on rules, may not be appropriate for different and changing programming patterns. Using models for machine learning, deep learning algorithms, as well as reinforcement learning approaches, this study examines how artificial intelligence (AI) could be utilized to improve code efficiency, hence improving compilation, execution speed, as well as resource consumption. AI-driven solutions provide automatic and intelligent code improvement via the analysis of code structures, identification of inefficiencies, and recommendation of changes. Code profiling, optimization, and the incorporation of artificial intelligence within the compilation procedure all assist developers in reducing execution time, memory use, and overall application performance. This paper examines current AI-based optimization methods, how they affect contemporary programming paradigms, and potential avenues for improving smart code in the future.},
  keywords={Deep learning;Codes;Machine learning algorithms;Automation;Software algorithms;Optimization methods;Reinforcement learning;Programming;Software;Security;Automated Code Profiling;Deep Learning for Performance Enhancement;AI-Driven Code Optimization;Machine Learning in Compilation;Intelligent Software Optimization},
  doi={10.1109/ICCAMS65118.2025.11234601},
  ISSN={},
  month={July},}@INPROCEEDINGS{11254972,
  author={Shah, Sanjana and Chohan, Gurmeet and Masthanali, Sabiya and Danish, Syed Muhammad and Otoum, Yazan},
  booktitle={2025 IEEE/ACIS 29th International Conference on Software Engineering, Artificial Intelligence, Networking and Parallel/Distributed Computing (SNPD)}, 
  title={Advancing Zero Trust Security in Industrial IoT (IIoT): A Machine Learning Perspective}, 
  year={2025},
  volume={},
  number={},
  pages={932-937},
  abstract={The Industrial Internet of Things (IIoT) transforms modern industries by enabling intelligent automation, predictive maintenance, and real-time analytics. However, increased connectivity introduces significant cybersecurity risks, making traditional perimeter-based security models insufficient. This paper examines the adoption of Zero Trust Architecture (ZTA) in IIoT environments, with a focus on integrating machine learning (ML) for adaptive security mechanisms. The study examines identity and access management (IAM), microsegmentation, and anomaly detection in IIoT networks, addressing the unique constraints of industrial environments. Furthermore, an ML-enhanced Trust Algorithm (TA) is proposed to evaluate security risks and dynamically automate access control decisions. By integrating Zero Trust principles with intelligent security mechanisms, this research contributes to the development of resilient IIoT architectures that can effectively mitigate evolving cyber threats.},
  keywords={Access control;Adaptation models;Industrial control;Computer architecture;Transforms;Real-time systems;Threat assessment;Zero Trust;Computer security;Industrial Internet of Things;IoT Security;Zero Trust;Machine Learning;Federated Learning;Industrial Control Systems;SCADA},
  doi={10.1109/SNPD65828.2025.11254972},
  ISSN={2693-8421},
  month={June},}@INPROCEEDINGS{11283213,
  author={Li, Xian and Wang, Xuelei and Xing, Xiangpeng and Zheng, Jiaqing},
  booktitle={2025 5th International Conference on Electronic Information Engineering and Computer Science (EIECS)}, 
  title={Quality Inspection of Automotive Parts Based on Machine Vision}, 
  year={2025},
  volume={},
  number={},
  pages={958-962},
  abstract={This paper centers on the practical requirements of automotive parts quality inspection and conducts research on batch automated inspection of automotive fuses based on machine vision. The aim is to efficiently and accurately determine the breakage status of the internal U-shaped fuse elements in multiple randomly scattered automotive fuses. The study builds a complete image processing algorithm workflow using the OpenCV-Python visual library. To address challenges such as multi-target detection and complex backgrounds, the algorithm focuses on solving key issues like target localization and segmentation, feature extraction, and status classification. Through techniques such as image preprocessing (e.g., grayscale conversion, filtering, binarization), morphological operations, and contour analysis, precise segmentation and localization of multiple scattered fuses are achieved. Furthermore, for each independent fuse region, the breakage status is intelligently determined by analyzing the morphological features of its internal U-shaped area. Experimental results demonstrate that the proposed method effectively enables batch, non-contact automated inspection of automotive fuses with high recognition accuracy, significantly improving inspection efficiency and reliability. This provides a practical technical solution for quality inspection of parts on industrial production lines.},
  keywords={Location awareness;Image segmentation;Visualization;Fuses;Production;Object segmentation;Inspection;Classification algorithms;Automotive engineering;Morphological operations;Machine vision;Quality inspection;OpenCV-Python;Automotive fuse;Multi-target image processing},
  doi={10.1109/EIECS67708.2025.11283213},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10390999,
  author={Yiğit, Yıldıray and Karabatak, Murat and Varol, Asaf and Nasab, Ahad},
  booktitle={2023 4th International Informatics and Software Engineering Conference (IISEC)}, 
  title={Investigation of DQN Algorithm for Driving Control for Smart Cities and Traffic Safety}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={With the rapid increase in the world population day by day, the migration of people from rural areas to cities is also increasing rapidly. This rapid population growth in cities brings with it many problems such as transportation, accommodation and education that need to be solved. Traffic and transportation problems in cities are at the forefront of these problems. Due to the increasing traffic day by day, the time people spend in traffic is increasing, and depending on the traffic density, there can be great variability in the acceleration and deceleration of the drivers. In addition, studies have shown that accidents due to excessive acceleration and deceleration are more common at times when traffic density is low. The fact that vehicle drivers can drive comfortably and safely in traffic can bring many advantages. Many parameters, from driving safety to fuel consumption, from environmental pollution to comfort, can be provided by driving control. The main goal of this work is to create an action strategy that maximizes the overall reward in the long run. In this study, an optimum speed has been tried to be suggested for vehicles in urban traffic by using deep reinforcement learning.},
  keywords={Sociology;Velocity control;Traffic control;Safety;Statistics;Vehicle dynamics;Autonomous vehicles;Traffic;Fuel Consumption;Driver Behavior},
  doi={10.1109/IISEC59749.2023.10390999},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{9926578,
  author={Kaur, Upinder and Ma, Xin and Huang, Yuanmeng and Voyles, Richard M.},
  booktitle={2022 IEEE 18th International Conference on Automation Science and Engineering (CASE)}, 
  title={Human-Like Multimodal Perception and Purposeful Manipulation for Deformable Objects}, 
  year={2022},
  volume={},
  number={},
  pages={1790-1797},
  abstract={Humans possess the uncanny ability to perceive and manipulate deformable objects with agility. Deformable objects, such as a ziplock bag, with their infinite configurations, are particularly challenging. Manipulating deformable objects is hard as deciding corrective action demands great familiarity with its state transitions. Humans learn to manipulate such objects by leveraging multimodal perception capabilities wherein they build a rich understanding by exploration and active manipulation. For robots, such adaptability is lacking as multimodal perception is still limited. In this work, we emulate human-like learning by extending multimodal perception to assist in exploratory manipulation–to build a rich understanding of the deformable object– and purposeful manipulation– to learn to achieve the desired state based on the knowledge of the object. To validate this framework, we undertake the task of closing a ziplock bag as it is a challenging perception task with a simple state structure demanding multi-sensory modes. The bag’s parameters are learned in 10mins during exploratory manipulation. With the multimodal inputs of the three sensors, the accuracy of state detection improves significantly across the different types of bags, illustrating the adaptability. The multimodal perception achieves a maximum state detection accuracy of 95.5%. The bags are closed fully in all 50 trials with the purposeful manipulation framework.},
  keywords={Computer aided software engineering;Automation;Sensors;Task analysis;Robots},
  doi={10.1109/CASE49997.2022.9926578},
  ISSN={2161-8089},
  month={Aug},}@INPROCEEDINGS{11227385,
  author={Wang, Chenghao and Li, Miaodi and Zhang, Muxiang and Zhang, Min},
  booktitle={2025 International Joint Conference on Neural Networks (IJCNN)}, 
  title={Deep Reinforcement Learning for Autonomous Driving with Multiple Expert Demonstrations}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Deep reinforcement learning (DRL) has emerged as a promising approach to address challenges in autonomous driving. Recently, reinforcement learning from expert demonstrations has gained considerable attention, offering a synergistic integration of imitation learning (IL) and reinforcement learning to enhance model performance. However, in complex driving scenarios, expert decisions may be suboptimal, leading to inefficient training and susceptibility to local optima. In light of this, we propose a novel DRL-based model, termed PME. In the decision-making process, we introduce an enhanced algorithm built upon Proximal Policy Optimization (PPO), which integrates multiple expert policies to mitigate the negative impact of erroneous expert decisions, thereby significantly improving the overall performance of the autonomous driving model. Experimental results, conducted in the CARLA simulator, demonstrate that the proposed PME model surpasses conventional reinforcement learning algorithms across various driving scenarios. The framework consistently achieves higher success rates under diverse conditions, showcasing improved learning stability and superior generalization capabilities.},
  keywords={Training;Imitation learning;Decision making;Neural networks;Cloning;Deep reinforcement learning;Stability analysis;Data models;Autonomous vehicles;Optimization;autonomous driving;deep reinforcement learning;multiple expert demonstrations},
  doi={10.1109/IJCNN64981.2025.11227385},
  ISSN={2161-4407},
  month={June},}@INPROCEEDINGS{11152139,
  author={Perez-Ferreiro, Pablo Miguel and Catala, Alejandro and Bugarin-Diz, Alberto and Alonso-Moral, Jose M.},
  booktitle={2025 IEEE International Conference on Fuzzy Systems (FUZZ)}, 
  title={Generating trustworthy explanations with a language model enriched by fuzzy rule-based systems}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={In this work, we have developed, validated, and deployed fuzzy-grounded, trustworthy, interactive explanations by combining fuzzy systems with Large Language Models (LLMs). More precisely, we profit from fuzzy systems’ ability to deal appropriately with vagueness and uncertainty in approximate reasoning and propose an efficient and effective way to combine fuzzy rule-based systems with the natural language verbalization capabilities of LLMs. The aim is to generate explanations that balance naturalness and faithfulness. The proposed software architecture is open-source and highly modular. We validated our work in the medical field. We observed significant statistical differences with related-samples Wilcoxon signed rank tests (p-value < 0.001) regarding hallucinations in the experimental scenarios under study, which hints at good faithfulness. We also produced significantly more compact narratives, which helps alleviate the usual ‘over-explanation’ issue of LLMs without a penalization in accuracy.},
  keywords={Uncertainty;Accuracy;Software architecture;Large language models;Natural languages;Cognition;Fuzzy systems},
  doi={10.1109/FUZZ62266.2025.11152139},
  ISSN={1558-4739},
  month={July},}@INPROCEEDINGS{11245440,
  author={Lin, Jipeng and Guo, Nan and Gong, Ziyan},
  booktitle={2025 IEEE International Symposium on Parallel and Distributed Processing with Applications (ISPA)}, 
  title={EBA-SQL: A Multi-Agent Collaborative Framework with Entity-Based Analysis for Text-to-SQL}, 
  year={2025},
  volume={},
  number={},
  pages={1312-1319},
  abstract={The in-context learning capability of Large Language Models has achieved significant success in text-to-SQL task. Most existed approaches generally adopt a straightforward three-stage workflow including 1) schema linking, 2) SQL generation, and 3) self-correction. However, processing subtasks through a single chain-of-thought prompt limits the reasoning capability of LLMs, while multiple candidate SQLs sacrifice token numbers and runtime cost. To balance execution accuracy and cost for fulfilling text-to-SQL task, a multi-agent collaborative framework EBA-SQL is proposed. We firstly propose a novel entity-based analysis strategy to improve LLMs' understanding and attention of question. Then EBA-SQL adopts a EBA-Driven Decomposer agent acting in the entity-based analysis strategy, which is the core component for question decomposition and SQL generation. Two auxiliary agents, the EBA-Driven Selector and the Error-Driven Refiner, are responsible for schema linking and self-correction, respectively. Experimental results demonstrate the effectiveness and efficiency of EBA-SQL. Specifically, as of June 2025, experiments on the BIRD dataset show that EBA-SQL achieves the best performance with an execution accuracy of $\text{6 3. 5 0 \%}$ on the test set among the open-source GPT-4 based text-to-SQL methods. Extensive analysis and ablation studies confirm that EBA-SQL outperforms the baselines with respect to token and time efficiency, thus to demonstrate the strong potential for practical applications. Our code is available on GitHub: https://github.com/xiaolinstudent/EBA-SQL.},
  keywords={Structured Query Language;Distributed processing;Accuracy;Runtime;Costs;Large language models;Collaboration;Birds;Cognition;Software development management;In-context learning;Large Language Models;Text-to-SQL},
  doi={10.1109/ISPA67752.2025.00181},
  ISSN={2158-9208},
  month={Oct},}@INPROCEEDINGS{11336123,
  author={Swathi Prasad, B. K. and Veerachar, Ravichandra and Sathish, Malathi and Juneja, Pradeep K},
  booktitle={2025 Third International Conference on Emerging Applications of Material Science and Technology (ICEAMST)}, 
  title={Design and Development of a Low-Cost Scalable Swarm Robots for Collective Behaviours}, 
  year={2025},
  volume={},
  number={},
  pages={994-1000},
  abstract={Swarm robotics enables collective behaviour among multiple autonomous agents through decentralized coordination, inspired by natural systems such as ants and bees. This paper presents the design and development of a low-cost, scalable, and modular swarm robot platform for implementing and analysing collective behaviour. The system follows a system engineering approach encompassing concept development, design, hardware realization, and validation. Each robot is constructed using a modular architecture consisting of an Arduino Pro Mini controller, TB6612FNG motor driver, TCRT5000 infrared obstacle detection sensor, and nRF24L01 transceiver for wireless communication. A master-slave configuration is implemented to test coordinated actions using a master replicator algorithm. The master robot detects obstacles in its path, adjusts its movement, and transmits environmental data to the slave robot for behaviour replication. Experimental validation confirmed successful communication at a data rate of 250 kbps and reliable obstacle detection within a 10 cm range. The proposed system demonstrates an affordable and flexible platform suitable for research and educational applications in swarm intelligence and cooperative robotics.},
  keywords={Robot kinematics;Power system management;Heuristic algorithms;Swarm robotics;Robot sensing systems;Systems engineering and theory;Motors;Main-secondary;Hardware;Transceivers;Swarm Robots;Obstacle detection;nRF24L01;module based;Master;Slave},
  doi={10.1109/ICEAMST67459.2025.11336123},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{11253302,
  author={Ighalo, Abraham and Sultana, Ajmery},
  booktitle={2025 IEEE/ACIS 29th International Conference on Software Engineering, Artificial Intelligence, Networking and Parallel/Distributed Computing (SNPD)}, 
  title={Quantum-Enhanced Data Analytics For Crime Prediction}, 
  year={2025},
  volume={},
  number={},
  pages={813-818},
  abstract={As criminal tactics become increasingly sophisticated, using advanced tools and technologies, the demand for more powerful analytical systems has surged. Although classical machine learning approaches have been widely used in criminal analysis, the exponential growth of data, driven largely by large language models (LLMs) and AI agents, has exposed their limitations. Quantum computing, rooted in the principles of quantum mechanics, presents a promising alternative that harnesses the behavior of atoms and electrons to perform complex computations. This study evaluates classical and quantum machine learning approaches for crime prediction, analyzing their efficacy in classifying criminal incidents. Classical models, such as logistic regression, XGBoost, random forest, and support vector machine, demonstrated robust performance, with ensemble methods such as random forest and XGBoost achieving particularly high effectiveness in classification tasks. In contrast, quantum models, including the variational quantum classifier, the quantum neural network, and the quantum support vector machine, showed promising theoretical advantages but lagged in practical performance due to current hardware. The findings highlight the need for further refinement of quantum techniques to bridge this gap and fully harness their potential for complex pattern recognition in criminal data analytics.},
  keywords={Support vector machines;Quantum computing;Machine learning algorithms;Computational modeling;Software algorithms;Quantum mechanics;Data science;Hardware;Random forests;Software engineering;Quantum machine Learning;Quantum Data Analytics;Predictive Policing;Crime Detection;Classical machine Learning},
  doi={10.1109/SNPD65828.2025.11253302},
  ISSN={2693-8421},
  month={June},}
