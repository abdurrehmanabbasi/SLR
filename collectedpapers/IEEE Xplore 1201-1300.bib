  title={Neural Active Sensing Vision and Manipulation for Cooperative Agents}, 
  year={2024},
  volume={},
  number={},
  pages={942-947},
  abstract={This work presents a pioneering exploration in active sensing for soft robotics, focusing on the integration of neural self-actuation for enhanced sensing and manipulation. The study delves into optimizing problems and inverse designs to augment the interactive and adaptive capabilities of soft robots across varied environments. It discusses the complexities of modeling large deformations unique to soft robotics, utilizing differentiable simulations to refine control strategies. The introduction of a novel network architecture targets active sensing and formulates it as an inverse problem, significantly boosting learning and performance in intricate tasks. Incorporating cutting-edge principles in neural graphics optimization, this research lays the groundwork for tactile sensing, paving the way for practical applications in real-world.},
  keywords={Adaptation models;Sensor placement;Inverse problems;Computational modeling;Computer architecture;Soft robotics;Predictive models;Robot sensing systems;Sensors;Optimization;Soft Robotics;Robots Learning;Tactile sensing;Inverse problem & optimization;Computer Vision},
  doi={10.1109/ICBASE63199.2024.10762162},
  ISSN={},
  month={Sep.},}@ARTICLE{11142724,
  author={He, Ningxin and Zhang, Zehui and Gao, Tiegang and Zhang, Songsong and Huo, Weiwei and Bin, Zuo},
  journal={IEEE Internet of Things Journal}, 
  title={Communication-Efficient Adaptive Wavelet-Compressed Federated Learning for State of Health Prediction of Lithium-Ion Batteries in IoT Environments}, 
  year={2025},
  volume={12},
  number={22},
  pages={47451-47465},
  abstract={Lithium-ion batteries (LIBs) are widely used in electric vehicles and energy storage systems, where accurate State of Health (SoH) prediction is essential for safety and reliability. While deep learning has shown promise for SoH modeling, obtaining high-quality training data remains challenging due to high testing costs and privacy constraints. This study proposes an enhanced federated learning (FL) approach, enabling multiple institutions to collaboratively train SoH models while preserving local data privacy. To address communication overhead in resource-constrained Internet of Things (IoT) environments and data heterogeneity across non-IID battery datasets, we introduce an adaptive wavelet-based compression framework. An agent-specific adaptive top-K sparsification (AATKS) mechanism dynamically adjusts the sparsification rate for each agent, mitigating the impact of data heterogeneity by preventing excessive information loss in critical updates while ensuring efficient communication. Additionally, a layer-wise energy weighted aggregation (LEWAgg) strategy enhances global model consistency by prioritizing high-energy coefficients, leading to more stable learning across heterogeneous clients. Experiments on three real-world LIBs datasets demonstrate that the proposed WCFL framework achieves a  $14\times $  reduction in communication cost with less than 0.75% accuracy loss compared to centralized training. This study provides an efficient and scalable solution for collaborative battery health management in practical IoT settings.},
  keywords={Batteries;Training;Accuracy;Data models;Integrated circuit modeling;Federated learning;Data privacy;Predictive models;Adaptation models;Wavelet transforms;Federated learning (FL);lithium-ion batteries (LIBs);model compression;state of health (SoH) prediction;wavelet transformation},
  doi={10.1109/JIOT.2025.3603160},
  ISSN={2327-4662},
  month={Nov},}@INPROCEEDINGS{10731463,
  author={Macciò, Simone and Shaaban, Mohamad and Carfì, Alessandro and Mastrogiovanni, Fulvio},
  booktitle={2024 33rd IEEE International Conference on Robot and Human Interactive Communication (ROMAN)}, 
  title={Kinesthetic Teaching in Robotics: a Mixed Reality Approach}, 
  year={2024},
  volume={},
  number={},
  pages={1610-1617},
  abstract={As collaborative robots become more common in manufacturing scenarios and adopted in hybrid human-robot teams, we should develop new interaction and communication strategies to ensure smooth collaboration between agents. In this paper, we propose a novel communicative interface that uses Mixed Reality as a medium to perform Kinesthetic Teaching (KT) on any robotic platform. We evaluate our proposed approach in a user study involving multiple subjects and two different robots, comparing traditional physical KT with holographic-based KT through user experience questionnaires and task-related metrics.},
  keywords={Software architecture;Education;Mixed reality;Virtual reality;Resists;Production;User experience;Manufacturing;Robots;Standards;Human-Robot Interaction;Mixed Reality;Kinesthetic Teaching;Software Architecture},
  doi={10.1109/RO-MAN60168.2024.10731463},
  ISSN={1944-9437},
  month={Aug},}@INPROCEEDINGS{11133936,
  author={Yang, Shu and Chen, Dantong and Cui, Laizhong and Xu, Mingwei},
  booktitle={2025 34th International Conference on Computer Communications and Networks (ICCCN)}, 
  title={WISTRO: Towards Efficient Weather-Aware Routing for Integrated Satellite-Terrestrial Networks}, 
  year={2025},
  volume={},
  number={},
  pages={1-9},
  abstract={Integrated satellite-terrestrial networks (ISTNs) have recently garnered significant attention. However, they face substantial challenges during routing in dynamic environments. Although previous works proposed many dynamic ISTN routing schemes, they mainly focus on topology changes. The network performance still deteriorates due to the fluctuation of link capacity under adverse weather. The main reason is that radio frequency or laser links are prone to interruption under extreme weather because of their high frequencies. However, weather is predictable; thus, we propose a weather-aware routing scheme to consider weather conditions while making routing decisions.We first formulate the problem as minimizing delay while satisfying loss and throughput requirements. Then, we propose a multi-agent reinforcement learning routing algorithm to adapt to high dynamic networks with frequently changed link weights. Using real-world weather datasets, we conduct extensive simulations and experimental results show that our approach reduces delay by at least 49.12% compared to baseline methods. Finally, we perform a case study to further validate the results.},
  keywords={Heuristic algorithms;System performance;Satellite broadcasting;Routing;Space-air-ground integrated networks;Deep reinforcement learning;Throughput;Delays;Topology;Meteorology;Integrated satellite-terrestrial network;Routing optimization;Deep Reinforcement learning},
  doi={10.1109/ICCCN65249.2025.11133936},
  ISSN={2637-9430},
  month={Aug},}@ARTICLE{11145230,
  author={Saleh, Fekri and Fapojuwo, Abraham O. and Krishnamurthy, Diwakar},
  journal={IEEE Transactions on Network and Service Management}, 
  title={eSlice: Elastic Inter-Slice Resource Allocation for Smart City Applications}, 
  year={2025},
  volume={22},
  number={6},
  pages={5619-5639},
  abstract={Network slicing is a fundamental enabler for the advancement of fifth generation (5G) and beyond 5G (B5G) networks, offering customized service-level agreements (SLAs) for distinct slices such as enhanced mobile broadband (eMBB), massive machine-type communications (mMTC), and ultra-reliable low-latency communication (URLLC). However, smart city applications often require multiple slices concurrently, posing significant challenges in resource allocation, service isolation, and maintaining performance guarantees. This article presents eSlice, an elastic inter-slice resource allocation mechanism specifically designed to address the dynamic requirements of smart city applications. eSlice organizes applications into hierarchical slices, leveraging cloud-native resource scaling to dynamically adapt to real-time demands. It integrates two novel algorithms: the Proactive eSlice Allocation Algorithm (PeSAA), which ensures the fair distribution of resources across the substrate network, and the Reactive eSlice Allocation Algorithm (ReSAA), which employs Multi-Agent Reinforcement Learning (MARL) to dynamically coordinate, reallocate, and recover unused resources as network conditions evolve. Experimental results demonstrate that eSlice significantly outperforms existing methods, achieving 94.3% resource utilization in simulation-based experiments under constrained urban-scale scenarios, providing a robust solution for dynamic resource management in 5G-enabled smart city networks.},
  keywords={Resource management;Smart cities;5G mobile communication;Ultra reliable low latency communication;Dynamic scheduling;Substrates;Network slicing;Heuristic algorithms;Real-time systems;Vehicle dynamics;Inter-slice;network slicing;smart city applications;dynamic resource allocation},
  doi={10.1109/TNSM.2025.3604352},
  ISSN={1932-4537},
  month={Dec},}@ARTICLE{10955178,
  author={Peng, Yuhuai and Li, Yuan and Guo, Yu and Zhang, Dawei and Khan, Fazlullah and Alturki, Ryan and Alshawi, Bandar},
  journal={IEEE Transactions on Consumer Electronics}, 
  title={A Blockchain-Based Distributed Collaborative Sensing and Spectrum Access Approach for Consumer Electronics}, 
  year={2025},
  volume={71},
  number={2},
  pages={5044-5054},
  abstract={Cognitive radio (CR) provides key technical support for the seamless communication of consumer electronic (CE) devices through distributed cooperative sensing and spectrum access. However, its openness and dynamic nature introduce potential security risks and challenges. Due to the openness of wireless communication, spectrum sensing and access are vulnerable to malicious attacks, and resource-constrained devices cannot effectively implement artificial intelligence (AI)-driven encryption and access control strategies. To address these limitations, this study proposes a blockchain-based distributed collaborative sensing method for CE devices. In the proposed method, after sensing, the smart contracts verify node legitimacy using the ring signature method. The malicious users are rejected by the outlier detection method, which improves the collaborative anti-interference ability. In addition, by using a centralized training and distributed execution architecture, a secure spectrum sensing strategy based on multi-agent reinforcement learning is designed. The proposed strategy ensures that each node makes independent decisions, which enhances the adaptability of the CE ecosystem. The proposed method is verified by extensive simulations, and the results show that it can maintain spectrum awareness of more than 95.72% and an access success rate of 91.19% under malicious attacks. Moreover, communication overhead is significantly reduced by approximately 93.53%.},
  keywords={Collaboration;Sensors;Security;Consumer electronics;Heuristic algorithms;Protection;Convolutional neural networks;Adaptation models;Resource management;Artificial intelligence;Blockchain;cognitive radio;consumer electronics;distributed collaborative sensing;secure spectrum access},
  doi={10.1109/TCE.2025.3558629},
  ISSN={1558-4127},
  month={May},}@ARTICLE{11394788,
  author={Zheng, Yupeng and Xing, Zebin and Zhang, Qichao and Jin, Bu and Li, Pengfei and Zheng, Yuhang and Xia, Zhongpu and Chen, Yaran and Zhao, Dongbin},
  journal={IEEE Transactions on Cognitive and Developmental Systems}, 
  title={PlanAgent: A Multi-modal Large Language Agent for Closed-loop Vehicle Motion Planning}, 
  year={2026},
  volume={},
  number={},
  pages={1-14},
  abstract={Vehicle motion planning is an essential component of autonomous driving technology. Current rule-based vehicle motion planning methods perform satisfactorily in common scenarios but struggle to generalize to long-tailed situations. Meanwhile, learning-based methods have yet to achieve superior performance over rule-based approaches in large-scale closed-loop scenarios. To address these issues, we propose PlanAgent, the first mid-to-mid planning system based on a multi-modal large language model (MLLM). MLLM is used as a cognitive agent to introduce human-like knowledge, interpretability, and commonsense reasoning into closed-loop planning. Specifically, PlanAgent leverages the power of MLLM through three core modules. First, an Environment Transformation module constructs a Bird’s Eye View (BEV) map and a lane-graph-based textual description from the environment as inputs. Second, a Reasoning Engine module introduces a hierarchical chain-of-thought from scene understanding to lateral and longitudinal motion instructions, culminating in planner code generation. Last, a Reflection module is integrated to simulate and evaluate the generated planner for reducing MLLM’s uncertainty. PlanAgent is endowed with the common-sense reasoning and generalization capability of MLLM, which empowers it to effectively tackle both common and complex long-tailed scenarios. Our proposed PlanAgent is evaluated on the large-scale and challenging nuPlan benchmarks. A comprehensive set of experiments convincingly demonstrates that PlanAgent outperforms the existing state-of-the-art in the closed-loop motion planning task.},
  keywords={Planning;Autonomous vehicles;Trajectory;Heavily-tailed distribution;Benchmark testing;Large language models;Reflection;Engines;Safety;Commonsense reasoning;Multi-modal Language Model;Language Agent;Autonomous Driving;Closed-loop Motion Planning},
  doi={10.1109/TCDS.2026.3664120},
  ISSN={2379-8939},
  month={},}@INPROCEEDINGS{9720399,
  author={Fernquest, Jon},
  booktitle={2022 Joint International Conference on Digital Arts, Media and Technology with ECTI Northern Section Conference on Electrical, Electronics, Computer and Telecommunications Engineering (ECTI DAMT & NCON)}, 
  title={PolySense Flashcards: A Machine-Learning-Enhanced Platform for Learning the Multiple Senses of Academic Vocabulary}, 
  year={2022},
  volume={},
  number={},
  pages={518-522},
  abstract={An architecture for a flashcard system for learning vocabulary is presented here that feeds directly off the experimental work on vocabulary acquisition. In principle, experiments in vocabulary acquisition based on traditional inferential statistics applied to small once-off collected sets of data informs vocabulary pedagogy as teachers are exposed to experimental results via training courses and practical teaching-oriented literature. Recently, however, in many domains of practical application this traditional statistics approach has been replaced by machine learning algorithms feeding off large continuous streams of real time data. Here it is proposed that a flashcard app that integrates such machine learning support into its architecture can serve as an adaptive experimental platform for continual pedagogical improvement. Flashcards for learning the multiple senses of high-frequency academic vocabulary is chosen as an important initial exploratory domain of application.},
  keywords={Training;Vocabulary;Machine learning algorithms;Machine learning;Real-time systems;Feeds;flashcard apps;software architecture;word sense disambiguation;text mining;recommendation systems;intelligent tutoring systems},
  doi={10.1109/ECTIDAMTNCON53731.2022.9720399},
  ISSN={2768-4644},
  month={Jan},}@ARTICLE{10454102,
  author={Mao, Bing and Wu, Xiaoqun and Liu, Hui and Xu, Yuhua and Lü, Jinhu},
  journal={IEEE Transactions on Cybernetics}, 
  title={Adaptive Fuzzy Tracking Control With Global Prescribed-Time Prescribed Performance for Uncertain Strict-Feedback Nonlinear Systems}, 
  year={2024},
  volume={54},
  number={9},
  pages={5217-5230},
  abstract={For strict-feedback systems with mismatched uncertainties, adaptive fuzzy control techniques are developed to provide global prescribed performance with prescribed-time convergence. First, a class of prescribed-time prescribed performance functions are designed to quantify the performance constraints of the tracking error. Additionally, a novel error transformation function is provided to eliminate the initial value limitations and resolve the singularity issue in previous research. To ensure the convergence of the tracking error into a prescribed bounded region within a prescribed time and satisfactory transient performance, controllers with or without approximating structures are established. Notably, the settling time and initial condition of the prescribed performance function are completely independent of the initial tracking error and system parameters, thereby improving upon existing results. Furthermore, the disadvantage of the semi-global boundedness of tracking error induced by dynamic surface control can be eliminated through the use of a novel Lyapunov-like energy function. Finally, the effectiveness of the proposed strategies is validated through numerical simulations performed on practical examples.},
  keywords={Nonlinear systems;Fuzzy logic;Adaptive systems;Convergence;Uncertainty;Fuzzy control;Adaptive fuzzy control;global prescribed performance;mismatched uncertainty;prescribed time;strict-feedback systems},
  doi={10.1109/TCYB.2024.3366177},
