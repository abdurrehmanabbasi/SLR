@INPROCEEDINGS{9929640,
  author={Leyesa, Marlon C. and Mariano, Oliver R. and Galvez, Reagan L.},
  booktitle={2022 IEEE 10th Region 10 Humanitarian Technology Conference (R10-HTC)}, 
  title={Project Cost Processing System for Electronics Systems Integrator}, 
  year={2022},
  volume={},
  number={},
  pages={211-215},
  abstract={The study aims to develop a system software that could calculate and estimate every project job order for an electronics systems integrator. Using the modified input-process-output model, the system could quickly and efficiently process each of the documents that are required for any project job order for the budgeting procedure, such as calculation and estimation for the budget at completion; calculation for the direct costs, which are the material cost, labor cost, outsourcing cost, general item cost, and equipment cost; calculation for the indirect cost which are the overhead operating cost and the liabilities; calculation for the contingency reserve and management reserve; computation for the distributed budget and the undistributed budget. The system also serves as a tracking system, which would help the company easily monitor the progress of the project if it is behind or ahead of schedule and if it is over budget or under budget. This system would be of great support to the company in every project engagement. Based on the evaluation conducted, the research is highly recommendable to the project managers and engineers in terms of functionality, reliability, usability, and efficiency.},
  keywords={Schedules;Costs;Estimation;Companies;Reliability engineering;System software;Outsourcing;electronics systems integrator;processing system;project cost management;monitoring and control;software development},
  doi={10.1109/R10-HTC54060.2022.9929640},
  ISSN={2572-7621},
  month={Sep.},}@INPROCEEDINGS{10483379,
  author={Deng, Caizi and Shi, Guoyou},
  booktitle={2023 International Conference on Intelligent Management and Software Engineering (IMSE)}, 
  title={Maritime Safety Decision-Making Model Based on Judgment Aggregation–A Case Study of the Interconnected Pipeline Route between Zhoushan and Ningbo Petrochemical Base}, 
  year={2023},
  volume={},
  number={},
  pages={215-221},
  abstract={The development of ocean resources implicates an array of stakeholders and departments. This study introduces a mechanism based on judgement aggregation, aiming to streamline decision-making, mitigate risks associated, and foster equitable, rational collective decisions for managing conflicts in ocean resource development. The proposed mechanism forms a coordinating committee of experts, facilitating centralized dialogue and information exchange. Leveraging a judgement aggregation model grounded in Social Choice Theory, it amalgamates the knowledge, experience, and judgments of experts to devise a holistic plan for resource development. The approach is implemented to assess the underwater pipeline route in the Zhenhai area of the Zhoushan-Ningbo Petrochemical Base. The findings suggest that majority voting rules do not yield consistent judgement sets. However, by employing the judgement aggregation model, optimal collective decisions can be derived from multiple individual decisions. This aids in harmonized and mutually advantageous planning of maritime transportation and other ocean activities, thereby safeguarding maritime safety.},
  keywords={Oceans;Decision making;Pipelines;Sea measurements;Transportation;Petrochemicals;Safety;Group decision making;judgment aggregation;logic;answer set programing},
  doi={10.1109/IMSE61332.2023.00050},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{11247740,
  author={Wan, Hanwen and Chen, Yifei and Deng, Yixuan and Wei, Zeyu and Li, Dongrui and Lin, Zexin and Wu, Donghao and Cheng, Jiu and Ji, Xiaoqiang},
  booktitle={2025 IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS)}, 
  title={EmbodiedAgent: A Scalable Hierarchical Approach to Overcome Practical Challenge in Multi-Robot Control}, 
  year={2025},
  volume={},
  number={},
  pages={12140-12146},
  abstract={This paper introduces EmbodiedAgent, a hierarchical framework for heterogeneous multi-robot control. EmbodiedAgent addresses critical limitations of hallucination in impractical tasks. Our approach integrates a next-action prediction paradigm with a structured memory system to decompose tasks into executable robot skills while dynamically validating actions against environmental constraints. We present Mul-tiPlan+, a dataset of more than 18,000 annotated planning instances spanning 100 scenarios, including a subset of impractical cases to mitigate hallucination. To evaluate performance, we propose the Robot Planning Assessment Schema (RPAS), combining automated metrics with LLM-aided expert grading. Experiments demonstrate EmbodiedAgent’s superiority over state-of-the-art models, achieving 71.85% RPAS score. Real-world validation in an office service task highlights its ability to coordinate heterogeneous robots for long-horizon objectives.},
  keywords={Measurement;Robot kinematics;Benchmark testing;Robustness;Planning;Multi-robot systems;Intelligent robots},
  doi={10.1109/IROS60139.2025.11247740},
  ISSN={2153-0866},
  month={Oct},}@ARTICLE{10457538,
  author={Schoenherr, Jordan Richard and Thomson, Robert},
  journal={IEEE Transactions on Technology and Society}, 
  title={When AI Fails, Who Do We Blame? Attributing Responsibility in Human–AI Interactions}, 
  year={2024},
  volume={5},
  number={1},
  pages={61-70},
  abstract={While previous studies of trust in artificial intelligence have focused on perceived user trust, the paper examines how an external agent (e.g., an auditor) assigns responsibility, perceives trustworthiness, and explains the successes and failures of AI. In two experiments, participants (university students) reviewed scenarios about automation failures and assigned perceived responsibility, trustworthiness, and preferred explanation type. Participants’ cumulative responsibility ratings for three agents (operators, developers, and AI) exceeded 100%, implying that participants were not attributing trust in a wholly rational manner, and that trust in the AI might serve as a proxy for trust in the human software developer. Dissociation between responsibility and trustworthiness suggested that participants used different cues, with the kind of technology and perceived autonomy affecting judgments. Finally, we additionally found that the kind of explanation used to understand a situation differed based on whether the AI succeeded or failed.},
  keywords={Artificial intelligence;Software algorithms;Ethics;Automation;Decision making;Cognitive processes;Technology acceptance model;Social implications of technology;Social factors;Human in the loop;Human factors;Trust management;Human-robot interaction;Failure analysis;Cognitive processes;technology acceptance model;technology social factors;human in the loop},
  doi={10.1109/TTS.2024.3370095},
  ISSN={2637-6415},
  month={March},}@ARTICLE{10812952,
  author={Zhu, Xiaoqiang and Liu, Jiqiang and Zhang, Tao and Liu, Yuan and Wang, Chenyang and Wang, Chunpeng and Zhao, Zhongqi and Han, Zhu},
  journal={IEEE Transactions on Cognitive Communications and Networking}, 
  title={CPPU: Policy Space Diversity for Informative Path Planning and GAI-Enabled Updating CSI in ISAC}, 
  year={2025},
  volume={11},
  number={2},
  pages={777-790},
  abstract={Integrated Sensing and Communication (ISAC) is a core component of 6G technology, driving advancements in networking and communication in combination with Generative Artificial Intelligence (GAI). By utilizing GAI’s predictive functions, indoor positioning achieves higher efficiency through optimized fingerprint localization methods. Traditional approaches to Channel State Information (CSI) collection remain costly and lack adaptability in dynamic environments. To address these challenges, this paper proposes an algorithm that combines multi-agent learning with a GAI model for CSI acquisition, Path Planning, and Updating, namely CPPU. Initially, the terrain is partitioned into multiple regions, each corresponding to a specific agent, ensuring comprehensive path coverage and eliminating backtracking solutions. Subsequently, the dynamic programming strategy of the policy space response oracle is employed to identify informative paths within each region. These paths are determined by integrating full-coverage paths with a small dataset of real CSI, thus representing the most informative paths that reflect the distribution of CSI. CSI data along these informative paths is then collected. Finally, the GAI model is deployed to predict and update the CSI distribution at the remaining points. Experimental validation in two real-world scenarios verifies that CPPU significantly reduces data acquisition costs while maintaining localization accuracy comparable to existing methods.},
  keywords={Path planning;Databases;Robots;Predictive models;Location awareness;Data collection;Costs;Data models;Robot kinematics;Prediction algorithms;ISAC;CSI;GAI;path planning;dynamic programming},
  doi={10.1109/TCCN.2024.3522088},
  ISSN={2332-7731},
  month={April},}@INPROCEEDINGS{10293356,
  author={Mambou, Elie Ngomseu and Woungang, Isaac},
  booktitle={2023 IEEE AFRICON}, 
  title={Bandit Algorithms Applied in Online Advertisement to Evaluate Click-Through Rates}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={Reinforcement learning approaches are increasingly used to model complex decision-based problems. The multi-armed bandit problem is a classical instance suitable for reinforcement learning challenges that involves balancing exploration and exploitation trade-offs. Finding a balance between exploration and exploitation is a fundamental aspect of a variety of reinforcement learning applications. Multi-armed bandit algorithms are useful in multiple industry domains such as computer games, clinical trials, telecommunication, and recommender systems. This paper aims to study the multi-armed bandit problem and contextualize the algorithms to provide a framework for optimizing click-through rates in online advertising, thereby improving the customer fidelity. To that end, parameterized bandit algorithms such as upper confidence bound (UCB), epsilon greedy (є-greedy), and SoftMax algorithms were implemented and tweaked to maximize performance in an advertising platform. The results obtained demonstrate optimal records in choosing the best adverts. The UCB approach achieves the highest cumulative mean rewards for selecting the arms over the iterations. Experiments stipulate that the proposed system outperforms the conventional techniques when є and τ are set to 0.1 as it does not rely on the availability of the data over varying cycles.},
  keywords={Industries;Video games;Reinforcement learning;Communications technology;Ensemble learning;Advertising;Task analysis;Click-through rate (CTR);Reinforcement learning (RL);multi-armed bandit (MAB);upper confidence bound (UCB);epsilon greedy (є-greedy);Boltzmann exploration (Soft-Max);exploration;exploitation},
  doi={10.1109/AFRICON55910.2023.10293356},
  ISSN={2153-0033},
  month={Sep.},}@INPROCEEDINGS{11063477,
  author={Nguyen, Truc and Tran, Vu and Nguyen, Ninh and Huynh, Trinh and Dinh, Dung},
  booktitle={2024 16th International Conference on Knowledge and System Engineering (KSE)}, 
  title={Chatbot for E-Commerce Service Based on Rasa Framework and BERT Model}, 
  year={2024},
  volume={},
  number={},
  pages={01-05},
  abstract={The rapid growth in demand for instant and personalized responses within the e-commerce sector, particularly in online clothing retail, presents a significant challenge: delivering timely customer support to enhance satisfaction. Traditional methods, such as call centers and email support, often prove slow and costly for e-commerce businesses. Chatbots offer a practical solution by providing instant and efficient support. Among available chatbot frameworks, the Rasa Framework stands out for its simplicity and effectiveness in real-world applications. This research focuses on developing and implementing a chatbot for intelligent and convenient ecommerce services using the Rasa Framework. In our evaluation, we conducted a comparative analysis of various machine learning models. The results highligh the superior performance of Google's BERT language model, particularly when integrated with the DIET and Fallback classifiers, achieving an accuracy of 0.64, compared to 0.56 without BERT. The system was tested with 400 questions across 50 topics, categorized into three primary question groups. Approximately 64 % of the responses were correct, with users reporting relatively positive satisfaction ratings. These findings suggest that BERT-enhanced chatbots have significant potential to improve customer service efficiency in e-commerce.},
  keywords={Knowledge engineering;Biological system modeling;Customer services;Clothing;Machine learning;Chatbots;Systems engineering and theory;Internet;Electronic commerce;Business;AI chatbot;Rasa;BERT;Ecommerce},
  doi={10.1109/KSE63888.2024.11063477},
  ISSN={2694-4804},
  month={Nov},}@INPROCEEDINGS{10452571,
  author={Ranganathan, Roehit and Kumar, G.Senthil and Angel, T.S.Shiny},
  booktitle={2023 International Conference on Data Science, Agents & Artificial Intelligence (ICDSAAI)}, 
  title={A Tool for Database Masking and Anonymization of PostgreSQL}, 
  year={2023},
  volume={},
  number={},
  pages={1-6},
  abstract={Managing and securing sensitive data in a production database can be a complex and challenging task, especially when creating a staging database for testing and development purposes. This is why we have designed a tool that can automate the process of creating a staging database from a backup of the production database while anonymizing critical data based on user input. Our tool is specifically designed for PostgreSQL databases and can be easily integrated into the database management workflow. It allows users to select which tables and fields in the database should be anonymized, with options for different anonymization techniques based on the data type. This ensures that sensitive data is properly protected and complies with data privacy regulations. To ensure the success of the anonymization process, the tool utilizes machine learning algorithms that analyze past user input to predict which fields are likely to be selected for anonymization. This helps reduce the risk of errors and ensures that all critical data is properly anonymized with high accuracy. In the future, we plan to enhance the tool with more advanced anonymization techniques and incorporate additional machine-learning algorithms to improve the accuracy of the prediction models. This will help further streamline the database management process and ensure that sensitive data is always properly secured.},
  keywords={Data privacy;Databases;Production;Information filtering;Task analysis;Information integrity;Testing;Database;Masking;PostgreSQL;Anonymizer;Passive Aggressive classifier},
  doi={10.1109/ICDSAAI59313.2023.10452571},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10452428,
  author={Saranya, K. and Sankaradass, Veeramalai},
  booktitle={2023 International Conference on Data Science, Agents & Artificial Intelligence (ICDSAAI)}, 
  title={Hyperpersonalization of Educational Content Through Multimodal Deep Learning and Gamification}, 
  year={2023},
  volume={},
  number={},
  pages={1-5},
  abstract={This project proposes a groundbreaking approach to revolutionize the traditional educational framework by integrating multimodal deep learning and gamification to foster hyper-personalized learning experiences. Envisioning a classroom where education resonates with individual cognitive rhythms and passions, the system employs advanced algorithms to analyze text, voice, and facial expressions, thereby adapting content delivery to cater to diverse learning styles and needs. Concurrently, gamified elements such as points, badges, and personalized challenges enhance motivation, engagement, and retention. The teacher’s role transforms from a primary knowledge source to a skilled guide and facilitator, leveraging AI-driven insights to curate tailored learning experiences and interventions. This paradigm shift in pedagogy aims to create an inclusive, empowering, and adaptive learning environment where every student embarks on a personalized educational odyssey, celebrating their unique potential and fostering lifelong learning.},
  keywords={Deep learning;Adaptive learning;Transforms;Data mining;Artificial intelligence;Multimodal deep learning;Natural language processing;Computer vision;Reinforcement learning;educational data mining},
  doi={10.1109/ICDSAAI59313.2023.10452428},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{10229466,
  author={He, Yejun and Razi, Muslim and Gao, Jerry and Tao, Chuanqi},
  booktitle={2023 IEEE International Conference On Artificial Intelligence Testing (AITest)}, 
  title={A Framework for Autonomous Vehicle Testing Using Semantic Models}, 
  year={2023},
  volume={},
  number={},
  pages={66-73},
  abstract={With the rapid development of big data and artificial intelligence, autonomous vehicles (AV) have achieved great success in diverse application domains. Although the current development of autonomous driving technology has been greatly improved, the accident rate of driverless vehicles still rises. Therefore, how to ensure the quality of AVs using different testing technologies has become an important issue. Traditional testing approaches such as decision tables and state charts struggle with diversified test inputs. Hence, there is a strong demand for new test models for AV testing. In this paper, we present a model-based testing framework that utilizes semantic trees and 3-dimensional (3D) test tables to model driving scenarios into individual test cases. Using the proposed framework, we generate fine-grained examples corresponding to the real world. Also, we evaluate the behavior of the Apollo AV system in 30 scenarios in SVL simulator. The results show that the scenarios generated by our framework can cover most conditions occurring, thus addressing the challenge of testing AVs for safety and reliability.},
  keywords={Solid modeling;Three-dimensional displays;Semantics;Closed box;Big Data;Safety;Reliability;model-based testing;autonomous vehicle testing;test scenario generation;black-box test},
  doi={10.1109/AITest58265.2023.00020},
  ISSN={2835-3560},
  month={July},}@INPROCEEDINGS{9832372,
  author={Zheng, Nianzhao and Li, Jialong and Mao, Zhenyu and Tei, Kenji},
  booktitle={2022 IEEE 2nd International Conference on Software Engineering and Artificial Intelligence (SEAI)}, 
  title={From Local to Global: A Curriculum Learning Approach for Reinforcement Learning-based Traffic Signal Control}, 
  year={2022},
  volume={},
  number={},
  pages={253-258},
  abstract={Traffic signal control (TSC) is one of the effective ways to mitigate traffic congestion, a growing problem causing significant economic loss to urban areas. In recent years, there is an increasing interest in using reinforcement learning (RL) in TSC since RL shows great potential in optimizing control policy for complex real-world traffic conditions. However, one concerning problem is the huge computing time/resources required to train the control policy for large-scale TSC. To address this problem, this paper proposes a method that utilizes a curriculum to help speed up the training process. Control policies of different single-intersection maps are learned first and then referenced to a large-scale map consisting of a certain number of different intersections. The preliminary evaluation demonstrates that our method achieves a jump-start compared to that of learning the target task from scratch.},
  keywords={Training;Economics;Conferences;Urban areas;Learning (artificial intelligence);Reinforcement learning;Task analysis;traffic signal control;curriculum learning;reinforcement learning},
  doi={10.1109/SEAI55746.2022.9832372},
  ISSN={},
  month={June},}@INPROCEEDINGS{11164027,
  author={Jaitly, Akshay and Cline, Jack and Farzan, Siavash},
  booktitle={2025 IEEE 21st International Conference on Automation Science and Engineering (CASE)}, 
  title={A MILP-Based Solution to Multi-Agent Motion Planning and Collision Avoidance in Constrained Environments}, 
  year={2025},
  volume={},
  number={},
  pages={2200-2207},
  abstract={We propose a mixed-integer linear program (MILP) for multi-agent motion planning that embeds Polytopic Action-based Motion Planning (PAAMP) into a sequence-then-solve pipeline. Region sequences confine each agent to adjacent convex polytopes, while a big-M hyperplane model enforces inter-agent separation. Collision constraints are applied only to agents sharing or neighboring a region, which reduces binary variables exponentially compared with naive formulations. An L1 path-length-plus-acceleration cost yields smooth trajectories. We prove finite-time convergence and demonstrate on representative multi-agent scenarios with obstacles that our formulation produces collision-free trajectories an order of magnitude faster than an unstructured MILP baseline.},
  keywords={Costs;Computer aided software engineering;Automation;Pipelines;Planning;Trajectory;Collision avoidance;Convergence},
  doi={10.1109/CASE58245.2025.11164027},
  ISSN={2161-8089},
  month={Aug},}@INPROCEEDINGS{11163868,
  author={Lewis, Ryan and Becker, Aaron T. and Bernardini, Francesco and Leclerc, Julien},
  booktitle={2025 IEEE 21st International Conference on Automation Science and Engineering (CASE)}, 
  title={Heterogeneous Performance of Swarm Collision Avoidance Strategies}, 
  year={2025},
  volume={},
  number={},
  pages={499-504},
  abstract={Four prominent collision avoidance methods are Artificial Potential Fields, Artificial Potential Fields expressed as Control Barrier Functions, Control Barrier Functions, and Reciprocal Velocity Obstacles. Prior work often assumes all agents are using the same obstacle avoidance methods. The methods differ in computational scalability, how they react to different types of obstacles, and in how they react to agents with heterogenous collision avoidance methods. This paper explores the scenario robustness and scalability of these methods through three key navigation scenarios: different structures of stationary obstacles, circle-crossing collision avoidance benchmarks, and defense against an antagonistic swarm.},
  keywords={Costs;Computer aided software engineering;Automation;Navigation;Scalability;Noise;Benchmark testing;Robustness;Safety;Collision avoidance},
  doi={10.1109/CASE58245.2025.11163868},
  ISSN={2161-8089},
  month={Aug},}@INPROCEEDINGS{11342575,
  author={Mitsuhashi, Daichi and Kanno, Taro},
  booktitle={2025 IEEE International Conference on Systems, Man, and Cybernetics (SMC)}, 
  title={Monoidal Systems and Functional Programming to Reduce Software Complexity in Computer Simulation}, 
  year={2025},
  volume={},
  number={},
  pages={3994-3999},
  abstract={Modeling and computer simulation are effective tools for predicting system behavior. However, simulation software (i.e., source codes), particularly those on social systems, tends to be complicated and un-reusable owing to the complexity, diversity, and ambiguity of the target systems. This makes it difficult to develop, validate, and explain simulation software. One possible solution is to formalize a mathematically rigorous simulation theory and incorporate it directly into a functional programming language. If the mathematical counterpart of the code is clear, coders can easily explain, validate, and extend it. In this study, we define "monoidal system" as the basis to describe the physical and social system that will be modeled. We also conducted an experiment to demonstrate that the introduction of a monoidal system could reduce program complexity in software development.},
  keywords={Codes;Computer simulation;Computational modeling;Source coding;Software;Mathematical models;Complexity theory;Functional programming;Dynamical systems;Software development management;computer simulation;software complexity;dynamical system;monoidal system;functional programming},
  doi={10.1109/SMC58881.2025.11342575},
  ISSN={},
  month={Oct},}@INPROCEEDINGS{11233640,
  author={Adler, Erik and Loevenich, Johannes F. and Spelter, Florian and Hürten, Tobias and Roncevic, Damian and Schwarzer, Maxime and Lopes, Roberto Rigolin F.},
  booktitle={2025 International Conference on Cybersecurity and AI-Based Systems (Cyber-AI)}, 
  title={LLMs for Penetration Testing: Solving CTF Challenges Using Offensive Cybersecurity Tools}, 
  year={2025},
  volume={},
  number={},
  pages={43-50},
  abstract={This paper defines a methodology for using pre-trained large language models (LLMs) to solve capture the flag (CTF) challenges. This investigation is motivated by recent developments introducing frameworks that allow LLMs to execute a set of tools to solve complex problems. The goal is to design and implement realistic red agents capable of executing state-of-the-art offensive tactics/techniques to train blue agents and human cybersecurity experts in gyms, emulated environments, and cyber ranges. Our solution uses a LLM (Claude 3.5 Sonnet) as a CTF Agent, integrating reasoning and tool usage in an iterative loop. In addition, our solution uses a fine-tuned LLM (Quantized LoRA) to automate the generation of code for vulnerability scanning scripts (Mistral 7b). This model interacts with the CTF agent, leveraging cyber threat intelligence to scan the attack surface and identify key areas for penetration testing, thus bridging the gap between CTF-based challenges and offensive security deployments. Our solution is evaluated on an open benchmark with 200 challenges categorized into cryptography, forensics, binary exploitation (pwn), reverse engineering, web exploitation, and miscellaneous, as well as a quantitative evaluation of the fine-tuned Mistral 7b. Experimental results suggest that LLM-based red agents can successfully automate offensive tactics/techniques using the same set of tools available to pen-testers.},
  keywords={Large language models;Forensics;Reverse engineering;Benchmark testing;Cognition;Robustness;Cyber threat intelligence;Iterative methods;Cryptography;Penetration testing;Large Language Models;Penetration Testing;Autonomous Offensive Agents;Capture The Flag},
  doi={10.1109/Cyber-AI66431.2025.11233640},
  ISSN={},
  month={Sep.},}@INPROCEEDINGS{10924896,
  author={Raza, Arif and Xiang, Junfan and Khan, Salabat and Shrivastava, Shivanshu and Ashraf, M. Wasim Abbas and Wang, Lu},
  booktitle={2024 IEEE Smart World Congress (SWC)}, 
  title={Collaborative Multi-Agent Proximal Policy Based Resource Allocation in Clustered IoV Networks}, 
  year={2024},
  volume={},
  number={},
  pages={1737-1745},
  abstract={The Internet of Vehicles (IoV) necessitates efficient resource management to meet the growing demands for high data rates, low latency, and real-time communication in Intelligent Transportation Systems (ITS). This paper presents a novel multiagent reinforcement learning framework based on the Proximal Policy Optimization (PPO) algorithm for optimizing resource allocation in clusters of cells within IoV networks. The framework dynamically allocates transmission power and bandwidth across base stations, each acting as a collaborative agent. Extensive simulations demonstrate that the multi-agent PPO approach outperforms other reinforcement learning algorithms, including Soft Actor-Critic (SAC) and Advantage Actor-Critic (A2C), regarding throughput, power efficiency, dynamic bandwidth allocation, and overall network performance.},
  keywords={Base stations;Heuristic algorithms;Clustering algorithms;Collaboration;Reinforcement learning;Bandwidth;Resource management;Vehicle dynamics;Optimization;Internet of Vehicles;Multi-agent reinforcement learning;Internet of Vehicles (IoV);Resource allocation;Clusters;Base stations;Proximal Policy Optimization (PPO)},
  doi={10.1109/SWC62898.2024.00268},
  ISSN={2993-396X},
  month={Dec},}@INPROCEEDINGS{11385085,
  author={Abbas, Muhammad Naveed and Asghar, Mamoona Naveed},
  booktitle={2025 Cyber Research Conference - Ireland (Cyber-RCI)}, 
  title={Adaptive Cyber-defence: A Reinforcement Learning-based Response to the Evolving Cyber-attacks in Network Security}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={One of the key objectives in any organisational digital network security strategy is to achieve cyber resilience, as online services and networks are vulnerable to threats such as service disruptions and data leaks. While traditional machine learning (ML) approaches have been explored to improve network security, their reliance on fixed heuristics limits adaptability. As network configurations and attack strategies evolve, these methods struggle to recognise novel patterns, exposing critical vulnerabilities. Reinforcement learning (RL) approaches are currently considered state-of-the-art for providing autonomy and adaptability to cyber defence mechanisms. These RL-based defence mechanisms can be robust in detection and response, and adaptive to varying network configurations and attack patterns. Based on these capabilities of RL, this research proposes a cyber defence mechanism powered by an RL-based deep recurrent Q-network with self-attention (SDRQN), which leverages self-attention and recurrence mechanisms. The results of the empirical analysis demonstrate that SDRQN achieved 52.65% more in the 6-Node Network, 49.96% more in the 8-Node Network, and 43.32% more in the 10-Node Network than the closest baseline, demonstrating its adaptability across varying task configurations.},
  keywords={Adaptive systems;Reinforcement learning;Network security;Pattern recognition;Cyberattack;Resilience;adaptive;defensive;cyber;cyber-agent;network security;reinforcement learning},
  doi={10.1109/Cyber-RCI68134.2025.11385085},
  ISSN={},
  month={Dec},}@INPROCEEDINGS{11118628,
  author={Yilmaz, Levent},
  booktitle={2025 Annual Modeling and Simulation Conference (ANNSIM)}, 
  title={Toward Models of Collective Intelligence for Goal-Directed Search in Exploratory Simulation and Analysis}, 
  year={2025},
  volume={},
  number={},
  pages={1-12},
  abstract={In goal-directed exploratory simulations, decentralized search strategies assist in the discovery of system designs and scenarios that exhibit targeted behavior. In problem domains with complex and rugged solution landscapes, exploration and exploitation processes must be carefully balanced to discover novel alternatives for further evaluation. Motivated by the systems model of creativity, this paper explores the use of mechanisms inspired by collective intelligence to mimic the behavior of communities of scientists represented by explorer agents with distinct behavioral traits and preferences. Explorer agents, coupled with individual and social learning strategies, divide their cognitive labor to discover significant epistemic positions in a hypothetical epistemic landscape. The proposed strategies are compared in terms of epistemic progress measured by the percentage of epistemically significant positions discovered and epistemic efficiency defined by the speed with which epistemic peaks are discovered.},
  keywords={Analytical models;Adaptation models;Computational modeling;Biological system modeling;Reinforcement learning;Collective intelligence;Search problems;Problem-solving;Creativity;System analysis and design;exploratory simulation;collective intelligence;systems model of creativity;agent-based simulation},
  doi={},
  ISSN={},
  month={May},}@ARTICLE{11344842,
  author={Teern, Anna and Elgendy, Nada and Kelanti, Markus and Tammia, Henna and Päivärinta, Tero},
  journal={IEEE Access}, 
  title={Systematic Literature Review on Evolvable Knowledge Graphs in Manufacturing}, 
  year={2026},
  volume={14},
  number={},
  pages={8450-8470},
  abstract={This systematic literature review investigates how evolvable knowledge graphs (KGs) enhance manufacturing. Evolvable KGs adapt to changing knowledge by leveraging machine learning algorithms and human expertise to improve decision-making, operational efficiency, and predictive maintenance capabilities beyond the capabilities of prevailing solutions enabled by dynamic KGs. This review maps the existing literature based on the stages of the KG development process. The main results are an updated model of the creation and maintenance of evolvable KGs in manufacturing and a literature-based synthesis of learning approaches for enabling KG evolution through knowledge processing and knowledge utilization. The results contribute to updating the KG development process model and synthesizing an understanding of evolvable KGs that utilize the observed learning approaches on knowledge processing to change KG relations and nodes, and three learning approaches through knowledge utilization (human-guided, machine-driven, and human-machine collaborative knowledge updates). Despite emerging advances, challenges persist in quality assurance, process planning, and integration of human expertise. The findings advocate addressing these issues to promote greater adoption and optimization of KGs in manufacturing. By deepening the understanding of how KGs can evolve through learning, this review sets a conceptual basis for future research to develop more dynamic and intelligent KG-based manufacturing systems.},
  keywords={Manufacturing;Ontologies;Systematic literature review;Semantic Web;Knowledge graphs;Semantics;Linked data;Data mining;Knowledge acquisition;Fifth Industrial Revolution;Knowledge based systems;knowledge graphs;learning systems;manufacturing systems},
  doi={10.1109/ACCESS.2026.3652618},
  ISSN={2169-3536},
  month={},}@INPROCEEDINGS{11011588,
  author={N, Vigneshwaran and Vijayaraj, A. and Murugan, V. P. and Jebakumar, R. and Mageshkumar, N. and Megavannan, R.},
  booktitle={2025 International Conference on Data Science, Agents & Artificial Intelligence (ICDSAAI)}, 
  title={Cognitive Large Language Model in Social Media with Local Memory}, 
  year={2025},
  volume={},
  number={},
  pages={1-5},
