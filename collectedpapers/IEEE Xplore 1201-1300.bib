  booktitle={2025 International Conference on Intelligent Computing, Information and Control Systems (ICOIICS)}, 
  title={An Efficient Deep Learning Framework for Nepali License Plate Recognition Using YOLOv8 and OCR}, 
  year={2025},
  volume={},
  number={},
  pages={800-805},
  abstract={This paper presents a deep learning-based system for automatic recognition of Nepali vehicle license plates using the YOLOv8 object detection framework and Optical Character Recognition (OCR).Unlike many existing license plate recognition systems optimized for Latin characters, this paper addresses the unique challenges posed by non-Latin scripts, which are commonly used in Nepal. These limitations hinder the effectiveness of automated traffic monitoring and vehicle identification in the region. To overcome these challenges, a deep learning-based system is developed, specifically tailored for Nepali license plates. The approach employs the YOLO object detection algorithm to detect vehicles and localize license plates, followed by an OCR module based on a Convolutional Recurrent Neural Network (CRNN) architecture that combines CNNs for feature extraction and LSTMs for sequence modeling of Nepali characters. By supporting the Nepali script, the system aims to enhance the effectiveness of traffic management, law enforcement, and vehicle tracking in Nepal.},
  keywords={Location awareness;YOLO;Accuracy;Recurrent neural networks;Pipelines;Motorcycles;Computer architecture;Robustness;Character recognition;License plate recognition;Nepali character recognition;OCR;YOLOv8;License plate detection;CNN;LSTM},
  doi={10.1109/ICOIICS67115.2025.11390644},
  ISSN={},
  month={Nov},}@INPROCEEDINGS{10628469,
  author={C, Pragyan K},
  booktitle={2024 IEEE 32nd International Requirements Engineering Conference (RE)}, 
  title={Requirements Copilot: Ambiguity Management in Feature Requests}, 
  year={2024},
  volume={},
  number={},
  pages={517-519},
  abstract={The popularity and usage of software applications (apps) among users have encouraged the industry to grow throughout many domains and categories. In today's competitive market, the requirements for apps change rapidly and continuously. Further, these requirements can be introduced through constant feature requests by end-users & other stakeholders of apps through various sources. Such requests are expressed in Natural Language (NL), where they can introduce various types of ambiguity which can lead to misunderstandings between stakeholders, developers, and testers about what feature is actually requested. This can result in wasted time and effort as developers may implement features incorrectly or build the wrong functionality altogether. This proposal aims to tackle ambiguity in feature requests using large language models (LLMs). Ultimately, the objective is to utilize LLMs to develop a practical and interactive framework to support the requirements evaluation phase. Through this framework, the submitted feature & change requests are first evaluated to detect potential ambiguities. Then, interactive negotiations with users are initiated to address such deficiencies.},
  keywords={Industries;Smoothing methods;Large language models;Natural languages;Feature extraction;Software;Stakeholders;Feature Requests;Large Language Models;Ambiguity;Requirement Smells},
  doi={10.1109/RE59067.2024.00069},
