  abstract={Edge caching alleviates backhaul pressure and enhances video service quality by deploying video content near user devices. However, the limited storage capacity of edge servers struggles to cope with the exponential growth of video data, challenging the delivery of high-quality video services. While both Device-to-Device (D2D) caching and multi-bitrate video technology are promising solutions to relieve the pressure on edge servers, existing research suffers from a key limitation: studies on multi-bitrate caching are predominantly focused on the edge layer, while D2D caching is often limited to single-bitrate scenarios. This isolation neglects the significant benefits of integrating D2D caching with multi-bitrate technology and fails to develop a cross-layer caching strategy for multi-bitrate videos. To address this limitation, we propose a D2D-enhanced Multi-bitrate video cAching straTEgy (MATE) for cloud-edge-device collaborative networks. We formulate a joint service latency and caching replacement cost optimization problem, which can be modeled as a mixed-integer programming problem. To overcome the coupling between caching strategies at the edge layer and device layer, we employ an alternating iterative optimization approach to decouple the original problem into two subproblems. We design an edge-device double-layer joint caching strategy, i.e., a device-layer caching strategy based on greedy algorithm and Lagrange multipliers, and an edge-layer caching strategy based on multi-agent twin delayed deep deterministic policy gradient algorithm. Extensive simulations are conducted to demonstrate the effectiveness of the proposed MATE.},
  keywords={Videos;Device-to-device communication;Servers;Bit rate;Costs;Optimization;Collaboration;Quality of service;Federated learning;Mobile handsets;Multi-bitrate video caching;cloud-edge-device collaborative networks;edge caching;D2D caching;deep reinforcement learning},
  doi={10.1109/TMC.2025.3641174},
  ISSN={1558-0660},
  month={},}@INPROCEEDINGS{11210405,
  author={Viswanathan, Chandramouli and Ramakrishnan, Jaishree and Srinivasan, Sathiyandrakumar},
  booktitle={2025 International Conference on Smart & Sustainable Technology (INCSST)}, 
  title={Improvement in Email Security with Machine Learning for Real-Time Phishing Attack Detection: An AI-Based Approach}, 
  year={2025},
  volume={},
  number={},
  pages={1-6},
  abstract={Phishing attacks, which trick users into revealing sensitive information in order to harvest amounts of sensitive or valuable data, represent one of the most enduring cybersecurity issues that affect both individuals and organizations alike. Conventional security measures such as rule-based filtering and blacklisting agents are insufficient in detecting advanced phishing attacks that utilize social engineering and obfuscation techniques. In this research, an AI-based approach is proposed for the improvement of the email security where the machine learning (ML) techniques are utilized for phishing attack detection in real time. Analyzes email headers, body content, embedded URLs, and user behavior patterns using a range of ML techniques such as the supervised learning, deep learning and NLP. We propose a novel hybrid AI model comprising of feature engineering, anomaly detection and reinforcement learning to enhance detection accuracy and reduce false positive rates. According to experimental results, phishing detection systems using ML are proven to be quicker, more efficient, and better able to adapt to new attack patterns compared to traditional ones. By integrating XAI, security solutions powered by AI become more interpretable for cybersecurity professionals due to increased transparency. While there are various challenges including resistant attacks and resource factor calculations, future work can include integrations such as Blockchain-based email authentication, federated learning for decentralized sharing of threat intelligence systems, quantum-resistant cryptographic techniques, to better secure the underlying systems against Phishing attack.},
  keywords={Deep learning;Adaptation models;Accuracy;Phishing;Computational modeling;Real-time systems;Natural language processing;Electronic mail;Security;Load modeling;Phishing detection;natural language processing;email security;explainable AI;adversarial attacks;real-time threat detection;anomaly detection},
  doi={10.1109/INCSST64791.2025.11210405},
  ISSN={},
  month={July},}@ARTICLE{11263809,
  author={Chen, Qinhu and Wang, Wenqiang and Fan, Zeming and Kang, Meilin and Yu, Chuan and Ahn, Ho Seok},
  journal={IEEE Robotics and Automation Letters}, 
  title={RewardRRT: Path Planning for Multi-Degree-of-Freedom Robots in Narrow Environments}, 
  year={2026},
  volume={11},
  number={1},
  pages={730-737},
  abstract={A novel path planning algorithm, RewardRRT, is proposed to address the challenge of Multi-degree-of-freedom robot path planning in narrow environments. In this approach, RewardRRT conceptualizes the sampling tree of Rapidly-exploring Random Trees (RRT) as an agent, assigning a reward value function to each sampled state. Simultaneously, the cumulative reward and reward increment are utilized as the state space, with a linear Kalman Filter applied to predict the state transitions. To enhance convergence speed, a bidirectional expansion strategy is implemented, wherein the tree with the lower cumulative reward prediction is prioritized for iteration. Here, the sampling bias is regulated using a sigmoid function and the prediction value. Finally, simulation tests in 4 distinct point cloud scenarios and a real experiment are conducted using a self-designed 21-degree-of-freedom wheeled humanoid robot. Compared to the best-performing algorithm from the Open Motion Planning Library (OMPL) in the same scenarios, RewardRRT achieves improvements in speed by 38.45%, 8.18%, 9.88%, and 14.98%, respectively. Furthermore, RewardRRT exhibits an average planning success rate of 88.25%, surpassing OMPL's best-performing algorithm by 29.75%. These results underscore the effectiveness of RewardRRT in solving path planning challenges in narrow environments.},
  keywords={Path planning;Robots;Trees (botanical);Manipulators;Planning;Collision avoidance;Heuristic algorithms;Prediction algorithms;Training;Service robots;Whole-body motion planning;constrained motion planning;collision avoidance},
  doi={10.1109/LRA.2025.3635448},
  ISSN={2377-3766},
  month={Jan},}@INPROCEEDINGS{11013241,
