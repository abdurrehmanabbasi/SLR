  month={},}@INPROCEEDINGS{11022301,
  author={Qin, Jing and Jin, Jianqiang and Wang, Zumin and Weng, Wencai and Ai, Qi and Wang, Boao},
  booktitle={2024 8th Asian Conference on Artificial Intelligence Technology (ACAIT)}, 
  title={Colorectal Cancer Target Screening Based on the CSAM-YOLO Algorithm}, 
  year={2024},
