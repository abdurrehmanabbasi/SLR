  journal={IEEE Transactions on Intelligent Transportation Systems}, 
  title={PUF-Enabled Key-Exchange Protocol for Vehicular Ad-Hoc Networks}, 
  year={2025},
  volume={},
  number={},
  pages={1-11},
  abstract={The Internet of Vehicles (IoV) enables data exchange among individuals, cloud resources, road infrastructures, and vehicles, interconnected through Vehicular Ad Hoc Networks (VANETs). VANETs comprise vehicles with Onboard Units (OBUs), Roadside Units (RSUs), and a Trusted Party Agent (TPA). The data transmission among these entities supports seamless interaction and collaborative traffic management. However, data transmission on public communication channels in VANETs presents significant challenges, including security, privacy, and authentication of participating entities. Although numerous key exchange and authentication protocols have been introduced to tackle these issues, many protocols remain vulnerable to various attacks, such as a vehicle, RSU, TPA impersonation, denial of service, physical cloning, and desynchronization attacks. Therefore, to address these vulnerabilities, we propose a key exchange protocol that leverages hash functions and Advanced Encryption Standard (AES) encryption. Our protocol also integrates the Physical Unclonable Function (PUF), enhancing its resistance to physical or cloning attacks. Additionally, it effectively counters threats like impersonation, session key leakage, ephemeral secret leakage, and desynchronization attacks. We validate the security and reliability of our protocol through both formal and informal analysis. Informal analysis highlights the protocol’s essential security features, while formal analysis provides robust substantiation. Performance evaluation reveals that our protocol achieves an average reduction of 35.53%, and 53.77%, in communication and computation overheads.},
  keywords={Protocols;Security;Authentication;Physical unclonable function;Vehicle dynamics;Cloning;Electronic mail;Real-time systems;Threat modeling;Road side unit;Authentication protocol;mutual authentication;key-exchange protocol;key-management;vehicular ad-hoc network},
  doi={10.1109/TITS.2025.3640830},
  ISSN={1558-0016},
  month={},}@ARTICLE{10909716,
  author={Lian, Zirui and Cao, Qianyue and Liang, Chao and Cao, Jing and Zhu, Zongwei and Yang, Zhi and Ji, Cheng and Li, Changlong and Zhou, Xuehai},
  journal={IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems}, 
  title={HaloFL: Efficient Heterogeneity-Aware Federated Learning Through Optimal Submodel Extraction and Dynamic Sparse Adjustment}, 
  year={2025},
  volume={44},
  number={9},
  pages={3518-3531},
  abstract={Federated learning (FL) is an advanced framework that enables collaborative training of machine learning models across edge devices. An effective strategy to enhance training efficiency is to allocate the optimal submodel based on each device’s resource capabilities. However, system heterogeneity significantly increases the difficulty of allocating submodel parameter budgets appropriately for each device, leading to the straggler problem. Meanwhile, data heterogeneity complicates the selection of the optimal submodel structure for specific devices, thereby impacting training performance. Furthermore, the dynamic nature of edge environments, such as fluctuations in network communication and computational resources, exacerbates these challenges, making it even more difficult to precisely extract appropriately sized and structured submodels from the global model. To address the challenges in heterogeneous training environments, we propose an efficient FL framework, namely, HaloFL. The framework dynamically adjusts the structure and parameter budget of submodels during training by evaluating three dimensions: 1) model-wise performance; 2) layer-wise performance; and 3) unit-wise performance. First, we design a data-aware model unit importance evaluation method to determine the optimal submodel structure for different data distributions. Next, using this evaluation method, we analyze the importance of model layers and reallocate parameters from noncritical layers to critical layers within a fixed parameter budget, further optimizing the submodel structure. Finally, we introduce a resource-aware dual-UCB multiarmed bandit agent, which dynamically adjusts the total parameter budget of submodels according to changes in the training environment, allowing the framework to better adapt to the performance differences of heterogeneous devices. Experimental results demonstrate that HaloFL exhibits outstanding efficiency in various dynamic and heterogeneous scenarios, achieving up to a 14.80% improvement in accuracy and a  $3.06\times $  speedup compared to existing FL frameworks.},
  keywords={Servers;Computational modeling;Performance evaluation;Data models;Data mining;Optimization;Integrated circuit modeling;Federated learning;Edge computing;Dynamic scenarios;edge computing;embedded systems;federated learning (FL);heterogeneous training},
  doi={10.1109/TCAD.2025.3548003},
  ISSN={1937-4151},
  month={Sep.},}@INPROCEEDINGS{11376210,
  author={Ganapam, Madan Mohan and Venkata Anjani Kumar, G and Kasa, Moulika},
  booktitle={2025 5th International Conference on Emerging Research in Electronics, Computer Science and Technology (ICERECT)}, 
  title={Integrating Generative AI into Digital Transformation: A Unified Pilot-to-Production Framework for Key Economic Sectors}, 
  year={2025},
  volume={},
  number={},
  pages={1-8},
  abstract={Generative AI (GenAI) is set to become the next big investment area for enterprises globally, but in most cases, when the proof of concept is promising, organizations are finding it difficult to get the proof of concept into production and into a system that delivers actual business value. In this paper presents a unified framework for scaling GenAI across healthcare, finance, retail, and manufacturing and validate the framework by exploring nontrivial scaling applications with industry clients. Eight 12 month longitudinal case studies plus a survey of 212 executives are employed for triangulation via technical telemetry, organizational-readiness metrics, and 10 year cost-benefit models. Our results show that (i) data platform maturity is the strongest accelerator of time until production (β=0.42,p<0.001), (ii) the adoption of ISO 42001's governance reduces 100 years ¼ severity incident risk and preserves as much as nine percent of net present value, and (iii) internal rate of return of median deployment is 41%, and payback takes a year or less for all deployments. There is a five level maturity ladder that ranges from ideation sandboxes to autonomous GenAI agents that links incremental capability building to gating KPIs and risk controls. Drawing from dynamic-capabilities theory, this study extends the theory by providing a specification of how they must co-evolve in order to convert transient pilots into durable advantage in the form of LLMOps, trust layers and "fusion teams." Guided by evidence based playbook, executives are equipped with concrete steps to make strategy, data fabric, culture and governance work hand in hand to take pilots out of the lab to production and get the cross-industry potential of GenAI unlocked.},
  keywords={Surveys;Industries;Generative AI;Biological system modeling;Finance;Production;Medical services;Manufacturing;Telemetry;Transient analysis;Generative AI (GenAI);pilot-to-production;data-platform maturity;Scaling AI;Dynamic capabilities},
